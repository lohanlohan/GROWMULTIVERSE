<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer item="ITEM_ID_BUSTER_BRUSH">
    <Data>
        <StateMachines>
            <StateMachine name="playerState">
                <States>
                    <State name="Equip"/>
                    <State name="Fall"/>
                    <State name="Punch"/>
                </States>
                <Transitions>
                    <Transition from="Equip" to="Fall">
                        <Condition>
                            <IsAction>FALL</IsAction>
                        </Condition>
                    </Transition>
                    <Transition from="Fall" to="Equip">
                        <Condition>
                            <IsAction operatorType="NotEqual">FALL</IsAction>
                        </Condition>
                    </Transition>
                    <Transition from="Equip|Fall" to="Punch">
                        <Condition>
                            <IsAction>PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition from="Punch" to="Equip">
                        <Condition type="and">
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                            <IsAction operatorType="NotEqual">FALL</IsAction>
                        </Condition>
                    </Transition>
                    <Transition from="Punch" to="Fall">
                        <Condition type="and">
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                            <IsAction>FALL</IsAction>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
            <StateMachine name="trailParticleState">
                <States>
                    <State name="Equip"/>
                    <State name="HorizontalMove"/>
                    <State name="Punch"/>
                    <State name="Sleep"/>
                </States>
                <Transitions>
                    <Transition from="Equip|HorizontalMove|Punch" to="Sleep">
                        <Condition>
                            <IsSleepingOnaBed>true</IsSleepingOnaBed>
                        </Condition>
                    </Transition>
                    <Transition from="Equip|HorizontalMove|Sleep" to="Punch">
                        <Condition>
                            <IsAction>PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition from="Punch|HorizontalMove|Sleep" to="Equip">
                        <Condition type="and">
                            <IsSleepingOnaBed>false</IsSleepingOnaBed>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                            <IsVariableFloat name="speed.x" operator="Less" abs="true">0.1</IsVariableFloat>
                        </Condition>
                    </Transition>
                    <Transition from="Punch|Equip|Sleep" to="HorizontalMove">
                        <Condition type="and">
                            <IsSleepingOnaBed>false</IsSleepingOnaBed>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                            <IsVariableFloat name="speed.x" operator="Greater" abs="true">0.1</IsVariableFloat>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
        </StateMachines>
        <Sprite name="pauldron_sprite" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="0,0"/>
        <Sprite name="equip_sprite" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="0,0"/>
        <Sprite name="fall_sprite" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="0,0"/>
        <Sprite name="slash_sprite" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="1,0"/>
        <Sprite name="trail_drops_sprite" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="15,0"/>
        <Sprite name="block_hit_sprite" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="14,0"/>
        <Sprite name="punch_projectile_sprite" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="8,0"/>
        <Sprite name="black_destoryedTile" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="17,0"/>
        <Sprite name="moonslash1" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="8,0"/>
        <Sprite name="moonslash2" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="9,0"/>
        <Sprite name="block_moon_sprite" fileName="game//mk4_demonicFlesh.rttex" textureSize="80" frame="16,0"/>
        <Animations>
            <SpriteAnimation name="slash_animation" sprite="slash_sprite" animTime="400" isLoop="true" playOnState="playerState.Punch">
                <Frame>1,0</Frame>
                <Frame>2,0</Frame>
                <Frame>3,0</Frame>
                <Frame>4,0</Frame>
                <Frame>5,0</Frame>
                <Frame>6,0</Frame>
                <Frame>7,0</Frame>
            </SpriteAnimation>
        </Animations>
        <RenderOptions>
            <Default>
                <Set name="DefaultRenderMannequinHandItem">false</Set>
                <Set name="HideParticlesOnTransform">false</Set>
                <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
                <Set name="RenderBackArmBuild">false</Set>
                <Set name="RenderFrontArmInfected">true</Set>
                <Set name="RenderBackArmInfected">true</Set>
                <Set name="UserNameOffset">21</Set>
            </Default>
        </RenderOptions>
        <ParticleSystems>
            <ParticleSystem name="drop_particles" updateStage="AddClothingParticles" updateState="trailParticleState.Equip" renderStage="RenderHandItem">
                <Emitter>
                    <Set name="offset">-45, -46</Set>
                    <Set name="emissionInterval">0.1</Set>
                    <Set name="forceXScaling">true</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle velocityRelativeToPlayerSpeed="true">
                    <Set name="sprite">trail_drops_sprite</Set>
                    <Random name="offset" min="-7, -2" max="4, 0"/>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="rotateWithVelocity">true</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.8, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Set name="useGravity">true</Set>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.5, 0.5</KeyFrame>
                        <KeyFrame>0.8, 0.8, 0.8</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">1</Set>
                    <Set name="initialVelocity">-10, -40</Set>
                    <Set name="gravityVector">0, 95</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="drop_particles_move" updateStage="AddClothingParticles" updateState="trailParticleState.HorizontalMove">
                <Emitter>
                    <Set name="offset">-49, -40</Set>
                    <Set name="emissionInterval">0.1</Set>
                    <Set name="forceXScaling">true</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">3</Set>
                </Emitter>
                <Particle velocityRelativeToPlayerSpeed="true">
                    <Set name="sprite">trail_drops_sprite</Set>
                    <Random name="offset" min="-18, -8" max="15, 8"/>
                    <Set name="rotateWithVelocity">true</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.8, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Set name="useGravity">true</Set>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.5, 0.5</KeyFrame>
                        <KeyFrame>1, 1, 1</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">0.8</Set>
                    <Set name="initialVelocity">-10, -40</Set>
                    <Set name="gravityVector">0, 100</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="punch_projectile" updateStage="OnPunchStart">
                <Emitter>
                    <Set name="offset">10,-16</Set>
                    <Set name="lifeTime">0.7</Set>
                    <Set name="particlesPerEmission">2</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">moonslash1</Set>
                    <Set name="rotateWithVelocity">true</Set>
                    <Set name="lifeTime">0.4</Set>
                    <Set name="useGravity">true</Set>
                    <Curve name="initialScale">
                        <KeyFrame>1.6, 1.6, 1.6</KeyFrame>
                        <KeyFrame>2, 2, 2</KeyFrame>
                    </Curve>
                    <VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="punch_projectile2" updateStage="OnPunchStart">
                <Emitter>
                    <Set name="offset">30,-17</Set>
                    <Set name="lifeTime">0.7</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">moonslash2</Set>
                    <Set name="rotateWithVelocity">true</Set>
                    <Set name="lifeTime">0.4</Set>
                    <Curve name="initialScale">
                        <KeyFrame>1.6, 1.6, 1.6</KeyFrame>
                        <KeyFrame>2.5, 2.5, 2.5</KeyFrame>
                    </Curve>
                    <VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="tile_break_particle" updateStage="OnDestroyedTile">
                <Emitter>
                    <Set name="particlesPerEmission">50</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">black_destoryedTile</Set>
                    <Set name="rotateWithVelocity">true</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Set name="useGravity">true</Set>
                    <Curve name="initialScale">
                        <KeyFrame>0.8, 0.8, 0.8</KeyFrame>
                        <KeyFrame>1.3, 1.3, 1.3</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">1</Set>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="25,60"/>
                    <Set name="gravityVector">10, 30</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="tile_hit_particle" updateStage="OnDamagedTile">
                <Emitter>
                    <Set name="lifeTime">0.9</Set>
                    <Set name="particlesPerEmission">9</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">block_hit_sprite</Set>
                    <Set name="offset">0,0</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.6, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0.2, 0.2, 0.2</KeyFrame>
                        <KeyFrame>1.2, 1.2, 1.2</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">1</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="tile_hit_splash" updateStage="OnDamagedTile">
                <Emitter>
                    <Set name="particlesPerEmission">16</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">block_moon_sprite</Set>
                    <Set name="rotateWithVelocity">true</Set>
                    <Set name="lifeTime">1.3</Set>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="40,60"/>
                    <Curve name="initialScale">
                        <KeyFrame>0, 1, 1</KeyFrame>
                        <KeyFrame>1, 0.25, 0.25</KeyFrame>
                    </Curve>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 0.8</KeyFrame>
                        <KeyFrame>0.5, 0.5</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Random name="posOffset" min="-2,-2" max="2,2"/>
                    <Random name="initialRotationRate" min="-10" max="300"/>
                </Particle>
            </ParticleSystem>
        </ParticleSystems>
    </Data>
    <RenderRules>
        <Update>
            <StopIf>
                <IsZombified>true</IsZombified>
            </StopIf>
            <AvatarTransform class="ArmAngle" onState="playerState.Equip|playerState.Fall">
                <Set name="armName">arm1Angle</Set>
                <Set name="armAngle">215</Set>
            </AvatarTransform>
        </Update>
        <RenderBackHandItem>
            <StopIf type="and">
                <IsZombified>true</IsZombified>
                <IsAction>PUNCH</IsAction>
            </StopIf>
            <SpriteRender name="equip_sprite" offset="27,3.1" rotationPoint="0,1" flip="0,1" alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" scale="1.1,1.1" onState="playerState.Equip|playerState.Punch"/>
            <SpriteRender name="fall_sprite" offset="27,3.1" rotationPoint="0,1" flip="0,1" alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" scale="1.1,1.1" onState="playerState.Fall"/>
        </RenderBackHandItem>
        <RenderInFront>
            <StopIf>
                <IsZombified>true</IsZombified>
            </StopIf>
            <SpriteRender name="slash_sprite" offset="30,-14" scale="1.6,1.6" alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" onState="playerState.Punch" drawShadow="false" tintOverride="255,255,255,255"/>
        </RenderInFront>
        <AddClothingParticles>
            <StopIf type="or">
                <IsZombified>true</IsZombified>
                <IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
                <IsWearing slot="SHOES">ITEM_ID_STAR_FIGHTER_REBEL_RAIDER</IsWearing>
                <IsWearing slot="SHOES">ITEM_ID_STAR_FIGHTER_IMPERIAL_ENFORCER</IsWearing>
            </StopIf>
        </AddClothingParticles>
        <OnPunchStart>
            <ParticleSystemUpdate name="punch_projectile"/>
            <StopIf>
                <IsZombified>true</IsZombified>
            </StopIf>
        </OnPunchStart>
        <RenderFrontpack>
            <SpriteRender name="pauldron_sprite" offset="0,-14"/>
        </RenderFrontpack>
        <OnPunchUpdate>
            <StopIf>
                <IsZombified>true</IsZombified>
            </StopIf>
            <AvatarTransform class="Face">
                <Set name="face">MAD</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle" onState="playerState.Equip|playerState.Fall">
                <Set name="armName">arm1Angle</Set>
                <Set name="armAngle">215</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle" onState="playerState.Punch">
                <Set name="armName">arm1Angle</Set>
                <Set name="armAngle">1250</Set>
                <Set name="isAdditive">true</Set>
                <Set name="pointTowardsPunchTarget">false</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle" onState="playerState.Punch">
                <Set name="armName">arm2Angle</Set>
                <Set name="armAngle">0</Set>
            </AvatarTransform>
        </OnPunchUpdate>
        <SwitchOffClothingParticles>
            <ParticleSystemOff name="punch_projectile"/>
            <ParticleSystemOff name="punch_projectile2"/>
            <ParticleSystemOff name="drop_particles"/>
            <ParticleSystemOff name="drop_particles_move"/>
            <ParticleSystemOff name="tile_break_particle"/>
            <ParticleSystemOff name="tile_hit_particle"/>
            <ParticleSystemOff name="tile_hit_splash"/>
        </SwitchOffClothingParticles>
    </RenderRules>
</ItemRenderer>
