<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
            <StateMachine name="Dance">
                <States>
                    <State name="False" />
                    <State name="True" />
                </States>
                <Transitions>
                    <Transition from="False" to="True">
                        <Condition>
                            <IsDancing>true</IsDancing>
                        </Condition>
                    </Transition>
                    <Transition from="True" to="False">
                        <Condition>
                            <IsDancing>false</IsDancing>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
		</StateMachines>
		
	<Sprite name="s_Necklace" fileName="game/custom_cosmetics1.rttex" textureSize="32" frame="24,9"/>
	<Sprite name="s_Fireworks" fileName="game/particles.rttex" textureSize="32"/>
	<Sprite name="s_Smoke" fileName="game/particles.rttex" textureSize="32"/>

	    <Animations>
  		    <SpriteAnimation name="A_FireworkSprites" sprite="s_Fireworks">
    		    <Frame>8,2</Frame>
    		    <Frame>9,2</Frame>
        	    <Frame>10,2</Frame>
                <Frame>11,2</Frame>
		    </SpriteAnimation>
  		    <SpriteAnimation name="A_SmokeAnimation" sprite="s_Smoke" autoPlay="true" isLoop="false" animTime="350">
    		    <Frame>0,0</Frame>
    		    <Frame>1,0</Frame>
        	    <Frame>2,0</Frame>
                <Frame>3,0</Frame>
    		    <Frame>4,0</Frame>
    		    <Frame>5,0</Frame>
        	    <Frame>6,0</Frame>
                <Frame>7,0</Frame>
    		    <Frame>8,0</Frame>
    		    <Frame>9,0</Frame>
		    </SpriteAnimation>
        </Animations>

	    <ParticleSystems>
			<ParticleSystem name="ps_Dance">
				<Emitter>
					<Set name="offset">4, -16</Set>
					<Random name="emissionInterval" min="0.25" max="0.5"/>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_Fireworks</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.75, 1</KeyFrame>
						<KeyFrame>1, 1</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.5, 0.25</KeyFrame>
						<KeyFrame>1, 1, 0.5</KeyFrame>
					</Curve>
					<Set name="lifeTime">1</Set>
					<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="100,150" />
                    <OnFinish>
                        <ParticleSystemName>onFinishSmoke_PS</ParticleSystemName>
						<ParticleSystemName>onFinish_PS</ParticleSystemName>
                    </OnFinish>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="onFinish_PS">
				<Emitter>
					<Set name="particlesPerEmission">36</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_Fireworks</Set>
          			<Set name="blendingMode">ADDITIVE</Set>
          			<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
              			<KeyFrame>0.75, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.5, 0.25</KeyFrame>
						<KeyFrame>1, 1, 0.5</KeyFrame>
					</Curve>
                    <Set name="rotateWithVelocity">true</Set>
					<Set name="useGravity">true</Set>
					<Random name="lifeTime" min="1" max="1.25"/>
					<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="150,200"/>
					<Set name="gravityVector">0, 130</Set>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="onFinishSmoke_PS">
				<Emitter>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_Smoke</Set>
          			<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="inSpecificOrder">false</Set>
          			<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 1</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1, 1</KeyFrame>
						<KeyFrame>1, 1, 1</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.35</Set>
				</Particle>
			</ParticleSystem>
	    </ParticleSystems>
  </Data>

  <RenderRules>
	<RenderInFront value="playerCenter">
		<MusicSource onState="Dance.True">
			<Set name="ItemID">ITEM_ID_PARTY_BOOMBOX</Set>
			<Set name="FadeOutTimeMs">500</Set>
		</MusicSource>
	</RenderInFront>

	<RenderChestItem>
	  	<SpriteRender name="s_Necklace" offset="0,-15" alignment="CENTER" blend="PREMULTIPLIED_ALPHA" drawShadow="false"/>
    </RenderChestItem>

	<AddClothingParticles>
		<ParticleSystemUpdate name="ps_Dance" onState="Dance.True"/>
	</AddClothingParticles>

	<SwitchOffClothingParticles>
		<ParticleSystemOff name="ps_Dance"/>
	</SwitchOffClothingParticles>
  </RenderRules>
</ItemRenderer>