<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="s_EdgeSlash" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="9,4"/>
		<Sprite name="s_Edge" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="0,4"/>
		<Sprite name="s_EdgeGlow" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="5,5"/>
        <Sprite name="s_PunchProjectiles" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="6,5"/>
        <Sprite name="s_EdgeParticles" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>
        <Sprite name="s_OnHit_EdgeParticles" fileName="game/exo_logo.rttex" textureSize="303x284"/>
        <Sprite name="s_Respawn_EdgeParticles" fileName="game/exo_logo.rttex" textureSize="303x284"/>

		<Animations>
			<SequenceAnimation name="a_sword" autoPlay="true" isLoop="false">
                <SpriteAnimation sprite="s_Edge" autoPlay="true" animTime="1000" isLoop="false">
					<Frame>0,4</Frame>
				</SpriteAnimation>
                <DelayAnimation delayTime="750" />
                <SpriteAnimation sprite="s_Edge" autoPlay="true" animTime="175" isLoop="false">
					<Frame>1,4</Frame>
					<Frame>2,4</Frame>
					<Frame>3,4</Frame>
       			    <Frame>4,4</Frame>
        		    <Frame>5,4</Frame>
					<Frame>6,4</Frame>
					<Frame>7,4</Frame>
					<Frame>8,4</Frame>
				</SpriteAnimation>

				<SpriteAnimation sprite="s_Edge" autoPlay="true" animTime="2000" isLoop="true">
       			    <Frame>8,4</Frame>
				</SpriteAnimation>
			</SequenceAnimation>

			<SequenceAnimation name="a_swordGlow" autoPlay="true" isLoop="true">
                <DelayAnimation delayTime="2500" />
                <SpriteAnimation sprite="s_EdgeGlow" autoPlay="true" animTime="275" isLoop="false">
					<Frame>0,5</Frame>
					<Frame>1,5</Frame>
					<Frame>2,5</Frame>
       			    <Frame>3,5</Frame>
        		    <Frame>4,5</Frame>
					<Frame>5,5</Frame>
				</SpriteAnimation>
                <DelayAnimation delayTime="6342" />
                <SpriteAnimation sprite="s_EdgeGlow" autoPlay="true" animTime="275" isLoop="false">
					<Frame>0,5</Frame>
					<Frame>1,5</Frame>
					<Frame>2,5</Frame>
       			    <Frame>3,5</Frame>
        		    <Frame>4,5</Frame>
					<Frame>5,5</Frame>
				</SpriteAnimation>
                <DelayAnimation delayTime="12450" />
                <SpriteAnimation sprite="s_EdgeGlow" autoPlay="true" animTime="275" isLoop="false">
					<Frame>0,5</Frame>
					<Frame>1,5</Frame>
					<Frame>2,5</Frame>
       			    <Frame>3,5</Frame>
        		    <Frame>4,5</Frame>
					<Frame>5,5</Frame>
				</SpriteAnimation>
                <DelayAnimation delayTime="1234" />
                <SpriteAnimation sprite="s_EdgeGlow" autoPlay="true" animTime="275" isLoop="false">
					<Frame>0,5</Frame>
					<Frame>1,5</Frame>
					<Frame>2,5</Frame>
       			    <Frame>3,5</Frame>
        		    <Frame>4,5</Frame>
					<Frame>5,5</Frame>
				</SpriteAnimation>
			</SequenceAnimation>

			<SequenceAnimation name="a_swordslash" autoPlay="false" isLoop="false" playOnAction="PUNCH">
                <SpriteAnimation sprite="s_EdgeSlash" autoPlay="true" animTime="175" isLoop="false">
					<Frame>9,4</Frame>
					<Frame>10,4</Frame>
					<Frame>11,4</Frame>
       			    <Frame>12,4</Frame>
				</SpriteAnimation>

				<SpriteAnimation sprite="s_EdgeSlash" autoPlay="true" animTime="2000" isLoop="true">
       			    <Frame>12,4</Frame>
				</SpriteAnimation>
			</SequenceAnimation>

            <SpriteAnimation name="a_PunchParticles" sprite="s_PunchProjectiles" autoPlay="true" animTime="425" isLoop="false">
                <Frame>6,5</Frame>
                <Frame>7,5</Frame>
				<Frame>8,5</Frame>
				<Frame>9,5</Frame>
            </SpriteAnimation>

            <SpriteAnimation name="a_Particles" sprite="s_EdgeParticles">
                <Frame>12,4</Frame>
                <Frame>13,4</Frame>
                <Frame>14,4</Frame>
            </SpriteAnimation>

            <SpriteAnimation name="a_Particles" sprite="s_OnHit_EdgeParticles" autoPlay="true" isLoop="true" animTime="800">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
                <Frame>2,0</Frame>
                <Frame>3,0</Frame>
                <Frame>4,0</Frame>
				<Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>7,0</Frame>
            </SpriteAnimation>

			<SpriteAnimation name="a_resp" sprite="s_Respawn_EdgeParticles" autoPlay="true" animTime="800" isLoop="false">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
                <Frame>2,0</Frame>
                <Frame>3,0</Frame>
                <Frame>4,0</Frame>
				<Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>7,0</Frame>
			</SpriteAnimation>
		</Animations>
		
		<ParticleSystems>
			<ParticleSystem name="Punch_Ps" updateStage="OnPunchStart">
				<Emitter attachment="targetPos">
                    <Set name="emissionInterval">0.25</Set>
					<Random name="offset" min="-16,16" max="16,-16"/>
					<Set name="lifeTime">0</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_PunchProjectiles</Set>
					<Set name="offset">0, 0</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.75</Set>
                    <Random name="initialAngle" min="0" max="360"/>
				        <Curve name="initialAlpha">
					        <KeyFrame>0, 1</KeyFrame>
					        <KeyFrame>0.25, 1</KeyFrame>
					        <KeyFrame>1, 0</KeyFrame>
				        </Curve>
				        <Curve name="initialScale">
            		        <KeyFrame>0, 0.6,0.2</KeyFrame>
            		        <KeyFrame>1, 0.6,0.2</KeyFrame>
          		        </Curve>
				</Particle>
			</ParticleSystem>

		 	<ParticleSystem name="OnHit_Ps">
				<Emitter>
					<Random name="offset" min="-1,-1" max="1,1"/>
					<Set name="lifeTime">3.75</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle>
					<Random name="offset" min="-1,-1" max="1,1"/>
					<Set name="sprite">s_OnHit_EdgeParticles</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">3.75</Set>
					<Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.9, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
					</Curve>
				    <Curve name="initialScale">
            		    <KeyFrame>0, 0.2,0.2</KeyFrame>
            		    <KeyFrame>1, 0.2,0.2</KeyFrame>
          		    </Curve>
				</Particle>
			</ParticleSystem>

            <ParticleSystem name="OnHitTrail_Ps">
                <Emitter>
                    <Random name="emissionInterval" min="0.02" max="0.03" />
                    <Set name="infParticles">true</Set>
                    <Set name="lifeTime">0.28</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle randomSpriteFrame="true">
                    <Set name="sprite">s_EdgeParticles</Set>
                    <Set name="renderAlignment">CENTER</Set>
                    <Set name="blendingMode">ADDITIVE</Set>
                    <Random name="offset" min="-1, 1" max="1, -1" />
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.9, 1</KeyFrame>
                        <KeyFrame>0.92, 0.1</KeyFrame>
                        <KeyFrame>0.94, 1</KeyFrame>
                        <KeyFrame>0.96, 0.1</KeyFrame>
                        <KeyFrame>0.98, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.2, 0.2</KeyFrame>
                        <KeyFrame>0.65, 0.32, 0.32</KeyFrame>
                        <KeyFrame>1, 0.2, 0.2</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">0.25</Set>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="2,4" />
                </Particle>
            </ParticleSystem>

			<ParticleSystem name="Killed_ps" secondary="OnHitTrail_Ps" renderStage="RenderInFront">
				<Emitter>
                    <Set name="offset">0, -10</Set>
				    <Set name="particlesPerEmission">2</Set>
                    <Set name="emissionInterval">0.05</Set>
                    <Set name="infParticles">true</Set>
				    <Set name="infLifeTime">false</Set>
                    <Set name="lifeTime">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
                    <Set name="offset">0, -5</Set>
				    <Set name="sprite">s_OnHit_EdgeParticles</Set>
				    <Set name="blendingMode">ADDITIVE</Set>
				    <Curve name="initialAlpha">
					    <KeyFrame>0, 1</KeyFrame>
					    <KeyFrame>1, 0</KeyFrame>
				    </Curve>
				    <Curve name="initialScale">
            		    <KeyFrame>0, 0.075,0.075</KeyFrame>
            		    <KeyFrame>1, 0.075,0.075</KeyFrame>
          		    </Curve>
				    <Set name="lifeTime">0.5</Set>
				    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="80,200"/>
                    <Set name="rotateWithVelocity">true</Set>
				</Particle>
			</ParticleSystem>

		 	<ParticleSystem name="OnDestroyed_Ps" secondary="OnHitTrail_Ps">
				<Emitter>
					<Random name="offset" min="-8,-8" max="8,8"/>
					<Set name="lifeTime">0.5</Set>
					<Set name="particlesPerEmission">12</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle>
					<Random name="offset" min="-8,-8" max="8,8"/>
					<Set name="sprite">s_OnHit_EdgeParticles</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">0.5</Set>
					<Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.9, 1</KeyFrame>
                        <KeyFrame>0.92, 0.1</KeyFrame>
                        <KeyFrame>0.94, 1</KeyFrame>
                        <KeyFrame>0.96, 0.1</KeyFrame>
                        <KeyFrame>0.98, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
					</Curve>
				    <Curve name="initialScale">
            		    <KeyFrame>0, 0.05,0.05</KeyFrame>
            		    <KeyFrame>1, 0.05,0.05</KeyFrame>
          		    </Curve>
					<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="80,200"/>
					<Set name="rotateWithVelocity">true</Set>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="ps_resp" renderStage="RenderInFront">
				<Emitter>
				<Set name="offset">0,-27</Set>
				<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
				<Set name="sprite">s_Respawn_EdgeParticles</Set>
				<Set name="blendingMode">ADDITIVE</Set>
				<Set name="offset">0,-27</Set>
				<Curve name="initialAlpha">
					<KeyFrame>0, 1</KeyFrame>
					<KeyFrame>1, 0</KeyFrame>
				</Curve>
				<Curve name="initialScale">
					<KeyFrame>2, 0.5, 0.5</KeyFrame>
				</Curve>
				<Set name="lifeTime">3</Set>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>

		<TileStampData>
			<Set name="FileName">game/enigma_particles_small2.rttex</Set>
			<Set name="EndFrame">15,5</Set>
			<Set name="FrameCount">4</Set>
		</TileStampData>

		<RenderOptions>
			<Default>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
                <Set name="PunchSoundOverride">HAND</Set>
				<Set name="PlayDefaultPunchAudio">false</Set>
				<Set name="HideAngelOnDeath">true</Set>
       			<Set name="HideAvatarOnDeath">true</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderHandItem>
			<SpriteRender name="s_Edge" rotateOffset="true" offset="40,4" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
			<SpriteRender name="s_EdgeGlow" rotateOffset="true" offset="40,4" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
			<SpriteRender name="s_EdgeSlash" rotateOffset="true" offset="40,4" alignment="CENTER" blend="PREMULTIPLIED_ALPHA" onAction="PUNCH"/>
		</RenderHandItem>

		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
		    <AvatarTransform class="ArmAngle">
			    <Set name="armName">arm2Angle</Set>
			    <Set name="armAngle">1750</Set>
			    <Set name="isAdditive">true</Set>
			    <Set name="pointTowardsPunchTarget">false</Set>
		    </AvatarTransform>
		</OnPunchUpdate>

	    <OnDamagedTile>
		    <ParticleSystemUpdate name="OnHit_Ps"/>
	    </OnDamagedTile>
	    <OnDestroyedTile>
		    <ParticleSystemUpdate name="OnDestroyed_Ps"/>
	    </OnDestroyedTile>

		<OnKilled>
			<ParticleSystemUpdate name="Killed_ps" />
		</OnKilled>
		<OnRespawned>
			<ParticleSystemUpdate name="ps_resp"/>
		</OnRespawned>

	    <SwitchOffClothingParticles>
		    <ParticleSystemOff name="OnHit_Ps"/>
			<ParticleSystemOff name="OnDestroyed_Ps"/>
			<ParticleSystemOff name="Killed_ps"/>
			<ParticleSystemOff name="ps_resp"/>
	    </SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>