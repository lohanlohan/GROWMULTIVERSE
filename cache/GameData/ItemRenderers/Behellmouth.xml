<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="Land">
				<States>
					<State name="Idle" />
					<State name="Punch"/>
					<State name="Move" />
					<State name="Jump" />
					<State name="Fall" />
				</States>
				<Transitions>
					<Transition to="Idle" from="Fall|Move|Punch">
						<Condition type="and">
							<IsVariableBool name="onGround">true</IsVariableBool>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Punch" from="Idle|Move|Jump|Fall" >
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Move" from="Jump|Fall|Idle|Punch">
						<Condition type="and">
							<IsVariableBool name="onGround">true</IsVariableBool>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Jump" from="Idle|Move|Fall|Punch">
						<Condition type="and">
							<IsVariableBool name="onGround">false</IsVariableBool>
							<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Fall" from="Jump|Idle|Move|Punch">
						<Condition type="and">
							<IsVariableBool name="onGround">false</IsVariableBool>
							<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="trailParticleState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
				</States>
				<Transitions>
					<Transition from="Idle" to="Move" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="Move" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Swim">
				<States>
					<State name="No"/>
					<State name="Yes"/>
				</States>
				<Transitions>
					<Transition from="No" to="Yes" >
						<Condition>
							<IsVariableBool name="onGround">false</IsVariableBool>
						</Condition>
					</Transition>
					<Transition from="Yes" to="No" >
						<Condition>
							<IsVariableBool name="onGround">true</IsVariableBool>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Punch">
				<States>
					<State name="No"/>
					<State name="Yes"/>
				</States>
				<Transitions>
					<Transition from="No" to="Yes" >
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition from="Yes" to="No" >
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Health">
				<States>
					<State name="Alive"/>
					<State name="DeathAnim" ExitTime="0.6"/>
					<State name="Dead" ExitTime="0.1"/>
					<State name="PreSpawn" ExitTime="0.2"/>
					<State name="SpawnL" ExitTime="0.55"/>
					<State name="SpawnR" ExitTime="0.55"/>
				</States>
				<Transitions>
					<Transition from="Alive" to="DeathAnim" >
						<Condition>
							<IsAction>DIE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DeathAnim" to="Dead"/>
					<Transition from="Dead" to="PreSpawn" >
						<Condition>
							<IsAction operatorType="NotEqual">DIE</IsAction>
						</Condition>
					</Transition>
					<Transition from="PreSpawn" to="SpawnL">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition from="PreSpawn" to="SpawnR">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition from="SpawnL" to="Alive" />
					<Transition from="SpawnR" to="Alive" />
				</Transitions>
			</StateMachine>
			<StateMachine name="Mobility">
				<States>
					<State name="Stationary"/>
					<State name="Moving"/>
				</States>
				<Transitions>
					<Transition to="Stationary" from="Moving">
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition to="Moving" from="Stationary">
						<Condition>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

