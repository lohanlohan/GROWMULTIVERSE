				<Set name="IgnoreDefaultDamagedTileEffect">false</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">false</Set>
				<Set name="AllowChangePunchType">true</Set>
				<Set name="IncludeAllActions">true</Set>
				<Set name="HideAvatarOnDeath">true</Set>
				<Set name="HideAngelOnDeath">false</Set>
				<Set name="HasDeathParticles">true</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<Update>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<AvatarTransform class="FootPosition">
				<Set name="foot1dy">0</Set>
				<Set name="foot2dy">0</Set>
				<Set name="foot1y">0</Set>
				<Set name="foot2y">0</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle" onState="Mobility.Moving">
				<Set name="armName">arm2Angle</Set>
				<Set name="armAngle">45</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle" onState="Mobility.Moving">
				<Set name="armName">arm1Angle</Set>
				<Set name="armAngle">-45</Set>
			</AvatarTransform>
		</Update>
		<RenderShoes>
			<StopIf>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<ParticleSystemUpdate name="ps_trail" onState="trailParticleState.Move"/>
			
		</RenderShoes>
		<RenderInFront value="playerCenter">
			<StopIf type="or">
				<IsZombified>true</IsZombified>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
			<Group onState="Health.Alive">
				<Group onState="Swim.No">
					<SpriteRender name="s_land_foot1" offset="-0,-12" alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER"/>
					<SpriteRender name="s_land_foot2" offset="-0,-12" alignmentLeft="RIGHT_CENTER" alignmentRight="LEFT_CENTER"/>
				</Group>
				<Group onState="Swim.Yes">
					<SpriteRender name="s_water_foot1" offset="-0,-12" alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER"/>
					<SpriteRender name="s_water_foot2" offset="-0,-12" alignmentLeft="RIGHT_CENTER" alignmentRight="LEFT_CENTER"/>
				</Group>
				<StopIf>
					<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
				</StopIf>
				<SpriteRender name="s_plasma_sprite" offset="14,7" onState="Punch.Yes" blend="PREMULTIPLIED_ALPHA" stretchToTarget="true" alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER" drawShadow="false" flip="1,0"/>
			</Group>
			<Group onState="Health.SpawnR">
				<ParticleSystemUpdate name="p_SpawnParticleR1"/>
				<ParticleSystemUpdate name="p_SpawnParticleR2"/>
			</Group>
			<Group onState="Health.SpawnL">
				<ParticleSystemUpdate name="p_SpawnParticleL1"/>
				<ParticleSystemUpdate name="p_SpawnParticleL2"/>
			</Group>
		</RenderInFront>
		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
		</OnPunchUpdate>
		<OnPunchStart>
			<ParticleSystemUpdate name="p_punch"/>
		</OnPunchStart>
		<OnKilled>
			<ParticleSystemUpdate name="p_DeathParticleL1" onState="Facing.Left"/>
			<ParticleSystemUpdate name="p_DeathParticleL2" onState="Facing.Left"/>
			<ParticleSystemUpdate name="p_DeathParticleR1" onState="Facing.Right"/>
			<ParticleSystemUpdate name="p_DeathParticleR2" onState="Facing.Right"/>
		</OnKilled>
	</RenderRules>
</ItemRenderer>