<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="s_Sword" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="0,7"/>
		<Sprite name="s_PunchRing" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="1,7"/>
        <Sprite name="s_DragSparks" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>
		<Sprite name="s_PunchSword" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="2,7"/>
		<Sprite name="s_tileSword" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="2,7"/>
	    <Sprite name="HitSpark_Sprite" fileName="game/particles.rttex" textureSize="32"/>
	    <Sprite name="trail_Sprite" fileName="game/particles.rttex" textureSize="32"/>

		<Animations>
                <SpriteCurveAnimation name="Ring_A_Spin" sprite="s_PunchRing" animTime="2000" autoPlay="true" isLoop="true">
                    <Curve name="rotation">
					    <KeyFrame>0, 0</KeyFrame>
					    <KeyFrame>1, 360</KeyFrame>
				    </Curve>
			    </SpriteCurveAnimation>

			<SpriteAnimation name="trail_anim" autoPlay="true" sprite="trail_Sprite" animTime="1200">
				<Frame>3, 0</Frame>
				<Frame>4, 0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="HitSpark_Anim" autoPlay="false" isLoop="false" sprite="HitSpark_Sprite"  animTime="200">
				<Frame>7, 5</Frame>
				<Frame>8, 5</Frame>
				<Frame>9, 5</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="move_trailleft" sprite="s_DragSparks" isLoop="true" animTime="250">
       			<Frame>7,6</Frame>
        		<Frame>8,6</Frame>
            </SpriteAnimation>
			<SpriteAnimation name="move_trailright" sprite="s_DragSparks" isLoop="true" animTime="250">
       			<Frame>7,6</Frame>
        		<Frame>8,6</Frame>
			</SpriteAnimation>
		</Animations>

    <VariableMap>
      <Set name="projectile_offset">0, 0</Set>
      <Set name="projectile_angle">0</Set>
    </VariableMap>

	<ParticleSystems>
      <ParticleSystem name="MoveTrail_going_right">
        <Emitter usePlayerFacing="true">
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="emissionInterval">0.01</Set>
          <Set name="particlesPerEmission">1</Set>
		  <Set name="offsetFacing">true</Set>
          <Random name="offset" min="-35, 0" max="-35, 0"/>
        </Emitter>
        <Particle randomSpriteFrame="true" velocityRelativeToPlayerSpeed="false">
          <Set name="sprite">s_DragSparks</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">1.7</Set>
          <Random name="initialScale" min="0.08,0.08" max="0.16,0.16"/>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>0.45, 1</KeyFrame>
			<KeyFrame>0.85, 0.85</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Set name="useGravity">true</Set>
          <Random name="gravityVector" min="0, 90" max="0, 180"/>
          <Random name= "initialVelocity" min="-25,-40" max="-40,-80"/>
        </Particle>
      </ParticleSystem>

      <ParticleSystem name="MoveTrail_going_left">
        <Emitter usePlayerFacing="true">
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="emissionInterval">0.01</Set>
          <Set name="particlesPerEmission">1</Set>
		  <Set name="offsetFacing">true</Set>
          <Random name="offset" min="-35, 0" max="-35, 0"/>
        </Emitter>
        <Particle randomSpriteFrame="true" velocityRelativeToPlayerSpeed="false">
          <Set name="sprite">s_DragSparks</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">1.7</Set>
          <Random name="initialScale" min="0.08,0.08" max="0.16,0.16"/>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>0.45, 1</KeyFrame>
			<KeyFrame>0.85, 0.85</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Set name="useGravity">true</Set>
          <Random name="gravityVector" min="0, 90" max="0, 180"/>
          <Random name= "initialVelocity" min="25,-40" max="40,-80"/>
        </Particle>
      </ParticleSystem>


			<ParticleSystem name="Punch_ps" secondary="Trail_ps">
				<Emitter attachment="targetPos">
					<Set name="offset">0,0</Set>
					<Set name="lifeTime">0.3</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_PunchSword</Set>
					<Select name="offset" input="punchCount">
						<Item>-35, -275</Item>
						<Item>0, -200</Item>
						<Item>35, -225</Item>
						<Item>15, -300</Item>
						<Item>-5, -175</Item>
						<Item>0, -225</Item>
					</Select>
					<Curve name="initialScale">
						<KeyFrame>0, 0.5,0.5</KeyFrame>
						<KeyFrame>1, 0.5,0.5</KeyFrame>
					</Curve>
					<Random name="targetPosOffset" min="-9,-9" max="9,12"/>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="lifeTime">0.3</Set>
					<VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="0.9" angleOutVar="projectile_angle"/>
                    <SetVar name="projectile_offset" source="targetPosOffset"/>
				</Particle>
			</ParticleSystem>
      <ParticleSystem name="ps_tileSword">
        <Emitter>
          <Set name="infParticles">true</Set>
          <Set name="checkParticleNumToEmit">true</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">1</Set>
          <Set name="delayTimer">0.15</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_tileSword</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">1.1</Set>
          <Set name="renderAlignment">RIGHT_CENTER</Set>
          <Set name='initialScale'>0.5,0.5</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.9, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
          <Set name="offset" source="projectile_offset"/>
          <Set name="initialAngle" source="projectile_angle"/>
        </Particle>
      </ParticleSystem>
			<ParticleSystem name="Trail_ps">
				<Emitter>
					<Set name="lifeTime">0.35</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">80</Set>
					<Random name="offset" min="-1,-1" max="1,1"/>
					<Random name="emissionInterval" min="0.02" max="0.03"/>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_DragSparks</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">1.2</Set>
					<Random name="offset" min="-2,-2" max="2,2"/>
					<Set name="initialRotationRate">200</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.6,0.6</KeyFrame>
						<KeyFrame>0.9, 0.6,0.6</KeyFrame>
						<KeyFrame>1, 0,0</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.9, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>

            <ParticleSystem name="ps_hitEmbers">
                <Emitter>
                    <Set name="lifeTime">0.25</Set>
                    <Set name="particlesPerEmission">8</Set>
                    <Set name="particlesToEmit">1</Set>
                </Emitter>
                <Particle randomSpriteFrame="true">
                    <Set name="sprite">s_DragSparks</Set>
                    <Set name="blendingMode">ADDITIVE</Set>
                    <Set name="lifeTime">1</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 1,1</KeyFrame>
                        <KeyFrame>1, 0.25,0.25</KeyFrame>
                    </Curve>
                    <Random name="initialRotationRate" min="5" max="15" />
                    <Random name="offset" min="-4,-3" max="4,3" />
                    <Set name="useGravity">true</Set>
                    <Set name="gravityVector">0, 100</Set>
                    <RandomRadial name="initialVelocity" angleRange="45,315" radiusRange="80,200" />
                </Particle>
            </ParticleSystem>

			<ParticleSystem name="hitSpark_particle" secondary="trail_particle">
				<Emitter>
					<Set name="particlesPerEmission">8</Set>
					<Set name="lifeTime">2</Set>
					<Set name="useTargetTileColorForTint">true</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">HitSpark_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="useGravity">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">2,2</Set>
					<Random name="finalScale" min="0.1, 0.1" max="0.4, 0.4"/>
					<Set name="lifeTime">1</Set>
					<RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="80,200"/>
					<Set name="gravityVector">0, 100</Set>
					<Random name="initialRotationRate" min="-300" max="300"/>
					<Random name="posOffset" min="0.1, 0" max="16.1, 16.3"/>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="trail_particle">
				<Emitter>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">80</Set>
					<Set name="emissionInterval">0.2</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">trail_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">1.2</Set>
					<Set name="initialRotationRate">150</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0, 0</KeyFrame>
						<KeyFrame>0.4, 1, 1</KeyFrame>
						<KeyFrame>0.8, 0.3, 0.3</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.5</KeyFrame>
						<KeyFrame>0.8, 0</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialVelocity">0,0</Set>
				</Particle>
			</ParticleSystem>
	</ParticleSystems>

		<TileStampData>
			<Set name="FileName">game/enigma_particles_small2.rttex</Set>
			<Set name="EndFrame">3,10</Set>
			<Set name="FrameCount">4</Set>
		</TileStampData>

    <RenderOptions>
      <Default>
        <Set name="PunchSoundOverride">HAND</Set>
        <Set name="PlayDefaultPunchAudio">false</Set>
        <Set name="DefaultRenderMannequinHandItem">false</Set>
        <Set name="RenderBackArmBuild">false</Set>
        <Set name="RenderBackArmInfected">true</Set>
        <Set name="RenderFrontArmInfected">true</Set>
      </Default>
    </RenderOptions>
	</Data>

	<RenderRules>
		<RenderHandItem>
            <SpriteRender name="s_Sword" offset="-26 ,0" flip="1,0" scale="0.75,0.75" rotationPoint="0,1" useFixedRotation="true" blend="PREMULTIPLIED_ALPHA" onAction="IDLE|WALK|JUMP|JUMPSTART|FALL|DANCE|DOUBLEJUMP"/>
            <SpriteRender name="s_Sword" offset="20 ,3" scale="0.75,0.75" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" onAction="PUNCH"/>
		</RenderHandItem>
        <RenderBehind>
            <SpriteRender name="s_PunchRing" offset="0 ,6" scale="0.85,0.85" alignment="CENTER" drawShadow="false" blend="PREMULTIPLIED_ALPHA" onAction="PUNCH"/>
        </RenderBehind>

       <Update>
            <AvatarTransform class="ArmAngle" onAction="IDLE|WALK|JUMP|JUMPSTART|DANCE|DOUBLEJUMP|FALL">
			    <Set name="armName">arm2Angle</Set>
			    <Set name="armAngle">80</Set>
		    </AvatarTransform>
        </Update>

        <OnPunchUpdate>
		    <AvatarTransform class="Face">
			    <Set name="face">MAD</Set>
		    </AvatarTransform>
            <AvatarTransform class="ArmAngle">
                <Set name="armName">arm2Angle</Set>
                <Set name="animTime">350</Set>
                <Set name="Curve">
                    <KeyFrame>0.0, 215</KeyFrame>
                    <KeyFrame>0.3, 360</KeyFrame>
                    <KeyFrame>0.8, 360</KeyFrame>
                    <KeyFrame>0.81, 215</KeyFrame>
                    <KeyFrame>1, 215</KeyFrame>
                </Set>
            </AvatarTransform>
        </OnPunchUpdate>

	    <OnPunchStart>
		    <ParticleSystemUpdate name="Punch_ps"/>
	    </OnPunchStart>

        <OnDamagedTile>
            <ParticleSystemUpdate name="ps_tileSword" />
            <ParticleSystemUpdate name="ps_hitEmbers" />
        </OnDamagedTile>

		<OnDestroyedTile>
			<ParticleSystemUpdate name="hitSpark_particle"/>
		</OnDestroyedTile>

		<AddClothingParticles>
			<ParticleSystemUpdate name="MoveTrail_going_right" onState="Facing.Right" onAction="WALK"/>
            <ParticleSystemUpdate name="MoveTrail_going_left" onState="Facing.Left" onAction="WALK"/>
		</AddClothingParticles>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="MoveTrail_going_right"/>
            <ParticleSystemOff name="MoveTrail_going_left"/>
            <ParticleSystemOff name="hitSpark_particle"/>
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>