<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
	<StateMachines>
		<StateMachine name="playerState">
			<States>
				<State name="Idle"/>
				<State name="Punch"/>
				<State name="ZombiePunch"/>
			</States>
			<Transitions>
				<Transition from="ZombiePunch|Punch" to="Idle" >
					<Condition>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition from="ZombiePunch|Idle" to="Punch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>false</IsZombified>
					</Condition>
				</Transition>
				<Transition from="Idle|Punch" to="ZombiePunch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>true</IsZombified>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
	</StateMachines>
	<Sprite name="Sword" fileName="game/garvs.rttex" textureSize="90" frame="0,1"/>
	<Sprite name="Sword_glow" fileName="game/garvs.rttex" textureSize="90" frame="1,1"/>
	<Sprite name="item_Punch" fileName="game/garvs.rttex" textureSize="90" frame="0,0"/>
	<Animations>
		<SpriteCurveAnimation name="glow" isLoop="true" autoPlay="true" sprite="Sword_glow" animTime="2000">
				<Curve name="alpha">
					<KeyFrame>0, 0.0</KeyFrame>
					<KeyFrame>0.5, 1</KeyFrame>
					<KeyFrame>1, 0.0</KeyFrame>
				</Curve>
			</SpriteCurveAnimation>	
		<SpriteAnimation name="Block_punch" sprite="item_Punch" animTime="750" autoPlay="true" isLoop="true" playOnState="playerState.Punch">
			<Frame>0,0</Frame>
			<Frame>1,0</Frame>
			<Frame>2,0</Frame>
			<Frame>3,0</Frame>
			<Frame>4,0</Frame>
			<Frame>5,0</Frame>
			<Frame>6,0</Frame>
		</SpriteAnimation>
    </Animations>

	<ParticleSystems>
		<ParticleSystem name="hit_stamp_particle">
        <Emitter>
          <Set name="lifeTime">1</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">1</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">item_Punch</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.7</Set>
          <Curve name="initialAlpha">
            <KeyFrame>1, 1</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 0.5,0.5</KeyFrame>
            <KeyFrame>1, 0.7,0.7</KeyFrame>
          </Curve>
        </Particle>
      </ParticleSystem>
	</ParticleSystems>
	<RenderOptions>
		<Default>
    		<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
        	<Set name="DefaultRenderMannequinHandItem">false</Set>
		</Default>
	</RenderOptions>
  </Data>

  <RenderRules>
    <RenderHandItem>
	  <SpriteRender name="Sword" rotateOffset="true" offset="23,5" alignment="CENTER"/>
	  <SpriteRender name="Sword_glow" rotateOffset="true" offset="23,5" alignment="CENTER" blendingMode="PREMULTIPLIED_ALPHA"/>
    </RenderHandItem>
	<OnPunchUpdate>
		<AvatarTransform class="Face">
			<Set name="face">MAD</Set>
		</AvatarTransform>
		<AvatarTransform class="ArmAngle">
			<Set name="armName">arm2Angle</Set>
			<Set name="armAngle">800</Set>
			<Set name="isAdditive">true</Set>
			<Set name="pointTowardsPunchTarget">false</Set>
		</AvatarTransform>
		<AvatarTransform class="ArmAngle" onState="playerState.Punch">
			<Set name="armName">arm2Angle</Set>
			<Set name="armAngle">1200</Set>
			<Set name="isAdditive">true</Set>
			<Set name="pointTowardsPunchTarget">false</Set>
		</AvatarTransform>
	</OnPunchUpdate>
	<OnDamagedTile>
      <ParticleSystemUpdate name="hit_stamp_particle" />
    </OnDamagedTile>
  </RenderRules>
</ItemRenderer>