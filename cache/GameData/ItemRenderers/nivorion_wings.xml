<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
	<Sprite name="item_Sprite_1" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="0,0"/>
    <Sprite name="item_Sprite_2" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="0,0"/>
	<Sprite name="smoke" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="13,0"/>
	<Sprite name="emberSprite" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>

	<Animations>
			<SpriteAnimation name="left_wing_Idle" playOnState="playerState.Idle|playerState.Move|playerState.SpiritGuide" sprite="item_Sprite_1" isLoop="true" animTime="100">
				<Frame>0,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_Idle" playOnState="playerState.Idle|playerState.Move|playerState.SpiritGuide" sprite="item_Sprite_2" isLoop="true" animTime="100">
				<Frame>0,0</Frame>
			</SpriteAnimation>
			
			<SpriteAnimation name="left_wing_DoubleJ" playOnState="playerState.DoubleJump" sprite="item_Sprite_1" isLoop="false" animTime="125">
        		<Frame>3,0</Frame>
        		<Frame>2,0</Frame>
				<Frame>1,0</Frame>
			</SpriteAnimation>		
			<SpriteAnimation name="right_wing_DoubleJ" playOnState="playerState.DoubleJump" sprite="item_Sprite_2" isLoop="false" animTime="125">
        		<Frame>3,0</Frame>
        		<Frame>2,0</Frame>
				<Frame>1,0</Frame>
			</SpriteAnimation>		

      		<SpriteAnimation name="left_wing_Fall" playOnState="playerState.Fall" sprite="item_Sprite_1" isLoop="true" animTime="100">
        		<Frame>3,0</Frame>
			</SpriteAnimation>		
			<SpriteAnimation name="right_wing_Fall" playOnState="playerState.Fall" sprite="item_Sprite_2" isLoop="true" animTime="100">
       			<Frame>3,0</Frame>
			</SpriteAnimation>	
		
			<SpriteAnimation name="left_wing_Jump" playOnState="playerState.Jump" sprite="item_Sprite_1" isLoop="false" animTime="350">
				<Frame>3,0</Frame>
				<Frame>2,0</Frame>
                <Frame>1,0</Frame>
                <Frame>3,0</Frame>
                <Frame>2,0</Frame>
                <Frame>1,0</Frame>
			</SpriteAnimation>			
			<SpriteAnimation name="right_wing_Jump" playOnState="playerState.Jump" sprite="item_Sprite_2" isLoop="false" animTime="350">
				<Frame>3,0</Frame>
				<Frame>2,0</Frame>
                <Frame>1,0</Frame>
                <Frame>3,0</Frame>
                <Frame>2,0</Frame>
                <Frame>1,0</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="emberAnimation" sprite="emberSprite" animTime="200">
				<Frame>14,1</Frame>
				<Frame>15,1</Frame>
			</SpriteAnimation>
    </Animations>

	<ParticleSystems>
		<ParticleSystem name="smoke_particle">
			<Emitter>
				<Random name="offset" min="-35, -9" max="36, -18"/>
				<Random name="emissionInterval" min="0.03" max="0.035"/>
				<Set name="infParticles">true</Set>
				<Set name="infLifeTime">true</Set>
				<Set name="particlesPerEmission">1</Set>
			</Emitter>
			<Particle>
				<Set name="sprite">smoke</Set>
				<Set name="blendingMode">ADDITIVE</Set>
				<Set name="isBackgroundParticle">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.7</KeyFrame>
                        <KeyFrame>0.75, 0.7</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.5,0.5</KeyFrame>
                        <KeyFrame>0.85, 0.5,0.5</KeyFrame>
						<KeyFrame>1, 0,0</KeyFrame>
					</Curve>
				<Random name="lifeTime" min="0.85" max="1.35"/>
				<Random name="initialVelocity" min="0, 3" max="0, 5"/>
			</Particle>
		</ParticleSystem>
			<ParticleSystem name="EmberLeftParticle">
				<Emitter>
					<Set name="offset">-20, -26</Set>
					<Set name="emissionInterval">0.1</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">emberSprite</Set>
					<Random name="offset" min="-8, -10" max="8, 12" />
					<Set name="renderAlignment">CENTER</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.3, 1</KeyFrame>
						<KeyFrame>0.8, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.85</Set>
					<Random name="initialVelocity" min="0, -16" max="0, -30" />
					<Set name="initialRotationRate">360</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="EmberRightParticle">
				<Emitter>
					<Set name="offset">20, -26</Set>
					<Set name="emissionInterval">0.1</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">emberSprite</Set>
					<Random name="offset" min="-8, -10" max="8, 12" />
					<Set name="renderAlignment">CENTER</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.3, 1</KeyFrame>
						<KeyFrame>0.8, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.85</Set>
					<Random name="initialVelocity" min="0, -16" max="0, -30" />
					<Set name="initialRotationRate">360</Set>
				</Particle>
			</ParticleSystem>
	</ParticleSystems>
  </Data>

  <RenderRules>
    <RenderBackpack>
      <SpriteRender name="item_Sprite_1" offset="3,-21" alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER"/>
	  <SpriteRender name="item_Sprite_2" offset="-3,-21" flip="1,0" alignmentLeft="RIGHT_CENTER" alignmentRight="LEFT_CENTER"/>
    </RenderBackpack>
	<AddClothingParticles>
		<ParticleSystemUpdate name="smoke_particle" onState="playerState.Move|playerState.Jump|playerState.DoubleJump|playerState.Fall"/>
		<ParticleSystemUpdate name="EmberLeftParticle" onState="playerState.Idle"/>
		<ParticleSystemUpdate name="EmberRightParticle" onState="playerState.Idle"/>
	</AddClothingParticles>
	<SwitchOffClothingParticles>
		<ParticleSystemOff name="smoke_particle"/>
	</SwitchOffClothingParticles>
  </RenderRules>
</ItemRenderer>