<?xml version="1.0"?>
<ItemRenderer>
    <Data>
        <Sprite name="s_Horns" fileName="game//mk4_custom_tiles_page2.rttex" textureSize="32" frame="2,20"/>
        <Sprite name="s_Halo" fileName="game//mk4_player_hair.rttex" textureSize="32" frame="5,1"/>
        <Sprite name="s_Pet" fileName="game//mk4_custom_tiles_page2.rttex" textureSize="32" frame="0,20"/>
        <Animations>
            <SpriteAnimation name="a_PetMoving" sprite="s_Pet" animTime="400" isLoop="true" autoPlay="true">
                <Frame>0,20</Frame>
                <Frame>1,20</Frame>
            </SpriteAnimation>
            <SpriteSinPulseAnimation name="HaloFloatAnim" sprite="s_Halo" autoPlay="true">
                <Parameter name="pos.y">
                    <Set name="period">3000</Set>
                    <Set name="scale">0.9</Set>
                </Parameter>
            </SpriteSinPulseAnimation>
        </Animations>
        <StateMachines>
            <StateMachine name="Motion">
                <States>
                    <State name="None"/>
                    <State name="Up"/>
                    <State name="Down"/>
                    <State name="Horizontal"/>
                    <State name="Punch"/>
                </States>
                <Transitions>
                    <Transition to="None" from="Punch|Up|Down|Horizontal">
                        <Condition type="and">
                            <IsVariableFloat name="pet.velocity.length" operator="Less" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Up" from="Punch|None|Down|Horizontal">
                        <Condition type="and">
                            <IsVariableFloat name="pet.velocity.y" operator="Less">-0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Down" from="Punch|None|Up|Horizontal">
                        <Condition type="and">
                            <IsVariableFloat name="pet.velocity.y" operator="Greater">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Horizontal" from="Punch|None|Down|Up">
                        <Condition type="and">
                            <IsVariableFloat name="pet.velocity.x" operator="Greater" abs="true">0.1</IsVariableFloat>
                            <IsVariableFloat name="pet.velocity.y" operator="Less" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Punch" from="None|Up|Down|Horizontal">
                        <Condition>
                            <IsAction>PUNCH</IsAction>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
        </StateMachines>
        <RenderOptions>
            <Default>
                <Set name="NeedRenderPet">true</Set>
                <Set name="PetOffsetDuplication">-32,0</Set>
            </Default>
        </RenderOptions>
    </Data>
    <RenderRules>
        <RenderHat>
            <SpriteRender flip="0,0" name="s_Horns" alignment="CENTER" offset="0,-23.7" rotateOffset="true" rotationPoint="0,1"/>
            <SpriteRender flip="0,0" name="s_Halo" scale="0.8,0.8" alignment="CENTER" offset="0,-33" rotateOffset="true" rotationPoint="0,1"/>
        </RenderHat>
        <RenderPet>
            <SpriteRender name="s_Pet" offset="0,0" scale="1,1" drawShadow="true" alignment="DOWN_CENTER"/>
        </RenderPet>
    </RenderRules>
</ItemRenderer>
