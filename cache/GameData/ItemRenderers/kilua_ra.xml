<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="md_sprite" fileName="game//killua_raps.rttex" textureSize="64"/>
		<Sprite name="md_punch" fileName="game//killua_p.rttex" textureSize="64"/>
		<Sprite name="md_eff" fileName="game//killua_awrarw.rttex" textureSize="128"/>
		<Sprite name="md_eff2" fileName="game//killua_light.rttex" textureSize="64"/>
		<Sprite name="break" fileName="game//ci_n4.rttex" textureSize="32" frame="9,34"/>
		<Sprite name="left" fileName="game//ci_n4.rttex" textureSize="32" frame="9,33"/>
        <Sprite name="right" fileName="game//ci_n4.rttex" textureSize="32" frame="9,33"/>
        
        <TileStampData>
      		<Set name="FileName">game/server_2424/ci_n4.rttex</Set>
      		<Set name="EndFrame">12,34</Set>
      		<Set name="FrameCount">4</Set>
    	</TileStampData>
    
		<StateMachines>
		<StateMachine name="Motion">
			<States>
				<State name="Idle" />
				<State name="Move" />
				<State name="Jump" />
				<State name="Fall" />
				<State name="Punch"/>
				<State name="Respawn"/>
			</States>
			<Transitions>
				<Transition to="Idle" from="Fall|Move|Jump|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						<IsVariableBool name="isAttacking">false</IsVariableBool>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Move" from="Jump|Fall|Idle|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Jump" from="Idle|Move|Fall|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Fall" from="Jump|Idle|Move|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Punch" from="Idle|Move|Jump|Fall">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
		</StateMachines>
		<Animations>
			<SpriteAnimation name="ge_eff2" sprite="md_eff2" animTime="600" isLoop="true" playOnState="Motion.Punch|Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				</SpriteAnimation>
			<SpriteAnimation name="punch_killua" sprite="md_punch" animTime="300" autoPlay="true" isLoop="true" playOnState="Motion.Punch">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				</SpriteAnimation>
			<SpriteAnimation name="ge_eff" sprite="md_eff" animTime="800" isLoop="true" playOnState="Motion.Punch|Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				</SpriteAnimation>
			<SpriteAnimation name="gigi_Idle_Animation" playOnState="Motion.Idle" sprite="md_sprite" animTime="1000" isLoop="true">
            <Frame>0,0</Frame>
			<Frame>1,0</Frame>
			<Frame>2,0</Frame>
			<Frame>3,0</Frame>
			<Frame>4,0</Frame>
            <Frame>5,0</Frame>
			<Frame>6,0</Frame>
			<Frame>7,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Punch_Animation" playOnState="Motion.Punch" sprite="md_sprite" animTime="400" isLoop="true">
			<Frame>0,3</Frame>
			<Frame>1,3</Frame>
			<Frame>2,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Jump_Animation" playOnState="Motion.Jump" sprite="md_sprite" animTime="400">
				<Frame>0,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Fall_Animation" playOnState="Motion.Fall" sprite="md_sprite" animTime="400">
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Walk_Animation" playOnState="Motion.Move" sprite="md_sprite" animTime="600" isLoop="true">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
				<Frame>4,1</Frame>
				<Frame>5,1</Frame>
				<Frame>6,1</Frame>
				<Frame>7,1</Frame>

			</SpriteAnimation>
		</Animations>
		<ParticleSystems>
			<ParticleSystem name="ps_punchCurved" updateStage="OnPunchStart">
        <Emitter>
            <Set name="offset">20,-10028</Set>
            <Set name="emissionInterval">4</Set>
            <Set name="lifeTime">1</Set>
            <Set name="particlesPerEmission">1</Set>
            <Set name="particlesToEmit">1</Set>
        </Emitter>
        <Particle>
            <Set name="sprite">md_punch</Set>
            <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
            <Set name="lifeTime">0.4</Set>
            <Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
            <Set name="rotateWithVelocity">true</Set>
            <Set name="interpolateAlpha">false</Set>
            <Set name="initialAlpha">1</Set>
            <Set name="finalAlpha">1</Set>
            <Set name="interpolateVelocity">true</Set>
            <Set name="initialScale">1,1</Set>
            <VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
            <VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
        </Particle>
        </ParticleSystem>
        <ParticleSystem name="left">
				<Emitter>
					<Random name="offset" min="-18, -9996" max="-15, -9996"/>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="checkParticleNumToEmit">true</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">left</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="isBackgroundParticle">false</Set>
					<Set name="initalRGB">1, 1, 1</Set>
					<Set name="relativeToEmitter">false</Set>
					<Set name="rotateWithVelocity">false</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="lifeTime">1</Set>
					<Set name="initialScale">1.1, 1.1</Set>
					<Set name="finalScale">1.5, 1.8</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="right">
				<Emitter>
					<Random name="offset" min="18, -9996" max="15, -9996"/>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="checkParticleNumToEmit">true</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">right</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="isBackgroundParticle">false</Set>
					<Set name="initalRGB">1, 1, 1</Set>
					<Set name="relativeToEmitter">false</Set>
					<Set name="rotateWithVelocity">false</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="interpolateScale">true</Set>
	            	<Set name="flipX">true</Set>
					<Set name="lifeTime">1</Set>
					<Set name="initialScale">1.1, 1.1</Set>
					<Set name="finalScale">1.5, 1.8</Set>
				</Particle>
			</ParticleSystem>
        
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="UserNameOffset">6</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<AvatarSilhouetteRender color="44,239,255,100" offset ="0,30" emissionInterval="0.08" onState="Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<SpriteRender name="md_eff" offset="0,-10048" scale="0.8,0.8" drawShadow="false" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<SpriteRender name="md_sprite" offset="0,-10028" drawShadow="true" scale="1,1" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<SpriteRender name="md_eff2" offset="5,-10018" scale="1,1" drawShadow="false" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<SpriteRender name="md_eff" offset="0,-10048" flip="1,0" tintOverride="0,0,0,60" scale="0.8,0.8" drawShadow="false" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
        </RenderInFront>
        
        <AddClothingParticles>
            <ParticleSystemUpdate name="left" onAction="JUMP|JUMPDOUBLE" drawShadow="false" alignment="DOWN_CENTER"/>
			<ParticleSystemUpdate name="right" onAction="JUMP|JUMPDOUBLE" drawShadow="false" alignment="DOWN_CENTER"/>
        </AddClothingParticles>
        
		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
		<OnPunchStart>
		</OnPunchStart>
	</RenderRules>
</ItemRenderer>