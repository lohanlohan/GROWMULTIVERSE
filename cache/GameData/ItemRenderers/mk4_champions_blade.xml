<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
    <Data>
        <Sprite name="s_swordglow" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="3,3"/>
        <Sprite name="s_sword" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="0,2"/>
        <Sprite name="s_trophy" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="2,3"/>
        <Sprite name="s_stat1" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="0,3"/>
        <Sprite name="s_stat2" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="1,3"/>
        <Sprite name="s_glow" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="0,0"/>
        <Sprite name="s_skin_dust_blue" fileName="game//mk4_particles11.rttex" textureSize="32" frame="23,5"/>
        <Sprite name="s_skin_dust_purple" fileName="game//mk4_particles11.rttex" textureSize="32" frame="24,5"/>
        <Sprite name="s_skin_stars_blue" fileName="game//mk4_particles11.rttex" textureSize="32"/>
        <Sprite name="s_skin_stars_purple" fileName="game//mk4_particles11.rttex" textureSize="32"/>
        <Sprite name="s_slasheffect" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="7,1"/>
        <Sprite name="championSlash" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="0,1"/>
        <Sprite name="s_tilepunch" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="8,1"/>
        <Sprite name="s_logo" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="4,3"/>
        <Sprite name="s_death" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="5,3"/>
        <Sprite name="s_respawn" fileName="game//mk4_champions_blade.rttex" textureSize="128" frame="0,4"/>
        <Animations>
            <SequenceAnimation name="a_sword" autoPlay="true" isLoop="false">
                <SpriteAnimation sprite="s_sword" autoPlay="true" animTime="4000" isLoop="false">
                    <Frame>0,0</Frame>
                    <Frame>0,2</Frame>
                    <Frame>1,2</Frame>
                    <Frame>1,2</Frame>
                    <Frame>2,2</Frame>
                    <Frame>3,2</Frame>
                    <Frame>3,2</Frame>
                    <Frame>4,2</Frame>
                    <Frame>5,2</Frame>
                    <Frame>6,2</Frame>
                    <Frame>6,2</Frame>
                    <Frame>7,2</Frame>
                    <Frame>7,2</Frame>
                    <Frame>8,2</Frame>
                    <Frame>8,2</Frame>
                    <Frame>9,2</Frame>
                    <Frame>9,2</Frame>
                    <Frame>10,2</Frame>
                </SpriteAnimation>
                <SpriteAnimation sprite="s_sword" autoPlay="true" animTime="2000" isLoop="true">
                    <Frame>10,2</Frame>
                </SpriteAnimation>
            </SequenceAnimation>
            <SpriteCurveAnimation name="glow" isLoop="true" autoPlay="true" sprite="s_swordglow" animTime="2000">
                <Curve name="alpha">
                    <KeyFrame>0, 0.0</KeyFrame>
                    <KeyFrame>0.5, 1</KeyFrame>
                    <KeyFrame>1, 0.0</KeyFrame>
                </Curve>
            </SpriteCurveAnimation>
            <SpriteAnimation name="champ_splash" sprite="championSlash" animTime="300" isLoop="true" playOnAction="PUNCH">
                <Frame>0,1</Frame>
                <Frame>1,1</Frame>
                <Frame>2,1</Frame>
                <Frame>3,1</Frame>
                <Frame>4,1</Frame>
                <Frame>5,1</Frame>
                <Frame>6,1</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="a_skin_stars_purple" sprite="s_skin_stars_purple" animTime="400">
                <Frame>25,5</Frame>
                <Frame>26,5</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="a_glow" sprite="s_glow" animTime="400">
                <Frame>0,0</Frame>
                <Frame>1,0</Frame>
                <Frame>2,0</Frame>
                <Frame>3,0</Frame>
                <Frame>4,0</Frame>
                <Frame>5,0</Frame>
                <Frame>6,0</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="a_skin_stars_blue" sprite="s_skin_stars_blue" animTime="200">
                <Frame>28,5</Frame>
                <Frame>29,5</Frame>
            </SpriteAnimation>
            <SpriteCurveAnimation name="trophy_rotation_anim" autoPlay="true" isLoop="true" sprite="s_trophy" animTime="3000">
                <Curve name="rotation">
                    <KeyFrame>1, -20</KeyFrame>
                </Curve>
            </SpriteCurveAnimation>
            <SpriteCurveAnimation name="a_trophy" autoPlay="true" isLoop="true" sprite="s_trophy" animTime="3000">
                <Curve name="pos.x">
                    <KeyFrame>1, 12</KeyFrame>
                </Curve>
            </SpriteCurveAnimation>
            <SpriteCurveAnimation name="a_trophy2" sprite="s_trophy" animTime="3000" autoPlay="true" isLoop="true">
                <Curve name="pos.y">
                    <KeyFrame>0.f, -4</KeyFrame>
                    <KeyFrame>0.5f, 0</KeyFrame>
                    <KeyFrame>1.f, -4</KeyFrame>
                </Curve>
            </SpriteCurveAnimation>
            <SpriteCurveAnimation name="a_stat1" sprite="s_stat1" animTime="5000" autoPlay="true" isLoop="true">
                <Curve name="pos.y">
                    <KeyFrame>0.f, -2</KeyFrame>
                    <KeyFrame>0.5f, 0</KeyFrame>
                    <KeyFrame>1.f, -2</KeyFrame>
                </Curve>
            </SpriteCurveAnimation>
            <SpriteCurveAnimation name="a_stat2" sprite="s_stat2" animTime="5000" autoPlay="true" isLoop="true">
                <Curve name="pos.y">
                    <KeyFrame>0.f, -2</KeyFrame>
                    <KeyFrame>0.5f, 0</KeyFrame>
                    <KeyFrame>1.f, -2</KeyFrame>
                </Curve>
            </SpriteCurveAnimation>
            <SpriteAnimation name="a_resp" sprite="s_respawn" autoPlay="true" animTime="700" isLoop="false">
                <Frame>0,4</Frame>
                <Frame>1,4</Frame>
                <Frame>2,4</Frame>
                <Frame>3,4</Frame>
                <Frame>4,4</Frame>
                <Frame>5,4</Frame>
                <Frame>6,4</Frame>
                <Frame>7,4</Frame>
                <Frame>8,4</Frame>
                <Frame>9,4</Frame>
                <Frame>0,5</Frame>
                <Frame>1,5</Frame>
                <Frame>2,5</Frame>
                <Frame>3,5</Frame>
                <Frame>4,5</Frame>
            </SpriteAnimation>
        </Animations>
        <ParticleSystems>
            <ParticleSystem name="ps_death" updateStage="OnKilled" renderStage="RenderInFront">
                <Emitter>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_death</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.6,0.6</KeyFrame>
                        <KeyFrame>1.5, 1.5, 1.5</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">2</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_resp" renderStage="RenderInFront">
                <Emitter>
                    <Set name="offset">0,-25</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_respawn</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="offset">0,-25</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>2, 2, 2</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">3</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_breakLogo" updateStage="OnDestroyedTile">
                <Emitter>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_logo</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.6,0.6</KeyFrame>
                        <KeyFrame>1.5, 1.5, 1.5</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">2</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="p_hit" updateStage="OnDamagedTile">
                <Emitter>
                    <Set name="particlesPerEmission">1</Set>
                    <Set name="lifeTime">0.5</Set>
                    <Set name="delayTimer">0.1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_tilepunch</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 1.5,1.5</KeyFrame>
                        <KeyFrame>1, 2, 2</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">0.5</Set>
                    <Random name="initialAngle" min="0" max="360"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="punch_projectile" updateStage="OnPunchStart">
                <Emitter>
                    <Set name="offset">12,-15</Set>
                    <Set name="lifeTime">0</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_slasheffect</Set>
                    <Set name="rotateWithVelocity">true</Set>
                    <Set name="lifeTime">0.4</Set>
                    <Set name="useGravity">true</Set>
                    <Curve name="initialScale">
                        <KeyFrame>0.8, 0.8, 0.8</KeyFrame>
                        <KeyFrame>1.2, 1.2, 1.2</KeyFrame>
                    </Curve>
                    <VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_dust_blue">
                <Emitter>
                    <Set name="offset">-16, -62</Set>
                    <Set name="emissionInterval">0.1</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_skin_dust_blue</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Random name="offset" min="-3, -3" max="3, 3"/>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="initialAlpha">0.15</Set>
                    <Set name="initialScale">3, 3</Set>
                    <Set name="lifeTime">2</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_dust_purple">
                <Emitter>
                    <Set name="offset">16, -66</Set>
                    <Set name="emissionInterval">0.1</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_skin_dust_purple</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Random name="offset" min="-3, -3" max="3, 3"/>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="initialAlpha">0.15</Set>
                    <Set name="initialScale">3, 3</Set>
                    <Set name="lifeTime">2</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_dust_blue2">
                <Emitter>
                    <Set name="offset">16, -86</Set>
                    <Set name="emissionInterval">0.1</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_skin_dust_blue</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Random name="offset" min="-3, -3" max="3, 3"/>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="initialAlpha">0.15</Set>
                    <Set name="initialScale">3, 3</Set>
                    <Set name="lifeTime">2</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_dust_purple2">
                <Emitter>
                    <Set name="offset">-16, -82</Set>
                    <Set name="emissionInterval">0.1</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_skin_dust_purple</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Random name="offset" min="-3, -3" max="3, 3"/>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="initialAlpha">0.15</Set>
                    <Set name="initialScale">3, 3</Set>
                    <Set name="lifeTime">2</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_skin_stars_purple">
                <Emitter>
                    <Set name="offset">2,-64</Set>
                    <Set name="offsetFacing">true</Set>
                    <Set name="emissionInterval">0.2</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <Set name="particlesToEmit">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_skin_stars_purple</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Random name="offset" min="32, -32" max="-32, 32"/>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.8, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Select name="lifeTime" input="randomNumber">
                        <Item>0.5</Item>
                        <Item>0.7</Item>
                    </Select>
                    <Random name="initialScale" min="1" max="1.5"/>
                    <Random name="initialAngle" min="0" max="360"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_glow">
                <Emitter>
                    <Set name="offset">0, -76</Set>
                    <Set name="offsetFacing">true</Set>
                    <Set name="emissionInterval">2</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">2</Set>
                    <Set name="particlesToEmit">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_glow</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.2, 0.8</KeyFrame>
                        <KeyFrame>0.5, 0.5</KeyFrame>
                        <KeyFrame>0.8, 0.2</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Select name="lifeTime" input="randomNumber">
                        <Item>1.5</Item>
                        <Item>2</Item>
                    </Select>
                    <Random name="initialScale" min="1" max="1.3"/>
                    <Random name="initialAngle" min="0" max="360"/>
                </Particle>
            </ParticleSystem>
        </ParticleSystems>
        <RenderOptions>
            <Default>
                <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
                <Set name="HideAngelOnDeath">true</Set>
                <Set name="HideAvatarOnDeath">true</Set>
            </Default>
        </RenderOptions>
    </Data>
    <RenderRules>
        <OnDrawCustomOutline>
            <AvatarTransform class="Scale">
                <Set name="targetScale">getCurrent</Set>
            </AvatarTransform>
            <AvatarTransform class="RenderData">
                <Set name="saturation">3</Set>
                <Set name="brightness">1</Set>
                <Set name="contrast">0.1</Set>
            </AvatarTransform>
            <AvatarOutline duration="1500" startScale="1,1" endScale="1.1,1.1">
                <Colours>
                    <Colour>87,30,150,255</Colour>
                    <Colour>90,10,90,255</Colour>
                </Colours>
            </AvatarOutline>
            <AvatarTransform class="RenderData">
                <Set name="saturation">1</Set>
                <Set name="brightness">1</Set>
                <Set name="contrast">0.1</Set>
            </AvatarTransform>
            <AvatarTransform class="Scale">
                <Set name="targetScale">reset</Set>
            </AvatarTransform>
        </OnDrawCustomOutline>
        <AddClothingParticles>
            <ParticleSystemUpdate name="ps_dust_blue"/>
            <ParticleSystemUpdate name="ps_dust_purple"/>
            <ParticleSystemUpdate name="ps_dust_blue2"/>
            <ParticleSystemUpdate name="ps_dust_purple2"/>
            <ParticleSystemUpdate name="ps_glow"/>
            <ParticleSystemUpdate name="ps_skin_stars_purple"/>
        </AddClothingParticles>
        <RenderInFront>
            <SpriteRender name="championSlash" offset="60,72" scale="1.5,1.5" alignment="DOWN_CENTER" blend="PREMULTIPLIED_ALPHA" drawShadow="false" onAction="PUNCH"/>
            <ParticleSystemRender name="p_hit" onAction="PUNCH"/>
        </RenderInFront>
        <RenderHandItem>
            <SpriteRender name="s_swordglow" scale="0.5,0.8" rotateOffset="true" offset="16,5" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
            <SpriteRender name="s_sword" scale="0.5,0.8" rotateOffset="true" offset="15,5" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
        </RenderHandItem>
        <RenderBehind>
            <ParticleSystemRender name="ps_dust_blue"/>
            <ParticleSystemRender name="ps_dust_purple"/>
            <ParticleSystemRender name="ps_dust_blue2"/>
            <ParticleSystemRender name="ps_dust_purple2"/>
            <ParticleSystemRender name="ps_glow"/>
            <SpriteRender name="s_trophy" offset="0,-18" scale="0.5,0.5" alignment="DOWN_CENTER"/>
            <SpriteRender name="s_stat1" offset="-32,-30" scale="0.2,0.2" alignment="DOWN_CENTER" blendingMode="ADDITIVE"/>
            <SpriteRender name="s_stat2" offset="32,-50" scale="0.2,0.2" alignment="DOWN_CENTER" blendingMode="ADDITIVE"/>
            <ParticleSystemRender name="ps_skin_stars_purple"/>
        </RenderBehind>
        <OnPunchUpdate>
            <StopIf>
                <IsZombified>true</IsZombified>
            </StopIf>
            <AvatarTransform class="Face">
                <Set name="face">MAD</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle">
                <Set name="armName">arm2Angle</Set>
                <Set name="armAngle">1100</Set>
                <Set name="isAdditive">true</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle">
                <Set name="armName">arm1Angle</Set>
                <Set name="armAngle">0</Set>
            </AvatarTransform>
        </OnPunchUpdate>
        <OnDamagedTile>
            <ParticleSystemUpdate name="p_hit"/>
        </OnDamagedTile>
        <OnRespawned>
            <ParticleSystemUpdate name="ps_resp"/>
        </OnRespawned>
        <SwitchOffClothingParticles>
            <ParticleSystemOff name="ps_dust_blue"/>
            <ParticleSystemOff name="ps_dust_purple"/>
            <ParticleSystemOff name="ps_dust_blue2"/>
            <ParticleSystemOff name="ps_dust_purple2"/>
            <ParticleSystemOff name="ps_glow"/>
            <ParticleSystemOff name="ps_tpy"/>
            <ParticleSystemOff name="ps_skin_stars_purple"/>
            <ParticleSystemOff name="championSlash"/>
        </SwitchOffClothingParticles>
    </RenderRules>
</ItemRenderer>
