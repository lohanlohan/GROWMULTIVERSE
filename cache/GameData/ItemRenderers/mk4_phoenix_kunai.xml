<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
    <Data>
        <Sprite name="s_Dagger1" fileName="game//mk4_enigma_dvw_1.rttex" textureSize="64" frame="15,4"/>
        <Sprite name="s_Flowers" fileName="game//mk4_enigma_particles_small2.rttex" textureSize="32"/>
        <Sprite name="s_projectile" fileName="game//mk4_enigma_dvw_1.rttex" textureSize="64" frame="15,3"/>
        <Sprite name="s_HitPetals" fileName="game//mk4_enigma_particles_small2.rttex" textureSize="32"/>
        <Sprite name="s_Everything" fileName="game//mk4_enigma_particles_small2.rttex" textureSize="32"/>
        <Sprite name="HitSpark_Sprite" fileName="game//mk4_particles11.rttex" textureSize="32"/>
        <Sprite name="trail_Sprite" fileName="game//mk4_enigma_particles_small2.rttex" textureSize="32"/>
        <Sprite name="glove" fileName="game//mk4_custom_cosmetics1.rttex" textureSize="32" frame="30,4"/>
        <StateMachines>
            <StateMachine name="Motion">
                <States>
                    <State name="Idle"/>
                    <State name="Move"/>
                    <State name="Punch"/>
                </States>
                <Transitions>
                    <Transition to="Idle" from="Move|Punch">
                        <Condition type="and">
                            <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Move" from="Idle|Punch">
                        <Condition type="and">
                            <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Punch" from="Idle|Move">
                        <Condition>
                            <IsAction>PUNCH</IsAction>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
        </StateMachines>
        <VariableMap>
            <Set name="kunai_angle">0</Set>
            <Set name="kunai_angle2">0</Set>
            <Set name="kunai_angle3">0</Set>
            <Set name="kunai_angle4">0</Set>
        </VariableMap>
        <Animations>
            <SpriteAnimation name="HitSpark_Anim" autoPlay="false" isLoop="false" sprite="HitSpark_Sprite" animTime="200">
                <Frame>30, 18</Frame>
                <Frame>30, 19</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="trail_anim" autoPlay="true" sprite="trail_Sprite" animTime="1200">
                <Frame>4, 4</Frame>
                <Frame>5, 4</Frame>
            </SpriteAnimation>
            <CurveAnimationFloat name="kunai_angle_rotation" autoPlay="true" isLoop="true" animTime="6000">
                <Curve name="kunai_angle">
                    <KeyFrame>0, -25</KeyFrame>
                    <KeyFrame>0.5, 25</KeyFrame>
                    <KeyFrame>1, -25</KeyFrame>
                </Curve>
            </CurveAnimationFloat>
            <CurveAnimationFloat name="kunai_angle_rotation2" autoPlay="true" isLoop="true" animTime="5000">
                <Curve name="kunai_angle2">
                    <KeyFrame>0, 25</KeyFrame>
                    <KeyFrame>0.5, -25</KeyFrame>
                    <KeyFrame>1, 25</KeyFrame>
                </Curve>
            </CurveAnimationFloat>
            <CurveAnimationFloat name="kunai_angle_rotation3" autoPlay="true" isLoop="true" animTime="5000">
                <Curve name="kunai_angle3">
                    <KeyFrame>0, -25</KeyFrame>
                    <KeyFrame>0.5, 25</KeyFrame>
                    <KeyFrame>1, -25</KeyFrame>
                </Curve>
            </CurveAnimationFloat>
            <CurveAnimationFloat name="kunai_angle_rotation4" autoPlay="true" isLoop="true" animTime="5000">
                <Curve name="kunai_angle4">
                    <KeyFrame>0, 25</KeyFrame>
                    <KeyFrame>0.5, -25</KeyFrame>
                    <KeyFrame>1, 25</KeyFrame>
                </Curve>
            </CurveAnimationFloat>
            <SpriteAnimation name="a_Flowers" sprite="s_Flowers">
                <Frame>2,4</Frame>
                <Frame>3,4</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="a_hitPetals" sprite="s_HitPetals">
                <Frame>0,4</Frame>
                <Frame>1,4</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="a_Everything" sprite="s_Everything">
                <Frame>0,4</Frame>
                <Frame>1,4</Frame>
                <Frame>2,4</Frame>
                <Frame>3,4</Frame>
            </SpriteAnimation>
        </Animations>
        <ParticleSystems>
            <ParticleSystem name="ps_Kunai">
                <Emitter>
                    <Set name="offset">0, -22</Set>
                    <Set name="emissionInterval">0.04</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <OrbitOffset>
                        <Set name="maxScale">0.7f</Set>
                        <Set name="hasOrbit">true</Set>
                        <Set name="hOrbitPeriod">6000</Set>
                        <Set name="hAmplitude">25</Set>
                        <Set name="hTimeOffset">1500</Set>
                        <Set name="vAmplitude">3</Set>
                        <Set name="vOrbitPeriod">4000</Set>
                        <Set name="vTimeOffset">750</Set>
                        <Set name="minScale">0.4</Set>
                    </OrbitOffset>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_Dagger1</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">0.06</Set>
                    <Set name="initialAngle" source="kunai_angle"/>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.45,0.45</KeyFrame>
                        <KeyFrame>1, 0.45,0.45</KeyFrame>
                    </Curve>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_Kunai3">
                <Emitter>
                    <Set name="offset">0, -22</Set>
                    <Set name="emissionInterval">0.04</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <OrbitOffset>
                        <Set name="maxScale">0.7f</Set>
                        <Set name="hasOrbit">true</Set>
                        <Set name="hOrbitPeriod">6000</Set>
                        <Set name="hAmplitude">25</Set>
                        <Set name="hTimeOffset">3000</Set>
                        <Set name="vAmplitude">3</Set>
                        <Set name="vOrbitPeriod">4000</Set>
                        <Set name="vTimeOffset">1500</Set>
                        <Set name="minScale">0.4</Set>
                    </OrbitOffset>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_Dagger1</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">0.06</Set>
                    <Set name="initialAngle" source="kunai_angle3"/>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.45,0.45</KeyFrame>
                        <KeyFrame>1, 0.45,0.45</KeyFrame>
                    </Curve>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_Kunai2">
                <Emitter>
                    <Set name="offset">0, -22</Set>
                    <Set name="emissionInterval">0.04</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <OrbitOffset>
                        <Set name="maxScale">0.7f</Set>
                        <Set name="hasOrbit">true</Set>
                        <Set name="hOrbitPeriod">6000</Set>
                        <Set name="hAmplitude">25</Set>
                        <Set name="hTimeOffset">3</Set>
                        <Set name="vAmplitude">3</Set>
                        <Set name="vOrbitPeriod">4000</Set>
                        <Set name="vTimeOffset">3</Set>
                        <Set name="minScale">0.4</Set>
                    </OrbitOffset>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_Dagger1</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">0.06</Set>
                    <Set name="initialAngle" source="kunai_angle2"/>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.45,0.45</KeyFrame>
                        <KeyFrame>1, 0.45,0.45</KeyFrame>
                    </Curve>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_Kunai4">
                <Emitter>
                    <Set name="offset">0, -22</Set>
                    <Set name="emissionInterval">0.04</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <OrbitOffset>
                        <Set name="maxScale">0.7f</Set>
                        <Set name="hasOrbit">true</Set>
                        <Set name="hOrbitPeriod">6000</Set>
                        <Set name="hAmplitude">25</Set>
                        <Set name="hTimeOffset">4500</Set>
                        <Set name="vAmplitude">3</Set>
                        <Set name="vOrbitPeriod">4000</Set>
                        <Set name="vTimeOffset">2250</Set>
                        <Set name="minScale">0.4</Set>
                    </OrbitOffset>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_Dagger1</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">0.06</Set>
                    <Set name="initialAngle" source="kunai_angle4"/>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.45,0.45</KeyFrame>
                        <KeyFrame>1, 0.45,0.45</KeyFrame>
                    </Curve>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_punchProjectile" secondary="ps_punchTrail" updateStage="AddClothingParticles" updateState="Motion.Punch">
                <Emitter>
                    <Random name="emissionInterval" min="0.15" max="0.23"/>
                    <Set name="infParticles">true</Set>
                    <Set name="lifeTime">0.35</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <Set name="offset">8,-10</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_projectile</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">0.3</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 0</KeyFrame>
                        <KeyFrame>0.2, 0</KeyFrame>
                        <KeyFrame>0.2, 1</KeyFrame>
                        <KeyFrame>1, 1</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.45,0.45</KeyFrame>
                        <KeyFrame>1, 0.45,0.45</KeyFrame>
                    </Curve>
                    <Random name="offset" min="-10, -8" max="10, 8"/>
                    <VectorTo name="initialVelocity" source="targetPos" offset="offset" duration="lifeTime" x="1"/>
                    <Set name="rotateWithVelocity">true</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_punchTrail">
                <Emitter>
                    <Random name="emissionInterval" min="0.012" max="0.03"/>
                    <Set name="infParticles">true</Set>
                    <Set name="lifeTime">0.5</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle randomSpriteFrame="true">
                    <Set name="sprite">s_Everything</Set>
                    <Set name="renderAlignment">CENTER</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Random name="offset" min="-1, 1" max="1, -1"/>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.2, 1</KeyFrame>
                        <KeyFrame>0.95, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.1, 0.1</KeyFrame>
                        <KeyFrame>0.65, 0.22, 0.22</KeyFrame>
                        <KeyFrame>1, 0.1, 0.1</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">1</Set>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="10,18"/>
                    <Select name="initialRotationRate" input="randomNumber">
                        <Item>-270</Item>
                        <Item>-90</Item>
                        <Item>180</Item>
                        <Item>90</Item>
                    </Select>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_shrapnel">
                <Emitter>
                    <Set name="lifeTime">0.25</Set>
                    <Set name="particlesPerEmission">16</Set>
                    <Set name="particlesToEmit">1</Set>
                </Emitter>
                <Particle randomSpriteFrame="true">
                    <Set name="sprite">s_HitPetals</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">1</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.85, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.45,0.45</KeyFrame>
                        <KeyFrame>1, 0.1,0.1</KeyFrame>
                    </Curve>
                    <Select name="initialRotationRate" input="randomNumber">
                        <Item>-270</Item>
                        <Item>-90</Item>
                        <Item>180</Item>
                        <Item>90</Item>
                    </Select>
                    <Random name="offset" min="-8" max="8"/>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="40,60"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="hitSpark_particle" secondary="trail_particle">
                <Emitter>
                    <Set name="particlesPerEmission">8</Set>
                    <Set name="lifeTime">2</Set>
                    <Set name="useTargetTileColorForTint">true</Set>
                </Emitter>
                <Particle randomSpriteFrame="true">
                    <Set name="sprite">HitSpark_Sprite</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="useGravity">true</Set>
                    <Set name="interpolateScale">true</Set>
                    <Set name="initialScale">2,2</Set>
                    <Random name="finalScale" min="0.1, 0.1" max="0.4, 0.4"/>
                    <Set name="lifeTime">1</Set>
                    <RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="80,200"/>
                    <Set name="gravityVector">0, 100</Set>
                    <Random name="initialRotationRate" min="-300" max="300"/>
                    <Random name="posOffset" min="0.1, 0" max="16.1, 16.3"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="trail_particle">
                <Emitter>
                    <Set name="lifeTime">1</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <Set name="particlesToEmit">80</Set>
                    <Set name="emissionInterval">0.2</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">trail_Sprite</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">1.2</Set>
                    <Set name="initialRotationRate">150</Set>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0, 0</KeyFrame>
                        <KeyFrame>0.4, 1, 1</KeyFrame>
                        <KeyFrame>0.8, 0.3, 0.3</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 0.5</KeyFrame>
                        <KeyFrame>0.8, 0</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Set name="initialVelocity">0,0</Set>
                </Particle>
            </ParticleSystem>
        </ParticleSystems>
        <RenderOptions>
            <Default>
                <Set name="IncludeAllActions">true</Set>
                <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
            </Default>
        </RenderOptions>
    </Data>
    <RenderRules>
        <RenderBackHandItem>
            <SpriteRender name="glove" offset="-2.6,11" rotateOffset="true" rotationPoint="0,1" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
        </RenderBackHandItem>
        <RenderHandItem>
            <SpriteRender name="glove" rotateOffset="true" alignment="UPPER_CENTER" blend="PREMULTIPLIED_ALPHA"/>
        </RenderHandItem>
        <RenderInFront>
            <ParticleSystemRender name="ps_Kunai"/>
            <ParticleSystemRender name="ps_Kunai2"/>
            <ParticleSystemRender name="ps_Kunai3"/>
            <ParticleSystemRender name="ps_Kunai4"/>
        </RenderInFront>
        <AddClothingParticles>
            <ParticleSystemUpdate name="ps_Kunai"/>
            <ParticleSystemUpdate name="ps_Kunai2"/>
            <ParticleSystemUpdate name="ps_Kunai3"/>
            <ParticleSystemUpdate name="ps_Kunai4"/>
        </AddClothingParticles>
        <SwitchOffClothingParticles>
            <ParticleSystemOff name="hitSpark_particle"/>
        </SwitchOffClothingParticles>
        <OnPunchUpdate>
            <StopIf>
                <IsZombified>true</IsZombified>
            </StopIf>
            <AvatarTransform class="Face">
                <Set name="face">MAD</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle">
                <Set name="armName">arm1Angle</Set>
                <Set name="animTime">200</Set>
                <Set name="Curve">
                    <KeyFrame>0, 0</KeyFrame>
                    <KeyFrame>1, 360</KeyFrame>
                </Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle">
                <Set name="armName">arm2Angle</Set>
                <Set name="animTime">200</Set>
                <Set name="Curve">
                    <KeyFrame>0, 180</KeyFrame>
                    <KeyFrame>1, 540</KeyFrame>
                </Set>
            </AvatarTransform>
        </OnPunchUpdate>
        <OnDamagedTile>
            <ParticleSystemUpdate name="ps_shrapnel"/>
        </OnDamagedTile>
        <OnDestroyedTile>
            <ParticleSystemUpdate name="hitSpark_particle"/>
        </OnDestroyedTile>
    </RenderRules>
</ItemRenderer>
