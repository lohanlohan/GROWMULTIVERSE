<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="s_Hair" fileName="game/enigma_particles5.rttex" textureSize="64" frame="12,1"/>
		<Sprite name="s_Bubbles" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="5,12"/>

		<Animations>
			<SpriteAnimation name="A_Hair" autoPlay="true" sprite="s_Hair" isLoop="true" animTime="800">
       			<Frame>12,1</Frame>
                <Frame>13,1</Frame>
				<Frame>14,1</Frame>
				<Frame>15,1</Frame>
			</SpriteAnimation>
		</Animations>

	<ParticleSystems>
      <ParticleSystem name="MoveTrail_going_right">
        <Emitter usePlayerFacing="true">
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Random name="emissionInterval" min="0.2" max="0.7"/>
          <Set name="particlesPerEmission">1</Set>
		  <Set name="offsetFacing">true</Set>
          <Random name="offset" min="10, -33" max="8, -34"/>
        </Emitter>
        <Particle>
          <Set name="sprite">s_Bubbles</Set>
          <Set name="blendingMode">ADDITIVE</Set>
          <Random name="lifeTime" min="2.5" max="4"/>
          <Curve name="initialAlpha">
            <KeyFrame>0, 0.25</KeyFrame>
            <KeyFrame>0.25, 0.55</KeyFrame>
            <KeyFrame>0.75, 0.55</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Set name="interpolateScale">true</Set>
          <Random name="initialScale" min="0.1,0.1" max="0.15,0.15"/>
          <Random name="finalScale" min="1.3,1.3" max="1.5,1.5"/>
          <Random name= "initialVelocity" min="-12,-1" max="-15,-2"/>
          <Curve name="initialRotationRate">
            <KeyFrame>0, 720</KeyFrame>
            <KeyFrame>1, 10000</KeyFrame>
          </Curve>
        </Particle>
      </ParticleSystem>

      <ParticleSystem name="MoveTrail_going_left">
        <Emitter usePlayerFacing="true">
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Random name="emissionInterval" min="0.2" max="0.7"/>
          <Set name="particlesPerEmission">1</Set>
		  <Set name="offsetFacing">true</Set>
          <Random name="offset" min="10, -33" max="8, -34"/>
        </Emitter>
        <Particle>
          <Set name="sprite">s_Bubbles</Set>
          <Set name="blendingMode">ADDITIVE</Set>
          <Random name="lifeTime" min="2.5" max="4"/>
          <Curve name="initialAlpha">
            <KeyFrame>0, 0.25</KeyFrame>
            <KeyFrame>0.25, 0.55</KeyFrame>
            <KeyFrame>0.75, 0.55</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Set name="interpolateScale">true</Set>
          <Random name="initialScale" min="0.1,0.1" max="0.15,0.15"/>
          <Random name="finalScale" min="1.3,1.3" max="1.5,1.5"/>
          <Random name= "initialVelocity" min="12,-1" max="15,-2"/>
          <Curve name="initialRotationRate">
            <KeyFrame>0, 720</KeyFrame>
            <KeyFrame>1, 10000</KeyFrame>
          </Curve>
        </Particle>
      </ParticleSystem>
	</ParticleSystems>

		<RenderOptions>
			<Default>
                <Set name="IncludeAllActions">true</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderHair>
            <SpriteRender name="s_Hair" offset="-10,-32" blend="PREMULTIPLIED_ALPHA"/>
		</RenderHair>

		<AddClothingParticles>
			<ParticleSystemUpdate name="MoveTrail_going_right" onState="Facing.Right"/>
            <ParticleSystemUpdate name="MoveTrail_going_left" onState="Facing.Left"/>
		</AddClothingParticles>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="MoveTrail_going_right"/>
            <ParticleSystemOff name="MoveTrail_going_left"/>
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>