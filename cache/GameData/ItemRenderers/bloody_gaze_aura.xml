<?xml version="1.0" ?>
<ItemRenderer>
    <Data>
    <StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

    <Sprite name="s_Eyes" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="2,12" />
	<Sprite name="s_Portal1" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="9,10" />
	<Sprite name="s_Portal2" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="9,10" />
	<Sprite name="s_Portal3" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="9,10" />
	<Sprite name="s_Smoke" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="10,10" />
	<Sprite name="s_SmokeGlowRight" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="10,10" />
	<Sprite name="s_SmokeGlowLeft" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="11,10" />

    <Animations>
    <SequenceAnimation name="a_aura" autoPlay="true" isLoop="true">
        <DelayAnimation delayTime="750" />
    <SpriteAnimation name="a_BloodEyes" sprite="s_Eyes" animTime="1000" autoPlay="true" isLoop="true">
        <Frame>2,12</Frame>
        <Frame>3,12</Frame>
        <Frame>4,12</Frame>
        <Frame>5,12</Frame>
        <Frame>6,12</Frame>
        <Frame>7,12</Frame>
    </SpriteAnimation>
    </SequenceAnimation>

    <SpriteSinPulseAnimation name="eye_float" sprite="s_Eyes" autoPlay="true">
			<Parameter name="pos.y">
				<Set name="period">3000</Set>
				<Set name="scale">1</Set>
			</Parameter>
	</SpriteSinPulseAnimation>

	<SpriteCurveAnimation name="A_PortalSpin1" sprite="s_Portal1" animTime="11000" autoPlay="true" isLoop="true">
            <Curve name="rotation">
				<KeyFrame>0, 0</KeyFrame>
				<KeyFrame>1, 360</KeyFrame>
			</Curve>
		</SpriteCurveAnimation>
		<SpriteCurveAnimation name="A_PortalSpin2" sprite="s_Portal2" animTime="10000" autoPlay="true" isLoop="true">
            <Curve name="rotation">
				<KeyFrame>0, 0</KeyFrame>
				<KeyFrame>1, -360</KeyFrame>
			</Curve>
		</SpriteCurveAnimation>
		<SpriteCurveAnimation name="A_PortalSpin3" sprite="s_Portal3" animTime="12900" autoPlay="true" isLoop="true">
            <Curve name="rotation">
				<KeyFrame>0, 0</KeyFrame>
				<KeyFrame>1, 360</KeyFrame>
			</Curve>
		</SpriteCurveAnimation>
    </Animations>

	<ParticleSystems>
			<ParticleSystem name="ps_SmokeGlowRight">
				<Emitter usePlayerFacing="true">
					<Set name="offset">0, -33</Set>
					<Set name="offsetFacing">false</Set>
					<Set name="emissionInterval">1.5</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_SmokeGlowRight</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="inSpecificOrder">true</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="interpolateAlpha">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1.1, 1.1</KeyFrame>
						<KeyFrame>1, 1.3, 1.3</KeyFrame>
					</Curve>
					<Set name="lifeTime">2.5</Set>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="ps_SmokeGlowLeft">
				<Emitter usePlayerFacing="true">
					<Set name="offset">0, -33</Set>
					<Set name="offsetFacing">false</Set>
					<Set name="emissionInterval">1.5</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_SmokeGlowLeft</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="inSpecificOrder">true</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="interpolateAlpha">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1.1, 1.1</KeyFrame>
						<KeyFrame>1, 1.3, 1.3</KeyFrame>
					</Curve>
					<Set name="lifeTime">2.5</Set>
				</Particle>
			</ParticleSystem>
	</ParticleSystems>

    </Data>

    <RenderRules>

    <RenderBackpack>
     <Group>
	  <SpriteRender name="s_Eyes" offset="1,-43" blend="PREMULTIPLIED_ALPHA" drawShadow="false" alignment="CENTER"/>>
      <ContextUpdate type="SetFlip">
        <Set name="flip">0,0</Set>
      </ContextUpdate>
    </Group>
    </RenderBackpack>

	<RenderBehind>
		<SpriteRender name="s_Smoke" offset="0,-9" scale="1.3,1.3" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
		<ParticleSystemRender name="ps_SmokeGlowRight" onState="Facing.Right"/>
		<ParticleSystemRender name="ps_SmokeGlowLeft" onState="Facing.Left"/>
		<SpriteRender name="s_Portal1" offset="0,-9" scale="0.95,0.95" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
		<SpriteRender name="s_Portal2" offset="0,-9" scale="0.65,0.65" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
		<SpriteRender name="s_Portal3" offset="0,-9" scale="0.35,0.35" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
	</RenderBehind>

	<AddClothingParticles>
		<ParticleSystemUpdate name="ps_SmokeGlowRight" />
		<ParticleSystemUpdate name="ps_SmokeGlowLeft" />
	</AddClothingParticles>

    </RenderRules>
</ItemRenderer>
    