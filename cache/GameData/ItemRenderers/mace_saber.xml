<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="s_Edge" fileName="game/enigma_sabers_1.rttex" textureSize="64" frame="0,3"/>
        <Sprite name="s_PunchProjectiles" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>

		<Animations>
			<SequenceAnimation name="a_sword" autoPlay="true" isLoop="false">
                <SpriteAnimation sprite="s_Edge" autoPlay="true" animTime="1000" isLoop="false">
					<Frame>0,3</Frame>
				</SpriteAnimation>
                <DelayAnimation delayTime="750" />
                <SpriteAnimation sprite="s_Edge" autoPlay="true" animTime="145" isLoop="false">
					<Frame>1,3</Frame>
					<Frame>2,3</Frame>
					<Frame>3,3</Frame>
       			    <Frame>4,3</Frame>
                    <Frame>5,3</Frame>
				</SpriteAnimation>

				<SpriteAnimation sprite="s_Edge" autoPlay="true" animTime="2000" isLoop="true">
       			    <Frame>5,3</Frame>
				</SpriteAnimation>
			</SequenceAnimation>
            <SpriteAnimation name="a_PunchParticles" sprite="s_PunchProjectiles">
                <Frame>3,5</Frame>
                <Frame>3,6</Frame>
            </SpriteAnimation>
		</Animations>

		<ParticleSystems>
			<ParticleSystem name="Punch_Ps" updateStage="OnPunchStart">
				<Emitter attachment="targetPos">
                    <Set name="emissionInterval">0.25</Set>
					<Random name="offset" min="-8,8" max="8,-8"/>
					<Set name="lifeTime">0</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_PunchProjectiles</Set>
					<Set name="offset">0, 0</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.75</Set>
                    <Random name="initialAngle" min="0" max="360"/>
				        <Curve name="initialAlpha">
					        <KeyFrame>0, 1</KeyFrame>
					        <KeyFrame>0.25, 1</KeyFrame>
					        <KeyFrame>1, 0</KeyFrame>
				        </Curve>
				        <Curve name="initialScale">
            		        <KeyFrame>0, 2,1.2</KeyFrame>
            		        <KeyFrame>1, 2,1.2</KeyFrame>
          		        </Curve>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>

		<RenderOptions>
			<Default>
                <Set name="PunchSoundOverride">HAND</Set>
				<Set name="PlayDefaultPunchAudio">false</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderHandItem>
			<SpriteRender name="s_Edge" rotateOffset="true" offset="20,5" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
		</RenderHandItem>

		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
		    <AvatarTransform class="ArmAngle">
			    <Set name="armName">arm2Angle</Set>
			    <Set name="armAngle">1750</Set>
			    <Set name="isAdditive">true</Set>
			    <Set name="pointTowardsPunchTarget">false</Set>
		    </AvatarTransform>
		</OnPunchUpdate>
	</RenderRules>
</ItemRenderer>