<?xml version="1.0"?>
<ItemRenderer>
    <Data>
        <StateMachines>
            <StateMachine name="Motion">
                <States>
                    <State name="Idle"/>
                    <State name="Move"/>
                    <State name="Punch"/>
                </States>
                <Transitions>
                    <Transition to="Idle" from="Move|Punch">
                        <Condition type="and">
                            <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Move" from="Idle|Punch">
                        <Condition type="and">
                            <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Punch" from="Idle|Move">
                        <Condition>
                            <IsAction>PUNCH</IsAction>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
        </StateMachines>
        <Sprite name="Helm" fileName="game//mk4_custom_cosmetics1.rttex" textureSize="32" frame="15,8"/>
        <Sprite name="Aura" fileName="game//mk4_enigma_particles4.rttex" textureSize="64" frame="6,1"/>
        <Sprite name="s_Pet" fileName="game//mk4_enigma_128_sprites1.rttex" textureSize="128" frame="11,0"/>
        <Sprite name="sword" fileName="game//mk4_custom_hand1.rttex" textureSize="32" frame="1,6"/>
        <Sprite name="dragon_fire" fileName="game//mk4_enigma_particles_small2.rttex" textureSize="32" frame="13,1"/>
        <Sprite name="HitSpark_Sprite" fileName="game//mk4_particles.rttex" textureSize="32"/>
        <Sprite name="trail_Sprite" fileName="game//mk4_enigma_particles_small2.rttex" textureSize="32"/>
        <Animations>
            <SpriteCurveAnimation name="Aura_Spin" autoPlay="true" isLoop="true" sprite="Aura" animTime="7500">
                <Curve name="rotation">
                    <KeyFrame>0, 0</KeyFrame>
                    <KeyFrame>1, 360</KeyFrame>
                </Curve>
            </SpriteCurveAnimation>
            <SpriteAnimation name="HitSpark_Anim" autoPlay="false" isLoop="false" sprite="HitSpark_Sprite" animTime="200">
                <Frame>7, 5</Frame>
                <Frame>8, 5</Frame>
                <Frame>9, 5</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="trail_anim" autoPlay="true" sprite="trail_Sprite" animTime="1200">
                <Frame>4, 4</Frame>
                <Frame>5, 4</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="a_dragon_idle" sprite="s_Pet" animTime="725" isLoop="true" autoPlay="true">
                <Frame>10,0</Frame>
                <Frame>11,0</Frame>
                <Frame>12,0</Frame>
                <Frame>11,0</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="a_dragon_punch" sprite="s_Pet" animTime="725" isLoop="true" playOnState="Motion.Punch">
                <Frame>13,0</Frame>
            </SpriteAnimation>
        </Animations>
        <ParticleSystems>
            <ParticleSystem name="ps_punchProjectile" updateStage="RenderPet" updateState="Motion.Punch">
                <Emitter usePlayerFacing="true">
                    <Random name="emissionInterval" min="0.002" max="0.004"/>
                    <Set name="infParticles">true</Set>
                    <Set name="lifeTime">0.15</Set>
                    <Set name="particlesPerEmission">3</Set>
                    <Set name="offset">-10,-38</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">dragon_fire</Set>
                    <Set name="blendingMode">ADDITIVE</Set>
                    <Set name="lifeTime">0.15</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 1</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.8,0.8</KeyFrame>
                        <KeyFrame>1, 1.5,1.5</KeyFrame>
                    </Curve>
                    <Random name="targetPosOffset" min="-3, -13" max="3, 13"/>
                    <VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="1"/>
                    <Set name="rotateWithVelocity">true</Set>
                    <OnFinish>
                        <ParticleSystemName>ps_punchSmoke</ParticleSystemName>
                    </OnFinish>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_punchSmoke">
                <Emitter>
                    <Set name="emissionInterval">0.01</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="lifeTime">0.5</Set>
                    <Set name="particlesPerEmission">2</Set>
                    <Set name="delay">-0.25</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">dragon_fire</Set>
                    <Set name="renderAlignment">CENTER</Set>
                    <Set name="blendingMode">ADDITIVE</Set>
                    <Random name="offset" min="-8, -8" max="8, 8"/>
                    <Set name="initialAngle">180</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.6, 0.6</KeyFrame>
                        <KeyFrame>1, 0.05, 0.05</KeyFrame>
                    </Curve>
                    <Set name="rotateWithVelocity">true</Set>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="60,80"/>
                    <Set name="lifeTime">0.5</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="hitSpark_particle" secondary="trail_particle">
                <Emitter>
                    <Set name="particlesPerEmission">8</Set>
                    <Set name="lifeTime">2</Set>
                    <Set name="useTargetTileColorForTint">true</Set>
                </Emitter>
                <Particle randomSpriteFrame="true">
                    <Set name="sprite">HitSpark_Sprite</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="useGravity">true</Set>
                    <Set name="interpolateScale">true</Set>
                    <Set name="initialScale">2,2</Set>
                    <Random name="finalScale" min="0.1, 0.1" max="0.4, 0.4"/>
                    <Set name="lifeTime">1</Set>
                    <RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="80,200"/>
                    <Set name="gravityVector">0, 100</Set>
                    <Random name="initialRotationRate" min="-300" max="300"/>
                    <Random name="posOffset" min="0.1, 0" max="16.1, 16.3"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="trail_particle">
                <Emitter>
                    <Set name="lifeTime">1</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <Set name="particlesToEmit">80</Set>
                    <Set name="emissionInterval">0.2</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">trail_Sprite</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">1.2</Set>
                    <Set name="initialRotationRate">150</Set>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0, 0</KeyFrame>
                        <KeyFrame>0.4, 1, 1</KeyFrame>
                        <KeyFrame>0.8, 0.3, 0.3</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 0.5</KeyFrame>
                        <KeyFrame>0.8, 0</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Set name="initialVelocity">0,0</Set>
                </Particle>
            </ParticleSystem>
        </ParticleSystems>
        <VariableMap>
            <Set name="projectile_offset">0, 0</Set>
            <Set name="projectile_angle">0</Set>
        </VariableMap>
        <RenderOptions>
            <Default>
                <Set name="NeedRenderPet">true</Set>
                <Set name="PetOffsetDuplication">0,0</Set>
                <Set name="IgnoreDefaultDamagedTileEffect">false</Set>
                <Set name="IgnoreDefaultDestroyedTileEffect">false</Set>
                <Set name="HideParticlesOnTransform">false</Set>
                <Set name="PunchSoundOverride">HAT</Set>
                <Set name="PlayDefaultPunchAudio">false</Set>
            </Default>
        </RenderOptions>
    </Data>
    <RenderRules>
        <RenderHat>
            <SpriteRender name="Helm" rotateOffset="true" offset="0,-32" alignment="CENTER"/>
        </RenderHat>
        <RenderBehind>
            <SpriteRender name="Aura" rotateOffset="true" offset="0,-9" blend="ADDITIVE" drawShadow="false" alignment="CENTER"/>
        </RenderBehind>
        <RenderPet>
            <SpriteRender name="s_Pet" alignment="DOWN_CENTER" offset="-66,15"/>
        </RenderPet>
        <OnPunchUpdate>
            <AvatarTransform class="Face">
                <Set name="face">MAD</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle">
                <Set name="armName">arm2Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle">
                <Set name="armName">arm1Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
            </AvatarTransform>
        </OnPunchUpdate>
        <OnDestroyedTile>
            <ParticleSystemUpdate name="hitSpark_particle"/>
        </OnDestroyedTile>
        <SwitchOffClothingParticles>
            <ParticleSystemOff name="hitSpark_particle"/>
        </SwitchOffClothingParticles>
    </RenderRules>
</ItemRenderer>
