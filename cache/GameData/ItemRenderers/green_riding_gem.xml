<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
    	<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
		<Sprite name="foot1_Sprite" fileName="game/enigma_custom_items1.rttex" textureSize="32" frame="30,0"/>
		<Sprite name="foot2_Sprite" fileName="game/enigma_custom_items1.rttex" textureSize="32" frame="30,1"/>
		<Sprite name="s_legs" fileName="game/player_sit.rttex" textureSize="32" frame="1,0" />
        <Sprite name="spark_trail" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>
        <Animations>
            <SpriteAnimation name="move_trailleft2" sprite="spark_trail" isLoop="true" animTime="250">
       			<Frame>6,13</Frame>
                <Frame>7,13</Frame>
            </SpriteAnimation>
			<SpriteAnimation name="move_trailright2" sprite="spark_trail" isLoop="true" animTime="250">
       			<Frame>6,13</Frame>
                <Frame>7,13</Frame>
			</SpriteAnimation>
		</Animations>
		<ParticleSystems>
        <ParticleSystem name="Spark_MoveTrail_going_right">
                <Emitter usePlayerFacing="true">
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Random name="emissionInterval" min="0.02" max="0.025"/>
                    <Set name="particlesPerEmission">1</Set>
		            <Set name="offsetFacing">true</Set>
                    <Random name="offset" min="-15, 9" max="-8, -8"/>
                </Emitter>
                <Particle randomSpriteFrame="true" velocityRelativeToPlayerSpeed="false">
                    <Set name="sprite">spark_trail</Set>
                    <Set name="isBackgroundParticle">false</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Random name="lifeTime" min="0.85" max="1.35"/>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.75, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.2,0.2</KeyFrame>
						<KeyFrame>0.05, 1,1</KeyFrame>
						<KeyFrame>0.1, 0.2,0.2</KeyFrame>
						<KeyFrame>0.15, 1,1</KeyFrame>
						<KeyFrame>0.2, 0.2,0.2</KeyFrame>
						<KeyFrame>0.25, 1,1</KeyFrame>
						<KeyFrame>0.3, 0.2,0.2</KeyFrame>
						<KeyFrame>0.35, 1,1</KeyFrame>
						<KeyFrame>0.4, 0.2,0.2</KeyFrame>
						<KeyFrame>0.45, 1,1</KeyFrame>
						<KeyFrame>0.5, 0.2,0.2</KeyFrame>
						<KeyFrame>0.55, 1,1</KeyFrame>
						<KeyFrame>0.6, 0.2,0.2</KeyFrame>
						<KeyFrame>0.65, 1,1</KeyFrame>
						<KeyFrame>0.7, 0.2,0.2</KeyFrame>
						<KeyFrame>0.75, 0.75,0.75</KeyFrame>
						<KeyFrame>0.8, 0.15,0.15</KeyFrame>
						<KeyFrame>0.85, 0.5,0.5</KeyFrame>
						<KeyFrame>0.9, 0.1,0.1</KeyFrame>
						<KeyFrame>0.95, 0.25,0.25</KeyFrame>
						<KeyFrame>1, 0.05,0.05</KeyFrame>
					</Curve>
				    <Random name="initialVelocity" min="0, 3" max="0, 5"/>
					<Select name="initialRotationRate" input="randomNumber">
						<Item>-720</Item>
						<Item>-360</Item>
						<Item>360</Item>
						<Item>720</Item>
					</Select> 
                </Particle>
            </ParticleSystem>

            <ParticleSystem name="Spark_MoveTrail_going_left">
                <Emitter usePlayerFacing="true">
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Random name="emissionInterval" min="0.02" max="0.025"/>
                    <Set name="particlesPerEmission">1</Set>
		            <Set name="offsetFacing">true</Set>
                    <Random name="offset" min="-15, 9" max="-8, -8"/>
                </Emitter>
                <Particle randomSpriteFrame="true" velocityRelativeToPlayerSpeed="false">
                    <Set name="sprite">spark_trail</Set>
                    <Set name="isBackgroundParticle">false</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Random name="lifeTime" min="0.85" max="1.35"/>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.75, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.2,0.2</KeyFrame>
						<KeyFrame>0.05, 1,1</KeyFrame>
						<KeyFrame>0.1, 0.2,0.2</KeyFrame>
						<KeyFrame>0.15, 1,1</KeyFrame>
						<KeyFrame>0.2, 0.2,0.2</KeyFrame>
						<KeyFrame>0.25, 1,1</KeyFrame>
						<KeyFrame>0.3, 0.2,0.2</KeyFrame>
						<KeyFrame>0.35, 1,1</KeyFrame>
						<KeyFrame>0.4, 0.2,0.2</KeyFrame>
						<KeyFrame>0.45, 1,1</KeyFrame>
						<KeyFrame>0.5, 0.2,0.2</KeyFrame>
						<KeyFrame>0.55, 1,1</KeyFrame>
						<KeyFrame>0.6, 0.2,0.2</KeyFrame>
						<KeyFrame>0.65, 1,1</KeyFrame>
						<KeyFrame>0.7, 0.2,0.2</KeyFrame>
						<KeyFrame>0.75, 0.75,0.75</KeyFrame>
						<KeyFrame>0.8, 0.15,0.15</KeyFrame>
						<KeyFrame>0.85, 0.5,0.5</KeyFrame>
						<KeyFrame>0.9, 0.1,0.1</KeyFrame>
						<KeyFrame>0.95, 0.25,0.25</KeyFrame>
						<KeyFrame>1, 0.05,0.05</KeyFrame>
					</Curve>
				    <Random name="initialVelocity" min="0, 3" max="0, 5"/>
					<Select name="initialRotationRate" input="randomNumber">
						<Item>-720</Item>
						<Item>-360</Item>
						<Item>360</Item>
						<Item>720</Item>
					</Select> 
                </Particle>
            </ParticleSystem>
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="IgnorePunchTypeCheck">true</Set>
				<Set name="UserNameOffset">2</Set>
				<Set name="ShouldHover">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
				
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderShoes>
			<SpriteRender name="foot1_Sprite" offset="17,17" alignmentLeft="DOWN_LEFT" alignmentRight="DOWN_RIGHT" drawShadow="false"/>
			<SpriteRender name="foot2_Sprite" offset="-15,17" alignmentLeft="DOWN_RIGHT" alignmentRight="DOWN_LEFT" drawShadow="false"/>
			<SpriteRender name="s_legs" offset="1,-7" tintOverride="SKINORPANTS" />
		</RenderShoes>
        <AddClothingParticles>
			<ParticleSystemUpdate name="Spark_MoveTrail_going_right" onState="Facing.Right" onAction="JUMP|FALL|WALK|JUMPDOUBLE"/>
            <ParticleSystemUpdate name="Spark_MoveTrail_going_left" onState="Facing.Left" onAction="JUMP|FALL|WALK|JUMPDOUBLE"/>
		</AddClothingParticles>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="Spark_MoveTrail_going_right"/>
            <ParticleSystemOff name="Spark_MoveTrail_going_left"/>
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>