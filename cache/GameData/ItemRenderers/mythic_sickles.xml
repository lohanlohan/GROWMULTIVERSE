        <SpriteRender name="s_SickleGlowLeft" scale="0.5,0.5" offset="0,7" rotateOffset="true" alignment="LEFT_CENTER" blend="PREMULTIPLIED_ALPHA" onState="Facing.Left"/>
        <SpriteRender name="s_SickleRight" scale="0.5,0.5" offset="0,7" rotateOffset="true" alignment="RIGHT_CENTER" blend="PREMULTIPLIED_ALPHA" onState="Facing.Right"/>
        <SpriteRender name="s_SickleLeft" scale="0.5,0.5" offset="0,7" rotateOffset="true" alignment="LEFT_CENTER" blend="PREMULTIPLIED_ALPHA" onState="Facing.Left"/>
      </RenderHandItem>

    <RenderBehind>
			<ParticleSystemRender name="ps_HellRays" />
		</RenderBehind>

     <Update>
        <AvatarTransform class="ArmAngle" onAction="WALK|DANCE|JUMP|JUMPSTART|DOUBLEJUMP|FALL">
			    <Set name="armName">arm2Angle</Set>
			    <Set name="armAngle">0</Set>
		    </AvatarTransform>
      </Update>

      <OnPunchStart>
			<ParticleSystemUpdate name="slash_particle"/>
		</OnPunchStart>

      <OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
		    <AvatarTransform class="ArmAngle">
			    <Set name="armName">arm2Angle</Set>
			    <Set name="armAngle">-720</Set>
			    <Set name="isAdditive">true</Set>
			    <Set name="pointTowardsPunchTarget">false</Set>
		    </AvatarTransform>
		</OnPunchUpdate>

    <OnDamagedTile>
			<ParticleSystemUpdate name="hit_particle"/>
		</OnDamagedTile>

      <OnDrawCustomOutline>
      	<AvatarTransform class="Scale">
        	<Set name="targetScale">1.1,1.1</Set>
      	</AvatarTransform>
      </OnDrawCustomOutline>

      <AddClothingParticles>
			<ParticleSystemUpdate name="MoveTrail_going_right" onState="Facing.Right" onAction="WALK"/>
      <ParticleSystemUpdate name="MoveTrail_going_left" onState="Facing.Left" onAction="WALK"/>
      <ParticleSystemUpdate name="EmberLeftParticle" />
			<ParticleSystemUpdate name="EmberRightParticle" />
		</AddClothingParticles>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="MoveTrail_going_right"/>
      <ParticleSystemOff name="MoveTrail_going_left"/>
      <ParticleSystemOff name="slash_particle"/>
      <ParticleSystemOff name="hit_particle"/>
		</SwitchOffClothingParticles>
    </RenderRules>
</ItemRenderer>