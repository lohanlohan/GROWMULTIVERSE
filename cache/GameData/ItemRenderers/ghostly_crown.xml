<?xml version="1.0" ?>
<ItemRenderer>
    <Data>
        <Sprite name="s_Crown" fileName="game/custom_cosmetics1.rttex" textureSize="32,32" frame="13,10" />
        <Sprite name="s_FaceGlow" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="14,13"/>
	    <Sprite name="s_Aura" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="14,2"/>
        <Sprite name="double_jump_particle_Sprite" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="14,2"/>
		<Sprite name="s_fire" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="12,9"/>

		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

        <VariableMap>
            <Set name="crown.rotate">10,0,0,1</Set>
			<Set name="context.pos">0, 0</Set>
        </VariableMap>

        <Animations>
            <CurveAnimationVec4 name="anim_hand_rotate" autoPlay="true" isLoop="true" animTime="300">
                <Curve name="crown.rotate">
                    <KeyFrame>1, 8, 0, 0, 1</KeyFrame>
                </Curve>
            </CurveAnimationVec4>
            <SpriteSinPulseAnimation name="crown_float" sprite="s_Crown" autoPlay="true">
			<Parameter name="pos.y">
				<Set name="period">3000</Set>
				<Set name="scale">1</Set>
			</Parameter>
			</SpriteSinPulseAnimation>
    			<SpriteSinPulseAnimation name="eyes_stretch1" sprite="s_FaceGlow" autoPlay="true">
				<Parameter name="scale.x">
					<Set name="offset">1</Set>
					<Set name="period">2500</Set>
					<Set name="scale">0.07</Set>
				</Parameter>
			</SpriteSinPulseAnimation>
			<SpriteSinPulseAnimation name="eyes_stretch2" sprite="s_FaceGlow" autoPlay="true">
				<Parameter name="scale.y">
					<Set name="offset">1</Set>
					<Set name="period">2750</Set>
					<Set name="scale">0.07</Set>
				</Parameter>
			</SpriteSinPulseAnimation>
        </Animations>

    <ParticleSystems>
        <ParticleSystem name="double_jump_particle">
				<Emitter>
          			<Set name="offset">0,-16</Set>
					<Set name="lifeTime">1.5</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="infParticles">true</Set>
          			<Set name="infLifeTime">true</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">double_jump_particle_Sprite</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="isBackgroundParticle">true</Set>
					<Set name="initalRGB">1, 1, 1</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="rotateWithVelocity">false</Set>
          			<Set name="interpolateScale">true</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="lifeTime">1.5</Set>
					<Set name="initialScale">1,1</Set>
          			<Set name="finalScale">1.8, 1.8</Set>
          			<Set name="initialVelocity">0.1,0.1</Set>
					<Random name="initialAngle" min="0" max="180"/>
				</Particle>
			</ParticleSystem>

        		<ParticleSystem name="ps_Aura" updateStage="AddClothingParticles">
			<Emitter>
				<Set name="offset">0, -15</Set>
				<Set name="offsetFacing">true</Set>
				<Set name="emissionInterval">1.5</Set>
				<Set name="infParticles">true</Set>
				<Set name="infLifeTime">true</Set>
				<Set name="particlesPerEmission">1</Set>
			</Emitter>
			<Particle randomSpriteFrame="true">
				<Set name="sprite">s_Aura</Set>
				<Set name="relativeToEmitter">true</Set>
				<Set name="inSpecificOrder">true</Set>
				<Set name="blendingMode">ADDITIVE</Set>
				<Set name="interpolateAlpha">true</Set>
				<Curve name="initialAlpha">
					<KeyFrame>0, 0</KeyFrame>
					<KeyFrame>0.5, 1</KeyFrame>
					<KeyFrame>1, 0</KeyFrame>
				</Curve>
				<Curve name="initialScale">
					<KeyFrame>0, 0.7, 0.7</KeyFrame>
					<KeyFrame>1, 1.8, 1.8</KeyFrame>
				</Curve>
                <Random name="initialAngle" min="0" max="360"/>
				<Set name="lifeTime">4</Set>
			</Particle>
		</ParticleSystem>

			<ParticleSystem name="PunchSpawner">
				<Emitter>
					<Set name="offset">0,0</Set>
					<Set name="lifeTime">0.3</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">double_jump_particle_Sprite</Set>
					<Select name="offset" input="punchCount">
						<Item>0, -65</Item>
						<Item>25, -50</Item>
						<Item>40, -15</Item>
						<Item>25, 10</Item>
						<Item>0, 25</Item>
						<Item>-25, 10</Item>
						<Item>-40, -15</Item>
						<Item>-25, -50</Item>
					</Select>
					<Curve name="initialScale">
						<KeyFrame>0, 0.2,0.2</KeyFrame>
						<KeyFrame>1, 0.2,0.2</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.15, 0.85</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">1.5</Set>
					<Random name="initialAngle" min="0" max="180"/>
					<Random name="initialRotationRate" min="-180" max="180"/>
					<Random name="finalRotationRate" min="-1800" max="1800"/>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="Punch_ps">
				<Emitter attachment="targetPos">
					<Set name="offset">0,0</Set>
					<Set name="lifeTime">0.3</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_fire</Set>
					<Set name="targetPos" source="context.pos"/>
					<Select name="targetPosOffset" input="punchCount">
						<Item>0, -65</Item>
						<Item>25, -50</Item>
						<Item>40, -15</Item>
						<Item>25, 10</Item>
						<Item>0, 25</Item>
						<Item>-25, 10</Item>
						<Item>-40, -15</Item>
						<Item>-25, -50</Item>
					</Select>
					<Curve name="initialScale">
						<KeyFrame>0, 0.8,0.8</KeyFrame>
						<KeyFrame>0.5, 0.6,0.6</KeyFrame>
						<KeyFrame>1, 0.2,0.2</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.75, 0.85</KeyFrame>
						<KeyFrame>1, 0.1</KeyFrame>
					</Curve>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="lifeTime">0.3</Set>
					<VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="1" angle="initialAngle"/>
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" offset="targetPosOffset" x="1" angle="finalAngle" />
				</Particle>
			</ParticleSystem>
	</ParticleSystems>

    <RenderOptions>
        <Default>
        <Set name="UserNameOffset">8</Set>
        <Set name="ShouldHover">true</Set>
        </Default>
    </RenderOptions>

    </Data>
    <RenderRules>
        <RenderBackpack>
			<ParticleSystemRender name="ps_Aura"/>
        </RenderBackpack>

    <RenderInFront>
		<SpriteRender name="s_FaceGlow" offset="0,-17" blend="PREMULTIPLIED_ALPHA" drawShadow="false" alignment="CENTER"/>
		<Group>
			<Translate forceValue="false">6,-55,0</Translate>
            <Rotate>crown.rotate</Rotate>
	        <SpriteRender name="s_Crown" blend="NORMAL" alignment="UPPER_CENTER" drawShadow="true" />
        </Group>
	</RenderInFront>

		<OnPunchStart>
			<ParticleSystemUpdate name="PunchSpawner"/>
			<ParticleSystemUpdate name="Punch_ps"/>
		</OnPunchStart>

    <AddClothingParticles>
		<ParticleSystemUpdate name="ps_Aura"/>
        <ParticleSystemUpdate name="double_jump_particle" onAction="JUMPDOUBLE" drawShadow="false"/>
	</AddClothingParticles>

    <SwitchOffClothingParticles>
		<ParticleSystemOff name="double_jump_particle"/>
    </SwitchOffClothingParticles>
		<OnPunchUpdate>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
		</OnPunchUpdate>
    <Update>
    	<AvatarTransform class="FootPosition">
			<Set name="foot1dy">0</Set>
			<Set name="foot2dy">0</Set>
			<Set name="foot1y">0</Set>
			<Set name="foot2y">0</Set>
		</AvatarTransform>
		<AvatarTransform class="Emotion">
			<Set name="emotion">EMOTION_COUNT</Set>
		</AvatarTransform>
	</Update>

	<OnDrawCustomOutline>
      	<AvatarTransform class="Scale">
        	<Set name="targetScale">1.1,1.1</Set>
      	</AvatarTransform>
    </OnDrawCustomOutline>

    </RenderRules>
</ItemRenderer>
