<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="mario_idle" fileName="game/m_ultraM_idle.rttex" textureSize="310,488"/>
		<Sprite name="mario_poses" fileName="game/m_ultraM_poses.rttex" textureSize="512,469"/>
		<Sprite name="mario_appear" fileName="game/m_ultraM_appear.rttex" textureSize="300,507"/>
		<StateMachines>
			<StateMachine name="Motion">
				<States>
				<State name="Appear" />
				<State name="Idle" />
				<State name="Move" />
				<State name="Jump" />
				<State name="Fall" />
				<State name="Punch"/>
				<State name="Dance"/>
				<State name="dance1"/>
				<State name="dance2"/>
				<State name="dance3"/>
				<State name="dance4"/>
			</States>
			<Transitions>
				<Transition to="Idle" from="Fall|Move|Jump|Punch|Appear" >
					<Condition type="and">
						<IsAnimationFinished>ok1</IsAnimationFinished>
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						<IsAction operator="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Move" from="Jump|Fall|Idle|Punch|Dance|dance1|dance2|dance3|dance4|Appear" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
						<IsAction operatorType="NotEqual">DANCE</IsAction>
						<IsAction operatorType="NotEqual">DANCE_DAB</IsAction>
						<IsAction operatorType="NotEqual">DANCE_FLOSS</IsAction>
						<IsAction operatorType="NotEqual">DANCE_MARCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Jump" from="Idle|Move|Fall|Punch|Dance|dance1|dance2|dance3|dance4|Appear" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
						<IsAction operatorType="NotEqual">DANCE</IsAction>
						<IsAction operatorType="NotEqual">DANCE_DAB</IsAction>
						<IsAction operatorType="NotEqual">DANCE_FLOSS</IsAction>
						<IsAction operatorType="NotEqual">DANCE_MARCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Fall" from="Jump|Idle|Move|Punch|Dance|dance1|dance2|dance3|dance4|Appear" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
						<IsAction operatorType="NotEqual">DANCE</IsAction>
						<IsAction operatorType="NotEqual">DANCE_DAB</IsAction>
						<IsAction operatorType="NotEqual">DANCE_FLOSS</IsAction>
						<IsAction operatorType="NotEqual">DANCE_MARCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Punch" from="Idle|Move|Jump|Fall|Dance|dance1|dance2|dance3|dance4|Appear">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsAction operatorType="NotEqual">DANCE</IsAction>
						<IsAction operatorType="NotEqual">DANCE_DAB</IsAction>
						<IsAction operatorType="NotEqual">DANCE_FLOSS</IsAction>
						<IsAction operatorType="NotEqual">DANCE_MARCH</IsAction>
					</Condition>
				</Transition>
				<Transition from="Move|Idle|Punch|Jump|Fall|Appear" to="Dance">
					<Condition>
						<IsAction>DANCE</IsAction>
						<IsAction>DANCE_DAB</IsAction>
						<IsAction>DANCE_FLOSS</IsAction>
						<IsAction>DANCE_MARCH</IsAction>
					</Condition>
				</Transition>
				
				<Transition to="dance1" from="Dance|dance4">
					<Condition>
						<IsAnimationFinished>dance_anim4</IsAnimationFinished>
					</Condition>
				</Transition>
				<Transition to="dance2" from="dance1">
					<Condition>
						<IsAnimationFinished>dance_anim1</IsAnimationFinished>
					</Condition>
				</Transition>
				<Transition to="dance3" from="dance2">
					<Condition>
						<IsAnimationFinished>dance_anim2</IsAnimationFinished>
					</Condition>
				</Transition>
				<Transition to="dance4" from="dance3">
					<Condition>
						<IsAnimationFinished>dance_anim3</IsAnimationFinished>
					</Condition>
				</Transition>
				
			</Transitions>
			</StateMachine>
		</StateMachines>
		<Animations>
			<SpriteAnimation name="ok1" playOnState="Motion.Appear" autoPlay="true" sprite="mario_appear" animTime="500">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="dance_anim1" playOnState="Motion.dance1" sprite="mario_poses" animTime="300">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="dance_anim2" playOnState="Motion.dance2" sprite="mario_poses" animTime="300">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="dance_anim3" playOnState="Motion.dance3" sprite="mario_poses" animTime="300">
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
				<Frame>3,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="dance_anim4" playOnState="Motion.dance4" sprite="mario_poses" animTime="300">
				<Frame>0,3</Frame>
				<Frame>1,3</Frame>
				<Frame>2,3</Frame>
				<Frame>3,3</Frame>
			</SpriteAnimation>
			
			<SpriteAnimation name="mario_Idle_Animation" playOnState="Motion.Idle" sprite="mario_idle" animTime="550" isLoop="true">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				<Frame>4,0</Frame>
				<Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="mario_Punch_Animation" playOnState="Motion.Punch" sprite="mario_poses" animTime="300" isLoop="true">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="mario_Jump_Animation" playOnState="Motion.Jump" sprite="mario_poses" animTime="300">
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
				<Frame>3,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="mario_Fall_Animation" playOnState="Motion.Fall" sprite="mario_poses" animTime="300">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="mario_Walk_Animation" playOnState="Motion.Move" sprite="mario_poses" animTime="300" >
				<Frame>0,3</Frame>
				<Frame>1,3</Frame>
				<Frame>2,3</Frame>
				<Frame>3,3</Frame>
			</SpriteAnimation>
		</Animations>
		<TileStampData>
            <Set name="FileName">game/particles9.rttex</Set>
            <Set name="EndFrame">28,17</Set>
            <Set name="FrameCount">4</Set>
        </TileStampData>
		<ParticleSystems>
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10</Set>
				<Set name="UserNameOffset">75</Set>
				<Set name="IncludeAllActions">true</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
			</Default>
			<Override overrideOnState="Motion.dance1|Motion.dance2|Motion.dance3|Motion.dance4">
                <Set name="UserNameOffset">95</Set>
            </Override>
		</RenderOptions>
	</Data>
	<RenderRules>
		<Update>
			<AvatarTransform class="FootPosition" onState="Motion.Dance|Motion.dance1|Motion.dance2|Motion.dance3">
                <Set name="foot1dy">0</Set>
                <Set name="foot2dy">0</Set>
                <Set name="foot1y">0</Set>
                <Set name="foot2y">0</Set>
            </AvatarTransform>
			<AvatarTransform class="ActionUpdate" onState="Motion.Dance|Motion.dance1|Motion.dance2|Motion.dance3|Motion.dance4">
                <Set name="action">NOD</Set>
            </AvatarTransform>
		</Update>
		<RenderTransform>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<AvatarSilhouetteRender color="255,255,255,100" offset="0,-35" emissionInterval="0.13" onState="Motion.Move|Motion.Jump|Motion.Fall"/>
			<SpriteRender name="mario_idle" offset="0,-35" drawShadow="true" onState="Motion.Idle" scale="0.27,0.27"/>
			<SpriteRender name="mario_appear" offset="0,-45" drawShadow="true" onState="Motion.Appear" scale="0.34,0.34"/>
			<SpriteRender name="mario_poses" offset="0,-45" drawShadow="true" onState="Motion.Punch|Motion.Move|Motion.Fall|Motion.Dance|Motion.dance1|Motion.dance2|Motion.dance4" scale="0.34,0.34"/>
			<SpriteRender name="mario_poses" offset="0,-35" drawShadow="true" onState="Motion.Jump|Motion.dance3" scale="0.34,0.34"/>
			
			<MusicSource onState="Motion.Dance|Motion.dance1|Motion.dance2|Motion.dance3|Motion.dance4">
                <Set name="MusicFile">audio/mp3/m_ultraM_music.mp3</Set>
            </MusicSource>
			<MusicSource onState="Motion.Appear">
                <Set name="MusicFile">audio/m_ultraM_appear.wav</Set>
            </MusicSource>
		</RenderTransform>
		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
	</RenderRules>
</ItemRenderer>