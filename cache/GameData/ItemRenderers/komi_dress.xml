<?xml version="1.0"?>
<ItemRenderer>
	<Data>
    <StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
    </StateMachines>

		<Sprite name="s_Dress" fileName="game/custom_tiles_page2.rttex" textureSize="32" frame="7,11" />
		<Sprite name="s_Particles" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>
		<Sprite name="s_OrbitParticles" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>
		<Sprite name="s_OrbitParticlesTrail" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="4,12"/>
		<Sprite name="s_AllParticles" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>

        <Animations>
            <SpriteAnimation name="A_Dress" autoPlay="true" sprite="s_Dress" animTime="400" isLoop="true">
        	    <Frame>7,11</Frame>
		        <Frame>8,11</Frame>
            </SpriteAnimation>

		    <SpriteAnimation name="A_Particles" sprite="s_Particles">
                <Frame>2,12</Frame>
                <Frame>3,12</Frame>
		    </SpriteAnimation>

		    <SpriteAnimation name="A_ParticlesTrail" sprite="s_OrbitParticlesTrail">
                <Frame>4,12</Frame>
		    </SpriteAnimation>

            <SpriteAnimation name="A_OrbitParticles" autoPlay="true" sprite="s_OrbitParticles" animTime="200" isLoop="true">
        	    <Frame>0,12</Frame>
		        <Frame>1,12</Frame>
            </SpriteAnimation>

		    <SpriteAnimation name="A_AllParticles" sprite="s_AllParticles">
                <Frame>0,12</Frame>
                <Frame>1,12</Frame>
                <Frame>2,12</Frame>
                <Frame>3,12</Frame>
                <Frame>4,12</Frame>
		    </SpriteAnimation>
        </Animations>

		<ParticleSystems>
    		<ParticleSystem name="Ps_IdleParticles">
	    		<Emitter>
		    		<Random name="offset" min="-9, 10" max="9, -15"/>
			    	<Random name="emissionInterval" min="0.1" max="0.5"/>
				    <Set name="infParticles">true</Set>
				    <Set name="infLifeTime">true</Set>
				    <Set name="particlesPerEmission">1</Set>
    			</Emitter>
	    		<Particle randomSpriteFrame="true">
		    		<Set name="sprite">s_Particles</Set>
			    	<Set name="blendingMode">ADDITIVE</Set>
				    <Set name="isBackgroundParticle">false</Set>
				    <Set name="initalRGB">1, 1, 1</Set>
                    <Random name="lifeTime" min="1" max="1.5" />
				    <Random name="initialVelocity" min="-5, 10" max="5, 25"/>
				    <Set name="initialAngle">0</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.2,0.2</KeyFrame>
						<KeyFrame>0.05, 1,1</KeyFrame>
						<KeyFrame>0.1, 0.2,0.2</KeyFrame>
						<KeyFrame>0.15, 1,1</KeyFrame>
						<KeyFrame>0.2, 0.2,0.2</KeyFrame>
						<KeyFrame>0.25, 1,1</KeyFrame>
						<KeyFrame>0.3, 0.2,0.2</KeyFrame>
						<KeyFrame>0.35, 1,1</KeyFrame>
						<KeyFrame>0.4, 0.2,0.2</KeyFrame>
						<KeyFrame>0.45, 1,1</KeyFrame>
						<KeyFrame>0.5, 0.2,0.2</KeyFrame>
						<KeyFrame>0.55, 1,1</KeyFrame>
						<KeyFrame>0.6, 0.2,0.2</KeyFrame>
						<KeyFrame>0.65, 1,1</KeyFrame>
						<KeyFrame>0.7, 0.2,0.2</KeyFrame>
						<KeyFrame>0.75, 0.75,0.75</KeyFrame>
						<KeyFrame>0.8, 0.15,0.15</KeyFrame>
						<KeyFrame>0.85, 0.5,0.5</KeyFrame>
						<KeyFrame>0.9, 0.1,0.1</KeyFrame>
						<KeyFrame>0.95, 0.25,0.25</KeyFrame>
						<KeyFrame>1, 0.05,0.05</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.95, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Select name="initialRotationRate" input="randomNumber">
						<Item>-720</Item>
						<Item>-360</Item>
						<Item>360</Item>
						<Item>720</Item>
					</Select>                    
			    </Particle>
		    </ParticleSystem>
		    <ParticleSystem name="Ps_WalkParticles">
			    <Emitter>
                    <Set name="useCharacterPos">true</Set>
                    <Random name="offset" min="8,0" max="-8,-15"/>
				    <Random name="emissionInterval" min="0.02" max="0.025"/>
				    <Set name="infParticles">true</Set>
				    <Set name="infLifeTime">true</Set>
				    <Set name="particlesPerEmission">1</Set>
			    </Emitter>
			    <Particle randomSpriteFrame="true">
				    <Set name="sprite">s_Particles</Set>
				    <Set name="blendingMode">ADDITIVE</Set>
				    <Set name="isBackgroundParticle">false</Set>
				    <Set name="initalRGB">1, 1, 1</Set>
					    <Curve name="initialAlpha">
						    <KeyFrame>0, 1</KeyFrame>
                            <KeyFrame>0.75, 1</KeyFrame>
						    <KeyFrame>1, 0</KeyFrame>
					    </Curve>
					    <Curve name="initialScale">
					    	<KeyFrame>0, 0.2,0.2</KeyFrame>
						    <KeyFrame>0.05, 1,1</KeyFrame>
					    	<KeyFrame>0.1, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.15, 1,1</KeyFrame>
					    	<KeyFrame>0.2, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.25, 1,1</KeyFrame>
					    	<KeyFrame>0.3, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.35, 1,1</KeyFrame>
					    	<KeyFrame>0.4, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.45, 1,1</KeyFrame>
					    	<KeyFrame>0.5, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.55, 1,1</KeyFrame>
					    	<KeyFrame>0.6, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.65, 1,1</KeyFrame>
					    	<KeyFrame>0.7, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.75, 0.75,0.75</KeyFrame>
					    	<KeyFrame>0.8, 0.15,0.15</KeyFrame>
					    	<KeyFrame>0.85, 0.5,0.5</KeyFrame>
					    	<KeyFrame>0.9, 0.1,0.1</KeyFrame>
					    	<KeyFrame>0.95, 0.25,0.25</KeyFrame>
					    	<KeyFrame>1, 0.05,0.05</KeyFrame>
					    </Curve>
				    <Random name="lifeTime" min="0.85" max="1.35"/>
				    <Random name="initialVelocity" min="0, 3" max="0, 5"/>
					    <Select name="initialRotationRate" input="randomNumber">
					    	<Item>-720</Item>
					    	<Item>-360</Item>
					    	<Item>360</Item>
					    	<Item>720</Item>
					    </Select> 
			    </Particle>
		    </ParticleSystem>

			<ParticleSystem name="ps_swirl">
				<Emitter>
					<Set name="offset">0, -16</Set>
					<Set name="emissionInterval">0.5</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>

                    <OrbitOffset>
                        <Set name="hasOrbit">true</Set>
                        <Set name="hAmplitude">20</Set>
                        <Set name="hOrbitPeriod">6000</Set>
                        <Set name="hTimeOffset">0</Set>
                        <Set name="vAmplitude">12</Set>
                        <Set name="vOrbitPeriod">4000</Set>
                        <Set name="vTimeOffset">0</Set>
                        <Set name="minScale">0.5</Set>
                        <Set name="maxScale">0.9</Set>
                    </OrbitOffset>
				</Emitter>
				<Particle>
					<Set name="sprite">s_OrbitParticles</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="inSpecificOrder">false</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialScale">1.2, 1.2</Set>
					<Set name="lifeTime">0.5</Set>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="ps_swirl2">
				<Emitter>
					<Set name="offset">0, -16</Set>
					<Set name="emissionInterval">0.5</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>

                    <OrbitOffset>
                        <Set name="hasOrbit">true</Set>
                        <Set name="hAmplitude">20</Set>
                        <Set name="hOrbitPeriod">-6000</Set>
                        <Set name="hTimeOffset">500</Set>
                        <Set name="vAmplitude">12</Set>
                        <Set name="vOrbitPeriod">4000</Set>
                        <Set name="vTimeOffset">1500</Set>
                        <Set name="minScale">0.5</Set>
                        <Set name="maxScale">0.9</Set>
                    </OrbitOffset>
				</Emitter>
				<Particle>
					<Set name="sprite">s_OrbitParticles</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="inSpecificOrder">false</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialScale">1.2, 1.2</Set>
					<Set name="lifeTime">0.5</Set>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="ps_skin_stars_blue">
				<Emitter>
					<Set name="offset">0, -16</Set>
					<Set name="emissionInterval">0.025</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>

                    <OrbitOffset>
                        <Set name="hasOrbit">true</Set>
                        <Set name="hAmplitude">20</Set>
                        <Set name="hOrbitPeriod">6000</Set>
                        <Set name="hTimeOffset">0</Set>
                        <Set name="vAmplitude">12</Set>
                        <Set name="vOrbitPeriod">4000</Set>
                        <Set name="vTimeOffset">0</Set>
                        <Set name="minScale">0.5</Set>
                        <Set name="maxScale">0.9</Set>
                    </OrbitOffset>
				</Emitter>
				<Particle>
					<Set name="sprite">s_OrbitParticlesTrail</Set>
					<Set name="inSpecificOrder">false</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.75</KeyFrame>
						<KeyFrame>0.2, 0.1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="lifeTime">1</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_skin_stars_blue2">
				<Emitter>
					<Set name="offset">0, -16</Set>
					<Set name="emissionInterval">0.025</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>

                    <OrbitOffset>
                        <Set name="hasOrbit">true</Set>
                        <Set name="hAmplitude">20</Set>
                        <Set name="hOrbitPeriod">-6000</Set>
                        <Set name="hTimeOffset">500</Set>
                        <Set name="vAmplitude">12</Set>
                        <Set name="vOrbitPeriod">4000</Set>
                        <Set name="vTimeOffset">1500</Set>
                        <Set name="minScale">0.5</Set>
                        <Set name="maxScale">0.9</Set>
                    </OrbitOffset>
				</Emitter>
				<Particle>
					<Set name="sprite">s_OrbitParticlesTrail</Set>
					<Set name="inSpecificOrder">false</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.75</KeyFrame>
						<KeyFrame>0.2, 0.1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="lifeTime">1</Set>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="ps_PunchParticles">
				<Emitter attachment="targetPos">
					<Random name="offset" min="-11,11" max="11,-11"/>
					<Set name="lifeTime">0</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">8</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_AllParticles</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">1.15</Set>
				        <Curve name="initialAlpha">
					        <KeyFrame>0, 1</KeyFrame>
					        <KeyFrame>0.75, 0.75</KeyFrame>
					        <KeyFrame>1, 0</KeyFrame>
				        </Curve>
					    <Curve name="initialScale">
					    	<KeyFrame>0, 0.2,0.2</KeyFrame>
						    <KeyFrame>0.05, 1,1</KeyFrame>
					    	<KeyFrame>0.1, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.15, 1,1</KeyFrame>
					    	<KeyFrame>0.2, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.25, 1,1</KeyFrame>
					    	<KeyFrame>0.3, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.35, 1,1</KeyFrame>
					    	<KeyFrame>0.4, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.45, 1,1</KeyFrame>
					    	<KeyFrame>0.5, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.55, 1,1</KeyFrame>
					    	<KeyFrame>0.6, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.65, 1,1</KeyFrame>
					    	<KeyFrame>0.7, 0.2,0.2</KeyFrame>
					    	<KeyFrame>0.75, 0.75,0.75</KeyFrame>
					    	<KeyFrame>0.8, 0.15,0.15</KeyFrame>
					    	<KeyFrame>0.85, 0.5,0.5</KeyFrame>
					    	<KeyFrame>0.9, 0.1,0.1</KeyFrame>
					    	<KeyFrame>0.95, 0.25,0.25</KeyFrame>
					    	<KeyFrame>1, 0.05,0.05</KeyFrame>
					    </Curve>
                    <Set name="initialRotationRate">360</Set>
                    <Set name="initialVelocity">0,-20</Set>
                    <Set name="useGravity">true</Set>
                    <Random name="gravityVector" min="0,-35" max="0,-85"/>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
	</Data>

	<RenderRules>
		<RenderShirt>
			<SpriteRender name="s_Dress" offset="0,-14" blend="PREMULTIPLIED_ALPHA" />
		</RenderShirt>

		<RenderInFront>
			<ParticleSystemRender name="ps_skin_stars_blue"/>
			<ParticleSystemRender name="ps_skin_stars_blue2"/>
			<ParticleSystemRender name="ps_swirl"/>
			<ParticleSystemRender name="ps_swirl2"/>
		</RenderInFront>

		<OnPunchUpdate>
            <AvatarTransform class="Emotion">
                <Set name="emotion">SHY</Set>
            </AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
            <AvatarTransform class="ArmAngle">
				<Set name="armName">arm1Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
			<ParticleSystemUpdate name="ps_PunchParticles" />
		</OnPunchUpdate>

        <AddClothingParticles>
        	<ParticleSystemUpdate name="Ps_IdleParticles" onState="playerState.Idle|playerState.SpiritGuide"/>
			<ParticleSystemUpdate name="Ps_WalkParticles" onState="playerState.Move|playerState.Jump|playerState.Fall"/>
			<ParticleSystemUpdate name="ps_skin_stars_blue"/>
			<ParticleSystemUpdate name="ps_skin_stars_blue2"/>
			<ParticleSystemUpdate name="ps_swirl"/>
			<ParticleSystemUpdate name="ps_swirl2"/>
		</AddClothingParticles>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="Ps_IdleParticles"/>
			<ParticleSystemOff name="Ps_WalkParticles"/>
			<ParticleSystemOff name="ps_skin_stars_blue"/>
			<ParticleSystemOff name="ps_skin_stars_blue2"/>
			<ParticleSystemOff name="ps_swirl"/>
			<ParticleSystemOff name="ps_swirl2"/>
            <ParticleSystemOff name="ps_PunchParticles"/>
		</SwitchOffClothingParticles>

	</RenderRules>
</ItemRenderer>
