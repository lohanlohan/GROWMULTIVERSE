<?xml version="1.0"?>
<ItemRenderer>
	<Data>
    <StateMachines>
      <StateMachine name="Motion">
        <States>
          <State name="Idle" />
          <State name="Move" />
          <State name="Punch" />
        </States>
        <Transitions>
          <Transition to="Idle" from="Move|Punch">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Move" from="Idle|Punch">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Punch" from="Idle|Move">
            <Condition>
              <IsAction>PUNCH</IsAction>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
    </StateMachines>

    	  <Sprite name="s_Pet" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="0,14"/>
        <Sprite name="sword" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="15,2" />
        <Sprite name="s_Pet_wing_front" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="4,14" />
        <Sprite name="s_Pet_wing_back" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="8,14" />
        <Sprite name="s_FirePunch" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="8,14"/>
        <Sprite name="s_Breath" fileName="game/enigma_particles5.rttex" textureSize="64"/>

    <Animations>
			<SpriteAnimation name="a_dragon_idle" sprite="s_Pet" animTime="725" isLoop="true" autoPlay="true">
				<Frame>0,14</Frame>
				<Frame>1,14</Frame>
				<Frame>2,14</Frame>
			</SpriteAnimation>

      <SpriteAnimation name="a_dragon_punch" sprite="s_Pet" animTime="725" isLoop="true" playOnState="Motion.Punch">
				<Frame>3,14</Frame>
			</SpriteAnimation>

      <SpriteAnimation name="a_dragon_wing_front" sprite="s_Pet_wing_front" animTime="1350" isLoop="true" autoPlay="true" >
		    <Frame>4,14</Frame>
		    <Frame>5,14</Frame>
		    <Frame>6,14</Frame>
        <Frame>7,14</Frame>
        <Frame>6,14</Frame>
        <Frame>5,14</Frame>
		</SpriteAnimation>

      <SpriteAnimation name="a_dragon_wing_back" sprite="s_Pet_wing_back" animTime="1350" isLoop="true" autoPlay="true" >
      	<Frame>8,14</Frame>
		    <Frame>9,14</Frame>
		    <Frame>10,14</Frame>
        <Frame>11,14</Frame>
        <Frame>10,14</Frame>
        <Frame>9,14</Frame>
		</SpriteAnimation>

      <SpriteAnimation name="a_breathsprites" sprite="s_Breath">
		    <Frame>9,15</Frame>
		    <Frame>10,15</Frame>
      	<Frame>11,15</Frame>
		</SpriteAnimation>
    </Animations>

    <VariableMap>
		<Set name="projectile_offset">0, 0</Set>
		<Set name="projectile_angle">0</Set>
	</VariableMap>

	<ParticleSystems>
      <ParticleSystem name="ps_punchProjectile" updateStage="RenderPet" updateState="Motion.Punch">
        <Emitter usePlayerFacing="true">
          <Random name="emissionInterval" min="0.002" max="0.004"/>
          <Set name="infParticles">true</Set>
          <Set name="lifeTime">0.15</Set>
          <Set name="particlesPerEmission">3</Set>
		      <Set name="offset">52,-45</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_FirePunch</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.15</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 1</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 0.7,0.7</KeyFrame>
            <KeyFrame>1, 1.25,1.25</KeyFrame>
          </Curve>
          <Random name="targetPosOffset" min="-3, -13" max="3, 13"/>
          <VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="1"/>
          <Set name="rotateWithVelocity">true</Set>
          <OnFinish>
            <ParticleSystemName>ps_punchSmoke</ParticleSystemName>
          </OnFinish>
        </Particle>
      </ParticleSystem>
      <ParticleSystem name="ps_punchSmoke">
        <Emitter>
          <Set name="emissionInterval">0.01</Set>
          <Set name="infParticles">true</Set>
          <Set name="lifeTime">0.5</Set>
          <Set name="particlesPerEmission">2</Set>
		      <Set name="delay">-0.25</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_FirePunch</Set>
          <Set name="renderAlignment">CENTER</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Random name="offset" min="-8, -8" max="8, 8" />
		      <Set name="initialAngle">180</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 0.6, 0.6</KeyFrame>
            <KeyFrame>1, 0.05, 0.05</KeyFrame>
          </Curve>
		  	<Set name="rotateWithVelocity">true</Set>
			<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="60,80"/>
          <Set name="lifeTime">0.5</Set>
        </Particle>
      </ParticleSystem>

      <ParticleSystem name="ps_Breath" updateStage="RenderPet" updateState="Motion.Idle">
        <Emitter>
          <Random name="emissionInterval" min="17" max="30"/>
          <Set name="infParticles">true</Set>
          <Set name="lifeTime">2.5</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="offset">64,-43</Set>
          <Set name="delayTimer">3</Set>
        </Emitter>
        <Particle randomSpriteFrame="true">
          <Set name="relativeToEmitter">true</Set>
          <Set name="sprite">s_Breath</Set>
          <Set name="renderAlignment">CENTER</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
		      <Random name="initialAngle" min="0" max="180"/>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Curve name="initialScale">
            <KeyFrame>0, 0.1, 0.1</KeyFrame>
            <KeyFrame>1, 0.3, 0.3</KeyFrame>
          </Curve>
          <Set name="lifeTime">2.5</Set>
        </Particle>
      </ParticleSystem>
	</ParticleSystems>

        <RenderOptions>
			<Default>
				<Set name="NeedRenderPet">true</Set>
				<Set name="PetOffsetDuplication">0,0</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">false</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">false</Set>
				<Set name="HideParticlesOnTransform">false</Set>
        <Set name="PunchSoundOverride">HAND</Set>
			  <Set name="PlayDefaultPunchAudio">false</Set>
			</Default>
		</RenderOptions>
	</Data>

	  <RenderRules>
        <RenderHandItem>
			    <SpriteRender name="sword" rotateOffset="true" offset="16,40" alignment="DOWN_CENTER" blend="PREMULTIPLIED_ALPHA"/>
        </RenderHandItem>

		<RenderPet>
      <SpriteRender name="s_Pet_wing_back" alignment="DOWN_CENTER" offset="23,14"/>
			<SpriteRender name="s_Pet" alignment="DOWN_CENTER" offset="0,15"/>
      <SpriteRender name="s_Pet_wing_front" alignment="DOWN_CENTER" offset="-4,14"/>
		</RenderPet>

		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
        <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
		</OnPunchUpdate>

  	<OnDrawCustomOutline>
      <AvatarTransform class="Scale">
        <Set name="targetScale">1.1,1.1</Set>
      </AvatarTransform>
    </OnDrawCustomOutline>
	</RenderRules>
</ItemRenderer>