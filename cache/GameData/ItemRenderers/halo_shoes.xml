<?xml version="1.0"?>
<ItemRenderer>
  <Data>
<StateMachines>
      <StateMachine name="Motion">
        <States>
          <State name="Idle" />
          <State name="Move" />
        </States>
        <Transitions>
          <Transition to="Idle" from="Move">
            <Condition type="or">
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsVariableBool name="onGround">false</IsVariableBool>
            </Condition>
          </Transition>
          <Transition to="Move" from="Idle">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
              <IsVariableBool name="onGround">true</IsVariableBool>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
      <StateMachine name="IsDying">
        <States>
          <State name="False" />
          <State name="True" />
        </States>
        <Transitions>
          <Transition from="False" to="True">
            <Condition>
              <IsAction>DIE</IsAction>
            </Condition>
          </Transition>
          <Transition from="True" to="False">
            <Condition>
              <IsAction operatorType="NotEqual">DIE</IsAction>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
    </StateMachines>

    <Sprite name="s_foot1" fileName="game/custom_feet2.rttex" textureSize="32" frame="3,0" />
    <Sprite name="s_foot2" fileName="game/custom_feet2.rttex" textureSize="32" frame="3,1" />
    <Sprite name="s_haloFront" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="0,1" />
    <Sprite name="s_haloBehind" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="1,1" />
    <Sprite name="s_HaloGlowFront" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="2,1"/>
    <Sprite name="s_HaloGlowBehind" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="3,1"/>
    <Sprite name="dirtSprite1" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="13,14"/>
    <Sprite name="dirtSprite2" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="13,14"/>
    <Sprite name="dirtSprite3" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="13,14"/>
    <Sprite name="s_GodlyRays" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="14,13"/>
    <Sprite name="magic_sparks_up" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>


    <Animations>
    <SpriteSinPulseAnimation name="halo_frontfloat" sprite="s_haloFront" autoPlay="true">
		<Parameter name="pos.y">
			<Set name="period">1800</Set>
			<Set name="scale">1</Set>
		</Parameter>
	</SpriteSinPulseAnimation>

    <SpriteSinPulseAnimation name="halo_behindfloat" sprite="s_haloBehind" autoPlay="true">
		<Parameter name="pos.y">
			<Set name="period">1800</Set>
			<Set name="scale">1</Set>
		</Parameter>
	</SpriteSinPulseAnimation>

    <SpriteSinPulseAnimation name="halo_frontglowfloat" sprite="s_haloFront" autoPlay="true">
		<Parameter name="pos.y">
			<Set name="period">1800</Set>
			<Set name="scale">1</Set>
		</Parameter>
	</SpriteSinPulseAnimation>

    <SpriteSinPulseAnimation name="halo_behindglowfloat" sprite="s_haloBehind" autoPlay="true">
		<Parameter name="pos.y">
			<Set name="period">1800</Set>
			<Set name="scale">1</Set>
		</Parameter>
	</SpriteSinPulseAnimation>

    <SpriteAnimation name="dirt1" sprite="dirtSprite1" animTime="500">
        <Frame>13,14</Frame>
        <Frame>15,14</Frame>
        <Frame>14,14</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="dirt2" sprite="dirtSprite2" animTime="525">
        <Frame>13,14</Frame>
        <Frame>14,14</Frame>
        <Frame>15,14</Frame>
      </SpriteAnimation>
      <SpriteAnimation name="dirt3" sprite="dirtSprite3" animTime="550">
        <Frame>15,14</Frame>
        <Frame>14,14</Frame>
        <Frame>13,14</Frame>
      </SpriteAnimation>

        <SpriteCurveAnimation name="A_GlowFront" sprite="s_HaloGlowFront" autoPlay="true" isLoop="true" animTime="1500">
			    <Curve name="alpha">
				    <KeyFrame>0.f, 0.f</KeyFrame>
				    <KeyFrame>0.25f, 1.f </KeyFrame>
				    <KeyFrame>0.5f, 0.f</KeyFrame>
				    <KeyFrame>0.75f, 1.f</KeyFrame>
				    <KeyFrame>1.f, 0.f</KeyFrame>
			    </Curve>
		    </SpriteCurveAnimation>

            <SpriteCurveAnimation name="A_GlowBehind" sprite="s_HaloGlowBehind" autoPlay="true" isLoop="true" animTime="1500">
			    <Curve name="alpha">
				    <KeyFrame>0.f, 0.f</KeyFrame>
				    <KeyFrame>0.25f, 1.f </KeyFrame>
				    <KeyFrame>0.5f, 0.f</KeyFrame>
				    <KeyFrame>0.75f, 1.f</KeyFrame>
				    <KeyFrame>1.f, 0.f</KeyFrame>
			    </Curve>
		    </SpriteCurveAnimation>

        <SpriteAnimation name="punch_particle_Sprites" autoPlay="false" sprite="magic_sparks_up">
       		    <Frame>13,13</Frame>
			        <Frame>15,13</Frame>
    	    </SpriteAnimation>
    </Animations>

    <ParticleSystems>
      <ParticleSystem name="dirtOrbit1" updateStage="AddClothingParticles">
        <Emitter>
          <Set name="offset">0, -10</Set>
          <Set name="emissionInterval">0.4</Set>
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="particlesPerEmission">1</Set>
          <OrbitOffset>
            <Set name="maxScale">0.5</Set>
            <Set name="hasOrbit">true</Set>
            <Set name="hOrbitPeriod">-3000</Set>
            <Set name="hAmplitude">20</Set>
            <Set name="hTimeOffset">0</Set>
            <Set name="vAmplitude">4</Set>
            <Set name="vOrbitPeriod">3000</Set>
            <Set name="vTimeOffset">0</Set>
            <Set name="minScale">0.1</Set>
          </OrbitOffset>
        </Emitter>
        <Particle>
          <Set name="sprite">dirtSprite1</Set>
          <Set name="relativeToEmitter">true</Set>
          <Set name="inSpecificOrder">false</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.5</Set>
        </Particle>
      </ParticleSystem>
      <ParticleSystem name="dirtOrbit2" updateStage="AddClothingParticles">
        <Emitter>
          <Set name="offset">0, -20</Set>
          <Set name="emissionInterval">0.4</Set>
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="particlesPerEmission">1</Set>
          <OrbitOffset>
            <Set name="maxScale">0.5</Set>
            <Set name="hasOrbit">true</Set>
            <Set name="hOrbitPeriod">3250</Set>
            <Set name="hAmplitude">26</Set>
            <Set name="hTimeOffset">-500</Set>
            <Set name="vAmplitude">-3</Set>
            <Set name="vOrbitPeriod">-3250</Set>
            <Set name="vTimeOffset">-500</Set>
            <Set name="minScale">0.1</Set>
          </OrbitOffset>
        </Emitter>
        <Particle>
          <Set name="sprite">dirtSprite2</Set>
          <Set name="relativeToEmitter">true</Set>
          <Set name="inSpecificOrder">false</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.525</Set>
        </Particle>
      </ParticleSystem>
      <ParticleSystem name="dirtOrbit3" updateStage="AddClothingParticles">
        <Emitter>
          <Set name="offset">0, -16</Set>
          <Set name="emissionInterval">0.4</Set>
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="particlesPerEmission">1</Set>
          <OrbitOffset>
            <Set name="maxScale">0.5</Set>
            <Set name="hasOrbit">true</Set>
            <Set name="hOrbitPeriod">-3500</Set>
            <Set name="hAmplitude">30</Set>
            <Set name="hTimeOffset">-1000</Set>
            <Set name="vAmplitude">7</Set>
            <Set name="vOrbitPeriod">3500</Set>
            <Set name="vTimeOffset">-1000</Set>
            <Set name="minScale">0.1</Set>
          </OrbitOffset>
        </Emitter>
        <Particle>
          <Set name="sprite">dirtSprite3</Set>
          <Set name="relativeToEmitter">true</Set>
          <Set name="inSpecificOrder">false</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">0.550</Set>
        </Particle>
      </ParticleSystem>

      <ParticleSystem name="ps_GodlyRays" updateStage="AddClothingParticles">
				<Emitter>
				<Set name="offset">0, -16</Set>
				<Set name="offsetFacing">true</Set>
				<Set name="emissionInterval">1</Set>
				<Set name="infParticles">true</Set>
				<Set name="infLifeTime">true</Set>
				<Set name="particlesPerEmission">2</Set>
			</Emitter>
			<Particle randomSpriteFrame="true">
				<Set name="sprite">s_GodlyRays</Set>
				<Set name="relativeToEmitter">true</Set>
				<Set name="inSpecificOrder">true</Set>
				<Set name="blendingMode">ADDITIVE</Set>
				<Set name="interpolateAlpha">true</Set>
				<Curve name="initialAlpha">
					<KeyFrame>0, 0</KeyFrame>
					<KeyFrame>0.5, 1</KeyFrame>
					<KeyFrame>1, 0</KeyFrame>
				</Curve>
				<Curve name="initialScale">
					<KeyFrame>0, 0.1, 0.1</KeyFrame>
					<KeyFrame>1, 0.8, 0.8</KeyFrame>
				</Curve>
        <Random name="initialAngle" min="0" max="180"/>
				<Set name="lifeTime">2</Set>
			</Particle>
			</ParticleSystem>

      <ParticleSystem name="particle_trail_right">
				<Emitter>
					<Random name="offset" min="-20, -8" max="20, -10"/>
					<Set name="emissionInterval">0.15</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">4</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">magic_sparks_up</Set>
					<Random name="offset" min="-3, -10" max="6, 12" />
					<Set name="renderAlignment">CENTER</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.3, 1</KeyFrame>
						<KeyFrame>0.8, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.8</Set>
					<Random name="initialVelocity" min="0, -16" max="0, -30" />
					<Set name="initialRotationRate">360</Set>
          <Set name="useGravity">true</Set>
          <Set name="gravityVector">0,-75</Set>
				</Particle>
			</ParticleSystem>
  </ParticleSystems>
  
  <RenderOptions>
        <Default>
        <Set name="ClothingOffsetFromShoes">-6</Set>
        <Set name="UserNameOffset">8</Set>
        <Set name="ShouldHover">true</Set>
        </Default>
    </RenderOptions>
    </Data>

<RenderRules>
  <RenderShoes>
        <Group>
        <Translate>leftFootYPos</Translate>
        <SpriteRender name="s_foot1" alignment="DOWN_CENTER" />
      </Group>
      <Group>
        <Translate>rightFootYPos</Translate>
        <SpriteRender name="s_foot2" alignment="DOWN_CENTER" />
      </Group>
    </RenderShoes>

    <RenderBehind>
        <ParticleSystemRender name="ps_GodlyRays"/>
        <SpriteRender name="s_HaloGlowBehind" offset="0,52" alignment="DOWN_CENTER" blend="PREMULTIPLIED_ALPHA"/>
        <SpriteRender name="s_haloBehind" offset="0,52" alignment="DOWN_CENTER" blend="PREMULTIPLIED_ALPHA"/>
	</RenderBehind>

    <RenderInFront>
    <Group>
      <ParticleSystemRender name="dirtOrbit1"/>
      <ParticleSystemRender name="dirtOrbit2"/>
      <ParticleSystemRender name="dirtOrbit3"/>
      <ContextUpdate type="SetFlip">
        <Set name="flip">0,0</Set>
      </ContextUpdate>
    </Group>
      <SpriteRender name="s_HaloGlowFront" offset="0,28" alignment="DOWN_CENTER" blend="PREMULTIPLIED_ALPHA"/>
      <SpriteRender name="s_haloFront" offset="0,28" alignment="DOWN_CENTER" blend="PREMULTIPLIED_ALPHA"/>
    </RenderInFront>

    <Update>
		<AvatarTransform class="FootPosition">
			<Set name="foot1dy">0</Set>
			<Set name="foot2dy">0</Set>
			<Set name="foot1y">0</Set>
			<Set name="foot2y">0</Set>
		</AvatarTransform>
	</Update>

  <AddClothingParticles>
			<ParticleSystemUpdate name="particle_trail_right" />
	</AddClothingParticles>

  <OnDrawCustomOutline>
      	<AvatarTransform class="Scale">
        	<Set name="targetScale">1.1,1.1</Set>
      	</AvatarTransform>
      </OnDrawCustomOutline>

  </RenderRules>
</ItemRenderer>