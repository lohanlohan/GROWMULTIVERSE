<?xml version="1.0"?>
<ItemRenderer >
	<Data>
		<Sprite name="sword_Sprite" fileName="game/kamusari_sword.rttex" textureSize="64" frame="0,0"/>
		<Sprite name="sword_Sprite_attack" fileName="game/kamusari_sword.rttex" textureSize="64" frame="4,0"/>
		<Sprite name="sword_slash_Sprite" fileName="game/kamusari_particle.rttex" textureSize="64" />
		<Sprite name="s_DestroyImpact" fileName="game/kamusari_break.rttex" textureSize="256" />
		<Sprite name="s_breakflame" fileName="game/kamusari_punch.rttex" textureSize="96"/>
		<Animations>
			<SpriteAnimation name="sword_slash_frames" sprite="sword_slash_Sprite" animTime="500" isLoop="false">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>			
			</SpriteAnimation>
			<SpriteAnimation name="sword_punch_frames" sprite="sword_Sprite_attack" animTime="300"  playOnAction="PUNCH">
				<Frame>4,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="sword_idle_frames" sprite="sword_Sprite" animTime="350" playOnState="Punch.False" >
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				<Frame>0,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_snowflakesHit" sprite="s_DestroyImpact" animTime="400" >
				<Frame>1,2</Frame>
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>0,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_snowflakes" sprite="s_breakflame" animTime="300" >
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
			</SpriteAnimation>
		</Animations>
		<StateMachines>
			<StateMachine name="Punch">
			<States>
				<State name="False" />
				<State name="True" />
			</States>
			<Transitions>
				<Transition from="False" to="True">
					<Condition>
						<IsAction>PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition from="True" to="False">
					<Condition>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
		</StateMachines>
		<ParticleSystems>
			<ParticleSystem name="ps_breakflame" updateStage="OnDamagedTile">
				<Emitter>
					<Set name="particlesPerEmission">1</Set>
					<Set name="offset">0,0</Set>
					<Set name="emissionInterval">0.5</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_breakflame</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 1,1</KeyFrame>
						<KeyFrame>1, 1,1</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.65, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.3</Set>
					<Random name="initialAngle" min="0" max="0" />
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="slash_particle" updateState="Punch.True">
				<Emitter>
					<Set name="offset">0,-22</Set>
					<Set name="emissionInterval">0.5</Set>
					<Set name="lifeTime">0.5</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">sword_slash_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.5</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="interpolateAlpha">false</Set>
					<Set name="initialAlpha">1</Set>
					<Set name="finalAlpha">1</Set>
					<Set name="interpolateVelocity">true</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
					<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ps_destroyImpact">
				<Emitter>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_DestroyImpact</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.3</Set>
					<Random name="initialAngle" min="0" max="0" />
					<Curve name="initialScale">
						<KeyFrame>0, 0.3,0.3</KeyFrame>
						<KeyFrame>1, 0.3,0.3</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		<TileStampData>
			<Set name="FileName">game/kamusari_tile.rttex</Set>
			<Set name="EndFrame">3,0</Set>
			<Set name="FrameCount">4</Set>
		</TileStampData>

		<RenderOptions>
			<Default>
				<Set name="HideParticlesOnTransform">false</Set>
				<Set name="IncludeAllActions">true</Set>
				<Set name="DefaultRenderMannequinHandItem">false</Set>
				<Set name="PunchSoundOverride">HAND</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
				<Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderHandItem>
				<SpriteRender name="sword_Sprite"  rotateOffset="true"  blend="PREMULTIPLIED_ALPHA" alignment="CENTER" offset="27,8" />
 			    <SpriteRender name="sword_Sprite_attack"  rotateOffset="true"  blend="PREMULTIPLIED_ALPHA" alignment="CENTER" offset="27,8" onAction="PUNCH"/>
		</RenderHandItem>
		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
				<Set name="armAngle">1200</Set>
				<Set name="isAdditive">true</Set>
				<Set name="pointTowardsPunchTarget">false</Set>
			</AvatarTransform>
		</OnPunchUpdate>
		<OnPunchStart>
			<ParticleSystemUpdate name="slash_particle"/>
		</OnPunchStart>
		<OnDestroyedTile>
			<ParticleSystemUpdate name="ps_destroyImpact" />
		</OnDestroyedTile>
	</RenderRules>
</ItemRenderer>