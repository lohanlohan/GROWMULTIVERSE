<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
  <StateMachines>
		<StateMachine name="playerState">
			<States>
				<State name="Idle"/>
				<State name="Punch"/>
				<State name="ZombiePunch"/>
			</States>
			<Transitions>
				<Transition from="ZombiePunch|Punch" to="Idle" >
					<Condition>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition from="ZombiePunch|Idle" to="Punch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>false</IsZombified>
					</Condition>
				</Transition>
				<Transition from="Idle|Punch" to="ZombiePunch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>true</IsZombified>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
	</StateMachines>
	<Sprite name="item_Sprite_1" fileName="game/enigma_particles2.rttex" textureSize="64" frame="4,12"/>
	<Sprite name="punch_effect" fileName="game/enigma_particles_small1.rttex" textureSize="32" frame="10,0"/>
	<Sprite name="shadow_punch_particle" fileName="game/enigma_particles_small1.rttex" textureSize="32" frame="12,0"/>
	<Animations>
      <SpriteAnimation name="wingFlexJump2" playOnAction="FALL|WALK|JUMP|IDLE" sprite="item_Sprite_1" animTime="1000" autoPlay="true" isLoop="true">
		<Frame>4,12</Frame>
        <Frame>5,12</Frame>
		<Frame>6,12</Frame>
		<Frame>7,12</Frame>
		<Frame>8,12</Frame>
		<Frame>9,12</Frame>
		<Frame>10,12</Frame>
		<Frame>11,12</Frame>
		<Frame>12,12</Frame>
      </SpriteAnimation>

      <SpriteAnimation name="wingFlexJump3" playOnState="playerState.Punch" sprite="item_Sprite_1" animTime="100" autoPlay="true" isLoop="true">
		<Frame>13,12</Frame>
		<Frame>4,12</Frame>
      </SpriteAnimation>

		<SpriteCurveAnimation name="glowpunch" sprite="punch_effect" isLoop="true" autoPlay="true" animTime="150">
			<Curve name="alpha">
				<KeyFrame>0.f, 1.f</KeyFrame>
				<KeyFrame>1.f, 0.f</KeyFrame>
			</Curve>
		</SpriteCurveAnimation>

	  <SpriteAnimation name="shadowPunch" autoPlay="true" sprite="punch_effect" isLoop="true" animTime="75">
        <Frame>10,0</Frame>
        <Frame>11,0</Frame>
      </SpriteAnimation>
    </Animations>

	<ParticleSystems>
		<ParticleSystem name="shadow_punch_particle">
			<Emitter attachment="targetPos">
				<Set name="offset">0,0</Set>
				<Set name="lifeTime">0.5</Set>
				<Set name="particlesPerEmission">8</Set>
			</Emitter>
			<Particle>
				<Set name="sprite">shadow_punch_particle</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="lifeTime">0.5</Set>
				<Set name="initalRGB">1,1,1</Set>
				<Set name="initialScale">1,1</Set>
				<Set name="initialRotationRate">360</Set>
				<Curve name="initialAlpha">
					<KeyFrame>0, 1</KeyFrame>
					<KeyFrame>0.5, 1</KeyFrame>
					<KeyFrame>1, 0</KeyFrame>
				</Curve>
				<Curve name="initialScale">
            		<KeyFrame>0, 1,1</KeyFrame>
            		<KeyFrame>1, 0.15,0.15</KeyFrame>
          		</Curve>
				<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="60,80"/>
			</Particle>
		</ParticleSystem>
	</ParticleSystems>

	<RenderOptions>
		<Default>
			<Set name="PunchSoundOverride">HAND</Set>
			<Set name="PlayDefaultPunchAudio">true</Set>
			<Set name="IgnoreDefaultDamagedTileEffect">false</Set>
		</Default>
	</RenderOptions>

  </Data>
  <RenderRules>
    <RenderFaceItem>
      <SpriteRender name="item_Sprite_1" offset="3,-40" blend="PREMULTIPLIED_ALPHA"/>
      <SpriteRender name="punch_effect" offset="8,-30" onState="playerState.Punch" blend="PREMULTIPLIED_ALPHA" stretchToTarget="true" alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER" drawShadow="false" flip="1,0"/>
    </RenderFaceItem>
	<OnPunchUpdate>
		<AvatarTransform class="Face">
			<Set name="face">MAD</Set>
		</AvatarTransform>
		<AvatarTransform class="ArmAngle">
			<Set name="armName">arm2Angle</Set>
			<Set name="armAngle">215</Set>
			<Set name="pointTowardsPunchTarget">false</Set>
		</AvatarTransform>
	</OnPunchUpdate>
	<OnDamagedTile>
		<ParticleSystemUpdate name="shadow_punch_particle"/>
	</OnDamagedTile>
  </RenderRules>
</ItemRenderer>