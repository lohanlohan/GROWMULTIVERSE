<?xml version="1.0"?>
<ItemRenderer>
	<Data>
        <Sprite name="DarkHold_Sprite" fileName="game/custom_cosmetics1.rttex" textureSize="32" frame="0,16"/>
        <Sprite name="DarkHold_Punch_Sprite" fileName="game/custom_cosmetics1.rttex" textureSize="32" frame="0,18"/>
        <Sprite name="Chaos_Magic_Sprite" fileName="game/custom_cosmetics1.rttex" textureSize="32" frame="0,19"/>
        <Sprite name="Magic_Damage_Sparks" fileName="game/particles11.rttex" textureSize="32"/>
	    <Sprite name="HitSpark_Sprite" fileName="game/particles.rttex" textureSize="32"/>
	    <Sprite name="trail_Sprite" fileName="game/particles11.rttex" textureSize="32"/>
		<Sprite name="Chaos_Glow_Sprite" fileName="game/chaosglow.rttex" textureSize="223x223" frame="0,0"/>

		<StateMachines>
			<StateMachine name="Action">
				<States>
					<State name="None" />
					<State name="Punch" />
				</States>
				<Transitions>
					<Transition to="None" from="Punch">
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Punch" from="None">
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
        <Animations>
			<SpriteAnimation name="Magic_damage_sparks_Sprites" autoPlay="false" sprite="Magic_Damage_Sparks">
       		    <Frame>31,26</Frame>
			    <Frame>31,28</Frame>
    	    </SpriteAnimation>
			<SpriteAnimation name="trail_anim" autoPlay="true" sprite="trail_Sprite" animTime="850">
       		    <Frame>31,26</Frame>
			    <Frame>31,28</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="HitSpark_Anim" autoPlay="false" isLoop="false" sprite="HitSpark_Sprite"  animTime="200">
				<Frame>7, 5</Frame>
				<Frame>8, 5</Frame>
				<Frame>9, 5</Frame>
			</SpriteAnimation>
						
            <SpriteSinPulseAnimation name="DarkHold_Hover_A" sprite="DarkHold_Sprite" isLoop="true" autoPlay="true">
			    <Parameter name="pos.y">
				    <Set name="period">3000</Set>
				    <Set name="scale">1</Set>
			    </Parameter>
	        </SpriteSinPulseAnimation>
            <SpriteSinPulseAnimation name="DarkHold_HoverPunch_A" sprite="DarkHold_Punch_Sprite" isLoop="true" autoPlay="true">
			    <Parameter name="pos.y">
				    <Set name="period">3000</Set>
				    <Set name="scale">1</Set>
			    </Parameter>
	        </SpriteSinPulseAnimation>

            <SequenceAnimation name="DarkHold_Idle_A" autoPlay="True" isLoop="True">
		        <SpriteAnimation sprite="DarkHold_Sprite" isLoop="False" animTime="600">
       		        <Frame>0,16</Frame>
                    <Frame>1,16</Frame>
                    <Frame>2,16</Frame>
    	        </SpriteAnimation>
		        <SpriteAnimation sprite="DarkHold_Sprite" isLoop="False" animTime="350">
       		        <Frame>3,16</Frame>
                    <Frame>4,16</Frame>
    	        </SpriteAnimation>
		        <SpriteAnimation sprite="DarkHold_Sprite" isLoop="False" animTime="600">
                    <Frame>5,17</Frame>
                    <Frame>6,17</Frame>
                    <Frame>7,17</Frame>
    	        </SpriteAnimation>   
		        <SpriteAnimation sprite="DarkHold_Sprite" isLoop="False" animTime="600">
       		        <Frame>0,16</Frame>
                    <Frame>1,16</Frame>
                    <Frame>2,16</Frame>
                    <Frame>3,17</Frame>
                    <Frame>4,17</Frame>
    	        </SpriteAnimation> 
		        <SpriteAnimation sprite="DarkHold_Sprite" isLoop="False" animTime="350">
       		        <Frame>5,16</Frame>
                    <Frame>6,16</Frame>
    	        </SpriteAnimation>
		        <SpriteAnimation sprite="DarkHold_Sprite" isLoop="False" animTime="1800">
       		        <Frame>7,17</Frame>
                    <Frame>0,16</Frame>
                    <Frame>1,16</Frame>
                    <Frame>2,16</Frame>
                    <Frame>3,17</Frame>
                    <Frame>4,17</Frame>
                    <Frame>5,17</Frame>
                    <Frame>6,17</Frame>
                    <Frame>7,17</Frame>
    	        </SpriteAnimation>            
            </SequenceAnimation>

		    <SpriteAnimation name="DarkHold_Punch_A" autoPlay="true" sprite="DarkHold_Punch_Sprite" isLoop="true" animTime="1000">
       		    <Frame>0,18</Frame>
                <Frame>1,18</Frame>
                <Frame>2,18</Frame>
                <Frame>3,18</Frame>
                <Frame>4,18</Frame>
                <Frame>5,18</Frame>
                <Frame>6,18</Frame>
                <Frame>7,18</Frame>
    	    </SpriteAnimation>
        </Animations>

        <ParticleSystems>
			<ParticleSystem name="Punch_Particles">
				<Emitter attachment="targetPos">
					<Random name="offset" min="-10,10" max="10,-10"/>
					<Set name="lifeTime">0</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">5</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">Chaos_Magic_Sprite</Set>
					<Set name="offset">0, 0</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">0.25</Set>
                    <Random name="initialAngle" min="0" max="360"/>
				        <Curve name="initialAlpha">
					        <KeyFrame>0, 1</KeyFrame>
					        <KeyFrame>0.65, 1</KeyFrame>
					        <KeyFrame>1, 0</KeyFrame>
				        </Curve>
				</Particle>
			</ParticleSystem>
		    <ParticleSystem name="Chaos_Damaged_Sparks">
				<Emitter>
				    <Set name="offset">0,0</Set>
				    <Set name="lifeTime">1.5</Set>
				    <Set name="particlesPerEmission">16</Set>
				    <Set name="delayTimer">0</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
				    <Set name="sprite">Magic_Damage_Sparks</Set>
				    <Set name="blendingMode">ADDITIVE</Set>
				    <Set name="lifeTime">1.25</Set>
				    <Set name="initalRGB">1,1,1</Set>
				    <Set name="initialScale">1,1</Set>
					    <Curve name="initialAlpha">
						    <KeyFrame>0, 1</KeyFrame>
						    <KeyFrame>0.75, 1</KeyFrame>
						    <KeyFrame>1, 0</KeyFrame>
					    </Curve>
				        <Curve name="initialScale">
            		        <KeyFrame>0, 1,1</KeyFrame>
            		        <KeyFrame>1, 1.5,1.5</KeyFrame>
          		        </Curve>
				    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="65,90"/>
			    </Particle>
			</ParticleSystem>
		    <ParticleSystem name="Chaos_Damaged_Glow">
                <Emitter>
                    <Set name="offset">0, 0</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="checkParticleNumToEmit">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <Set name="particlesToEmit">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">Chaos_Glow_Sprite</Set>
                    <Set name="blendingMode">ADDITIVE</Set>
                    <Set name="lifeTime">0.75</Set>
                    <Random name="initialAngle" min="0" max="360"/>
				        <Curve name="initialAlpha">
					        <KeyFrame>0, 1</KeyFrame>
					        <KeyFrame>0.75, 1</KeyFrame>
					        <KeyFrame>1, 0</KeyFrame>
				        </Curve>
				        <Curve name="initialScale">
					        <KeyFrame>0, 0.3,0.3</KeyFrame>
					        <KeyFrame>0.75, 0.5,0.5</KeyFrame>
					        <KeyFrame>1, 0.65,0.65</KeyFrame>
				        </Curve>
                </Particle>
            </ParticleSystem>
			<ParticleSystem name="hitSpark_particle" secondary="trail_particle">
				<Emitter>
					<Set name="particlesPerEmission">8</Set>
					<Set name="lifeTime">2</Set>
					<Set name="useTargetTileColorForTint">true</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">HitSpark_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="useGravity">true</Set>
					<Set name="interpolateScale">true</Set>
					<Set name="initialScale">2,2</Set>
					<Random name="finalScale" min="0.1, 0.1" max="0.4, 0.4"/>
					<Set name="lifeTime">1</Set>
					<RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="80,200"/>
					<Set name="gravityVector">0, 100</Set>
					<Random name="initialRotationRate" min="-300" max="300"/>
					<Random name="posOffset" min="0.1, 0" max="16.1, 16.3"/>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="trail_particle">
				<Emitter>
					<Set name="lifeTime">1</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">80</Set>
					<Set name="emissionInterval">0.2</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">trail_Sprite</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">1.2</Set>
					<Set name="initialRotationRate">150</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0, 0</KeyFrame>
						<KeyFrame>0.4, 2.5, 2.5</KeyFrame>
						<KeyFrame>0.8, 1.25, 1.25</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.75</KeyFrame>
						<KeyFrame>0.8, 0.6</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Set name="initialVelocity">0,0</Set>
				</Particle>
			</ParticleSystem>
        </ParticleSystems>

		    <RenderOptions>
			    <Default>
			        <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
			        <Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
					<Set name="PunchSoundOverride">HAND</Set>
			  		<Set name="PlayDefaultPunchAudio">false</Set>
			    </Default>
		    </RenderOptions>
            <TileStampData>
                <Set name="FileName">game/particles11.rttex</Set>
                <Set name="EndFrame">27,1</Set>
                <Set name="FrameCount">4</Set>
            </TileStampData>
    </Data>

	<RenderRules>
        <RenderInFront>
            <SpriteRender name="DarkHold_Sprite" blend="PREMULTIPLIED_ALPHA" offset="16,-33" alignment="UPPER_CENTER" onState="Action.None"/>
            <SpriteRender name="DarkHold_Punch_Sprite" blend="PREMULTIPLIED_ALPHA" offset="16,-33" alignment="UPPER_CENTER" onState="Action.Punch"/>
        </RenderInFront>

		<OnPunchUpdate>
            <AvatarTransform class="Emotion">
                <Set name="emotion">ANGRY</Set>
            </AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
            <AvatarTransform class="ArmAngle">
				<Set name="armName">arm1Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
			<ParticleSystemUpdate name="Punch_Particles"/>
		</OnPunchUpdate>
		<OnDamagedTile>
			<ParticleSystemUpdate name="Chaos_Damaged_Glow"/>
			<ParticleSystemUpdate name="Chaos_Damaged_Sparks"/>
		</OnDamagedTile>
		<OnDestroyedTile>
			<ParticleSystemUpdate name="hitSpark_particle"/>
		</OnDestroyedTile>
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="Punch_Particles"/>
			<ParticleSystemOff name="hitSpark_particle" />
			<ParticleSystemOff name="Chaos_Damaged_Glow" />
			<ParticleSystemOff name="Chaos_Damaged_Sparks" />
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>