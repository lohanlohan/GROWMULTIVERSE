<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="md_sprite" fileName="game//sonic_red.rttex" textureSize="128"/>
		<Sprite name="md_jump" fileName="game//snc7_jump.rttex" textureSize="135"/>
		<Sprite name="s_trail" fileName="game//sonic_runs.rttex" textureSize="32"/>
		<Sprite name="md_light" fileName="game//raps_ganteng.rttex" textureSize="64"/>
		<StateMachines>
		<StateMachine name="Motion">
			<States>
				<State name="Idle" />
				<State name="Move" />
				<State name="Jump" />
				<State name="Fall" />
				<State name="Punch"/>
				<State name="Respawn"/>
			</States>
			<Transitions>
				<Transition to="Idle" from="Fall|Move|Jump|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						<IsVariableBool name="isAttacking">false</IsVariableBool>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Move" from="Jump|Fall|Idle|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Jump" from="Idle|Move|Fall|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Fall" from="Jump|Idle|Move|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Punch" from="Idle|Move|Jump|Fall">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
		</StateMachines>
		<Animations>
			<SpriteAnimation name="gigi_Idle_Animation" playOnState="Motion.Idle" sprite="md_sprite" animTime="800" isLoop="true">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Punch_Animation" playOnState="Motion.Punch" sprite="md_sprite" animTime="600" isLoop="true">
				<Frame>0,2</Frame>
				<Frame>1,2</Frame>
				<Frame>2,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Jump_Animation" playOnState="Motion.Jump" sprite="md_jump" animTime="600">
				<Frame>0,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Fall_Animation" playOnState="Motion.Fall" sprite="md_jump" animTime="600">
                <Frame>1,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Walk_Animation" playOnState="Motion.Move" sprite="md_sprite" animTime="600" isLoop="true">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="anim_trail" sprite="s_trail" animTime="600" isLoop="true">
				<Frame>0,1</Frame>
				<Frame>1,1</Frame>
				<Frame>2,1</Frame>
				<Frame>3,1</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="anim_efek" sprite="md_light" animTime="800" isLoop="true" playOnState="Motion.Punch|Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				<Frame>4,0</Frame>
				<Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>7,0</Frame>
				<Frame>8,0</Frame>
				<Frame>9,0</Frame>
				<Frame>10,0</Frame>
				<Frame>11,0</Frame>

			</SpriteAnimation>
		</Animations>
		<ParticleSystems>
		<ParticleSystem name="particles_trail">
				<Emitter>
					<Set name="offset">-3,-10015</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="infParticles">true</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="emissionInterval">.15</Set>
				</Emitter>
				<Particle angleRelativeToPlayerSpeed="true">
					<Set name="sprite">s_trail</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">0.6</Set>
					<Set name="isBackgroundParticle">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1.8, 1.5</KeyFrame>
						<KeyFrame>1, 4, 1.5</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
			
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="UserNameOffset">14</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<SpriteRender name="md_sprite" offset="0,-10028" drawShadow="true" scale="0.5,0.5" onState="Motion.Idle|Motion.Move|Motion.Punch"/>
			<SpriteRender name="md_jump" offset="0,-10028" drawShadow="true" scale="0.5,0.5" onState="Motion.Jump|Motion.Fall"/>
			<SpriteRender name="md_light" offset="0,-10028" drawShadow="false" scale="1,1" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
		</RenderInFront>
		
		<AddClothingParticles>
		 <ParticleSystemUpdate name="particles_trail" onState="Motion.Move"/>
		</AddClothingParticles>
		
		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
		<OnPunchStart>
		</OnPunchStart>
	</RenderRules>
</ItemRenderer>