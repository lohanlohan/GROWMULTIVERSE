<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
    <Data>
		<StateMachines>
			<StateMachine name="Action">
				<States>
					<State name="None" />
					<State name="Punch" />
				</States>
				<Transitions>
					<Transition to="None" from="Punch">
						<Condition>
							<IsAction operatorType="NotEqual">PUNCH</IsAction>
						</Condition>
					</Transition>
					<Transition to="Punch" from="None">
						<Condition>
							<IsAction>PUNCH</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>
        
	<Sprite name="s_Crown" fileName="game/custom_tiles_page2.rttex" textureSize="32" frame="14,6"/>
	<Sprite name="s_Crystal" fileName="game/custom_tiles_page2.rttex" textureSize="32" frame="15,6"/>
	<Sprite name="s_CrystalGlow" fileName="game/custom_tiles_page2.rttex" textureSize="32" frame="16,6"/>
    <Sprite name="s_Leaves" fileName="game/enigma_particles5.rttex" textureSize="64"/>
	<Sprite name="HitSpark_Sprite" fileName="game/particles.rttex" textureSize="32"/>
	<Sprite name="trail_Sprite" fileName="game/particles.rttex" textureSize="32"/>

    <Animations>
	    <SpriteSinPulseAnimation name="Crystal_A_Float" sprite="s_Crystal" autoPlay="true">
			<Parameter name="pos.y">
				<Set name="period">4000</Set>
				<Set name="scale">1</Set>
			</Parameter>
	    </SpriteSinPulseAnimation>


	    <SpriteSinPulseAnimation name="CrystalGlow_A_Float" sprite="s_CrystalGlow" autoPlay="true">
			<Parameter name="pos.y">
				<Set name="period">4000</Set>
				<Set name="scale">1</Set>
			</Parameter>
	    </SpriteSinPulseAnimation>

		<SpriteCurveAnimation name="A_Glow" isLoop="true" playOnState="Action.None" sprite="s_CrystalGlow" animTime="5000">
			<Curve name="alpha">
				<KeyFrame>0.f, 0.f</KeyFrame>
				<KeyFrame>0.2f, 0.75.f </KeyFrame>
				<KeyFrame>0.4f, 1.f</KeyFrame>
				<KeyFrame>0.8f, 0.75.f</KeyFrame>
				<KeyFrame>1.f, 0.f</KeyFrame>
			</Curve>
		</SpriteCurveAnimation>	

		<SpriteCurveAnimation name="A_CurvePunch" sprite="s_CrystalGlow" playOnState="Action.Punch"  isLoop="true" animTime="350">
			<Curve name="alpha">
				<KeyFrame>0.f, 0.f</KeyFrame>
				<KeyFrame>0.25f, 0.75.f </KeyFrame>
				<KeyFrame>0.5f, 1.f</KeyFrame>
				<KeyFrame>0.75f, 0.75.f</KeyFrame>
				<KeyFrame>1.f, 0.f</KeyFrame>
			</Curve>
		</SpriteCurveAnimation>

		<SpriteAnimation name="A_AllLeafSprites" sprite="s_Leaves">
			<Frame>12,0</Frame>
			<Frame>13,0</Frame>
            <Frame>14,0</Frame>
            <Frame>15,0</Frame>
		</SpriteAnimation>

		<SpriteAnimation name="HitSpark_Anim" autoPlay="false" isLoop="false" sprite="HitSpark_Sprite"  animTime="200">
			<Frame>1,5</Frame>
			<Frame>2,5</Frame>
            <Frame>3,5</Frame>
            <Frame>4,5</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="trail_anim" autoPlay="true" sprite="trail_Sprite" animTime="1200">
			<Frame>3, 0</Frame>
			<Frame>4, 0</Frame>
		</SpriteAnimation>
    </Animations>

    <ParticleSystems>
		<ParticleSystem name="Ps_LeavesPunch" updateStage="AddClothingParticles" updateState="Action.Punch">
			<Emitter attachment="targetPos">
				<Random name="offset" min="-11,11" max="11,-11"/>
				<Set name="lifeTime">0</Set>
				<Set name="infParticles">false</Set>
				<Set name="particlesPerEmission">1</Set>
				<Set name="particlesToEmit">1</Set>
				<Set name="delayTimer">0.1</Set>
			</Emitter>
			<Particle randomSpriteFrame="true">
				<Set name="sprite">s_Leaves</Set>
				<Set name="offset">0, 0</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="lifeTime">1.25</Set>
                <Set name="initialScale">0.65,0.65</Set>
                <Random name="initialAngle" min="0" max="360"/>
			        <Curve name="initialAlpha">
				        <KeyFrame>0, 1</KeyFrame>
				        <KeyFrame>0.65, 1</KeyFrame>
				        <KeyFrame>1, 0</KeyFrame>
				    </Curve>
                <Random name="initialRotationRate" min="360" max="1080"/>
			</Particle>
		</ParticleSystem>

		<ParticleSystem name="hitSpark_particle" secondary="trail_particle">
			<Emitter>
				<Set name="particlesPerEmission">8</Set>
				<Set name="lifeTime">2</Set>
			</Emitter>
			<Particle randomSpriteFrame="true">
				<Set name="sprite">HitSpark_Sprite</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="useGravity">true</Set>
				<Set name="interpolateScale">true</Set>
				<Set name="initialScale">1,1</Set>
				<Random name="finalScale" min="0.1, 0.1" max="0.4, 0.4"/>
				<Set name="lifeTime">1</Set>
				<RandomRadial name="initialVelocity" angleRange="30,330" radiusRange="80,200"/>
				<Set name="gravityVector">0, 100</Set>
				<Random name="initialRotationRate" min="-300" max="300"/>
				<Random name="posOffset" min="0.1, 0" max="16.1, 16.3"/>
			</Particle>
		</ParticleSystem>
		<ParticleSystem name="trail_particle">
			<Emitter>
				<Set name="lifeTime">1</Set>
				<Set name="particlesPerEmission">1</Set>
				<Set name="particlesToEmit">80</Set>
				<Set name="emissionInterval">0.2</Set>
			</Emitter>
			<Particle>
				<Set name="sprite">trail_Sprite</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="lifeTime">1.2</Set>
				<Set name="initialRotationRate">150</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0, 0</KeyFrame>
						<KeyFrame>0.4, 1, 1</KeyFrame>
						<KeyFrame>0.8, 0.3, 0.3</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0.5</KeyFrame>
						<KeyFrame>0.8, 0</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
				<Set name="initialVelocity">0,0</Set>
			</Particle>
		</ParticleSystem>

		<ParticleSystem name="Ps_TravelingLeaves">
			<Emitter>
				<Set name="infLifeTime">true</Set>
				<Set name="infParticles">false</Set>
				<Set name="particlesToEmit">1</Set>
				<Set name="particlesPerEmission">1</Set>
				<Set name="randomizeInterval">true</Set>
				<Set name="intervalMin">0.1</Set>
				<Set name="intervalMax">0.3</Set>
			</Emitter>
			<Particle randomSpriteFrame="true" autoLifeTimeToTarget="true">
				<Set name="sprite">s_Leaves</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="offset">0,-45</Set>
				<Set name="initalRGB">1,1,1</Set>
				<Random name="initialAngle" min="0" max="180"/>
				<Random name="initialRotationRate" min="90" max="270"/>
				<RandomRadial name="initialVelocity" angleRange="-10,10" radiusRange="150,160" baseAnglePosition="targetPos" baseOffset="0,46"/>
				<Curve name="initialAlpha">
					<KeyFrame>0, 0</KeyFrame>
					<KeyFrame>0.2, 1</KeyFrame>
					<KeyFrame>0.8, 1</KeyFrame>
					<KeyFrame>1, 0</KeyFrame>
				</Curve>
				<Curve name="initialScale">
					<KeyFrame>0, 0.3, 0.3</KeyFrame>
					<KeyFrame>1, 0.6, 0.6</KeyFrame>
				</Curve>
			</Particle>
		</ParticleSystem>
    </ParticleSystems>

	<RenderOptions>
		<Default>
        	<Set name="UserNameOffset">8</Set>
            <Set name="PunchSoundOverride">HAT</Set>
			<Set name="PlayDefaultPunchAudio">false</Set>
		</Default>
	</RenderOptions>
    </Data>

    <RenderRules>
        <RenderHat>
	        <SpriteRender name="s_Crown" rotateOffset="true" offset="0,-42" alignment="CENTER"/>
	        <SpriteRender name="s_Crystal" rotateOffset="true" offset="2.5,-45" alignment="CENTER"/>
            <SpriteRender name="s_CrystalGlow" rotateOffset="true" offset="2.5,-45" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
        </RenderHat>

		<OnPunchUpdate>
            <AvatarTransform class="Emotion">
                <Set name="emotion">HAPPY</Set>
            </AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
            <AvatarTransform class="ArmAngle">
				<Set name="armName">arm1Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
		</OnPunchUpdate>

		<OnPunchStart>
 			<ParticleSystemUpdate name="Ps_TravelingLeaves"/>
		</OnPunchStart>

		<OnDestroyedTile>
			<ParticleSystemUpdate name="hitSpark_particle"/>
		</OnDestroyedTile>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="Ps_LeavesPunch"/>
			<ParticleSystemOff name="hitSpark_particle"/>
			<ParticleSystemOff name="Ps_TravelingLeaves"/>
		</SwitchOffClothingParticles>
    </RenderRules>
</ItemRenderer>