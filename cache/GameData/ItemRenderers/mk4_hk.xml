<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
    <Data>
        <Sprite name="hk_idle" fileName="game//mk4_hk.rttex" textureSize="64,96" frame="0,0"/>
        <Sprite name="hk_walk" fileName="game//mk4_hk.rttex" textureSize="64,96" frame="4,0"/>
        <Sprite name="hk_jump" fileName="game//mk4_hk.rttex" textureSize="64,96" frame="10,0"/>
        <Sprite name="hk_fall" fileName="game//mk4_hk.rttex" textureSize="64,96" frame="11,0"/>
        <Sprite name="hk_sleep" fileName="game//mk4_hk.rttex" textureSize="64,96" frame="12,0"/>
        <Sprite name="hk_sit" fileName="game//mk4_hk.rttex" textureSize="64,96" frame="13,0"/>
        <Sprite name="hk_Punch" fileName="game//mk4_hk.rttex" textureSize="64,96" frame="14,0"/>
        <StateMachines>
            <StateMachine name="Motion">
                <States>
                    <State name="Idle"/>
                    <State name="Move"/>
                    <State name="Jump"/>
                    <State name="Fall"/>
                    <State name="Sleep"/>
                    <State name="Sit"/>
                    <State name="Punch"/>
                </States>
                <Transitions>
                    <Transition to="Idle" from="Fall|Move|Jump|Sleep|Punch|Sit">
                        <Condition type="and">
                            <IsVariableBool name="onGround">true</IsVariableBool>
                            <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
                            <IsVariableBool name="isAttacking">false</IsVariableBool>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                            <IsSitting>false</IsSitting>
                            <IsSleepingOnaBed>false</IsSleepingOnaBed>
                        </Condition>
                    </Transition>
                    <Transition to="Move" from="Jump|Fall|Idle|Sleep|Punch|Sit">
                        <Condition type="and">
                            <IsVariableBool name="onGround">true</IsVariableBool>
                            <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Jump" from="Idle|Move|Fall|Sleep|Punch|Sit">
                        <Condition type="and">
                            <IsVariableBool name="onGround">false</IsVariableBool>
                            <IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Fall" from="Jump|Idle|Move|Sleep|Punch|Sit">
                        <Condition type="and">
                            <IsVariableBool name="onGround">false</IsVariableBool>
                            <IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Sleep" from="Idle|Move|Jump|Fall|Punch|Sit">
                        <Condition type="or">
                            <IsSleepingOnaBed>true</IsSleepingOnaBed>
                            <IsAction>SLEEP</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Sit" from="Idle|Move|Jump|Fall|Punch|Sleep">
                        <Condition>
                            <IsSitting>true</IsSitting>
                        </Condition>
                    </Transition>
                    <Transition to="Punch" from="Idle|Move|Jump|Fall|Sleep|Sit">
                        <Condition>
                            <IsAction>PUNCH</IsAction>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
        </StateMachines>
        <Animations>
            <SpriteAnimation name="hk_Idle_Animation" playOnState="Motion.Idle" sprite="hk_idle" animTime="1000" isLoop="true">
                <Frame>0,0</Frame>
                <Frame>1,0</Frame>
                <Frame>2,0</Frame>
                <Frame>3,0</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="hk_Sleep_Animation" playOnState="Motion.Sleep" sprite="hk_sleep" animTime="600" isLoop="true">
                <Frame>12,0</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="hk_Sit_Animation" playOnState="Motion.Sit" sprite="hk_sit" animTime="600" isLoop="true">
                <Frame>13,0</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="hk_Punch_Animation" playOnState="Motion.Punch" sprite="hk_Punch" animTime="300" isLoop="true">
                <Frame>14,0</Frame>
                <Frame>15,0</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="hk_Jump_Animation" playOnState="Motion.Jump" sprite="hk_jump" animTime="300">
                <Frame>10,0</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="hk_Fall_Animation" playOnState="Motion.Fall" sprite="hk_fall" animTime="300">
                <Frame>11,0</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="hk_Walk_Animation" playOnState="Motion.Move" sprite="hk_walk" animTime="400" isLoop="true">
                <Frame>4,0</Frame>
                <Frame>5,0</Frame>
                <Frame>6,0</Frame>
                <Frame>7,0</Frame>
                <Frame>8,0</Frame>
                <Frame>9,0</Frame>
            </SpriteAnimation>
        </Animations>
        <RenderOptions>
            <Default>
                <Set name="JumpEndStateRange">100</Set>
                <Set name="ClothingOffsetFromShoes">-8</Set>
                <Set name="IsRidingBird">true</Set>
                <Set name="IsVehicle">true</Set>
                <Set name="UserNameOffset">10</Set>
                <Set name="RenderShoesWithMermaidTail">true</Set>
                <Set name="ShoesHidesBodyLegs">true</Set>
                <Set name="IsToRenderPants">false</Set>
            </Default>
        </RenderOptions>
    </Data>
    <RenderRules>
        <RenderInFront>
            <StopIf>
                <IsVariableBool name="isMannequin">true</IsVariableBool>
                <IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
            </StopIf>
            <SpriteRender name="hk_idle" offset="0,-27" drawShadow="true" onState="Motion.Idle" scale="0.8,0.8"/>
            <SpriteRender name="hk_sleep" offset="2,-50" drawShadow="true" onState="Motion.Sleep" scale="0.8,0.8"/>
            <SpriteRender name="hk_sit" offset="0,-44" drawShadow="true" onState="Motion.Sit" scale="0.8,0.8"/>
            <SpriteRender name="hk_Punch" offset="0,-27" drawShadow="true" onState="Motion.Punch" scale="0.8,0.8"/>
            <SpriteRender name="hk_walk" offset="0,-27" drawShadow="true" onState="Motion.Move" scale="0.8,0.8"/>
            <SpriteRender name="hk_jump" offset="0,-27" drawShadow="true" onState="Motion.Jump" scale="0.8,0.8"/>
            <SpriteRender name="hk_fall" offset="0,-27" drawShadow="true" onState="Motion.Fall" scale="0.8,0.8"/>
        </RenderInFront>
        <RenderShoes>
            <StopIf>
                <IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
            </StopIf>
        </RenderShoes>
    </RenderRules>
</ItemRenderer>
