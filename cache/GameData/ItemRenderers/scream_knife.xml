<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>

  <StateMachines>
      <StateMachine name="Motion">
        <States>
          <State name="Idle" />
          <State name="Move" />
          <State name="JumpFall" />
          <State name="Punch" />
        </States>
        <Transitions>
          <Transition to="Idle" from="Move|Punch|JumpFall">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Move" from="Idle|Punch|JumpFall">
            <Condition type="and">
              <IsVariableFloat name="speed.x" operator="Greater" abs="true">0.1</IsVariableFloat>
              <IsVariableFloat name="speed.y" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Punch" from="Idle|Move|JumpFall">
            <Condition>
              <IsAction>PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="JumpFall" from="Idle|Move|Punch">
            <Condition type="and">
              <IsVariableFloat name="speed.y" operator="Greater" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
        </Transitions>
      </StateMachine>
    </StateMachines>

    <VariableMap>
        <Set name="knife.rotate">10,0,0,1</Set>
		<Set name="context.pos">0, 0</Set>
    </VariableMap>

    <Sprite name="s_frontStick" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="14,3"/>
    <Sprite name="slash" fileName="game/particles.rttex" textureSize="32" frame="1,6"/>
    <Sprite name="blood_sprite" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="7,11"/>
    <Sprite name="S_OnDamagedParticle" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="15,12"/>
    <Sprite name="s_EdgeParticles" fileName="game/enigma_particles_small2.rttex" textureSize="32"/>

    <Animations>
        <CurveAnimationVec4 name="anim_hand_rotate" autoPlay="true" isLoop="true" animTime="300">
            <Curve name="knife.rotate">
                <KeyFrame>1, -2, 0, 0, 1</KeyFrame>
            </Curve>
        </CurveAnimationVec4>

			<SpriteCurveAnimation name="slash_fade" isLoop="true" autoPlay="true" sprite="slash" animTime="175">
				<Curve name="alpha">
					<KeyFrame>0.f, 0.f</KeyFrame>
					<KeyFrame>0.5f, 0.9.f</KeyFrame>
					<KeyFrame>1.f, 0.f</KeyFrame>
				</Curve>
			</SpriteCurveAnimation>
    </Animations>

    <ParticleSystems>
    		<ParticleSystem name="blood_particle">
	    		<Emitter>
		    		<Random name="offset" min="0, -17" max="10, -15"/>
			    	<Random name="emissionInterval" min="2" max="5"/>
				    <Set name="infParticles">true</Set>
				    <Set name="infLifeTime">true</Set>
				    <Set name="particlesPerEmission">1</Set>
    			</Emitter>
	    		<Particle>
		    		<Set name="sprite">blood_sprite</Set>
			    	<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				    <Set name="isBackgroundParticle">false</Set>
				    <Set name="initalRGB">1, 1, 1</Set>
				    <Set name="initialAlpha">1</Set>
				    <Set name="finalAlpha">0</Set>
				    <Set name="interpolateAlpha">true</Set>
				    <Set name="interpolateScale">true</Set>
				    <Set name="initialScale">0.3, 0.3</Set>
				    <Set name="finalScale">0.6, 0.6</Set>
				    <Set name="lifeTime">1.5</Set>
				    <Random name="initialVelocity" min="0, 10" max="0, 15"/>
				    <Set name="initialAngle">0</Set>
			    </Particle>
		    </ParticleSystem>

        		<ParticleSystem name="Ps_OnDamagedParticle">
			<Emitter>
				<Set name="offset">0,0</Set>
				<Set name="lifeTime">0.6</Set>
				<Set name="particlesPerEmission">10</Set>
			</Emitter>
			<Particle randomSpriteFrame="true">
				<Set name="sprite">S_OnDamagedParticle</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="lifeTime">0.6</Set>
				<Set name="rotateWithVelocity">true</Set>
        <Set name="initialAngle">90</Set>
				<Curve name="initialAlpha">
					<KeyFrame>0, 1</KeyFrame>
					<KeyFrame>0.75, 0.75</KeyFrame>
					<KeyFrame>1, 0</KeyFrame>
				</Curve>
			    <Curve name="initialScale">
            	<KeyFrame>0, 0.35,0.35</KeyFrame>
            	<KeyFrame>1, 1,1</KeyFrame>
        	</Curve>
            <Set name="useGravity">true</Set>
            <Set name="gravityVector">0, 60</Set>
            <RandomRadial name="initialVelocity" angleRange="45,315" radiusRange="50,75" />
			</Particle>
		</ParticleSystem>
    </ParticleSystems>

    <TileStampData>
			<Set name="FileName">game/enigma_particles_small2.rttex</Set>
			<Set name="EndFrame">15,5</Set>
			<Set name="FrameCount">4</Set>
		</TileStampData>

    <RenderOptions>
      <Default>
        <Set name="PunchSoundOverride">HAND</Set>
        <Set name="PlayDefaultPunchAudio">false</Set>
        <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
      </Default>
    </RenderOptions>
  </Data>


  <RenderRules>
    <RenderHandItem>
    <Group>
	  <Translate forceValue="false">-6,6,0</Translate>
      <Rotate>knife.rotate</Rotate>
      <SpriteRender name="s_frontStick" scale="0.38,0.38" alignment="CENTER" rotateOffset="true" blend="PREMULTIPLIED_ALPHA"/>
    </Group>
      <SpriteRender name="slash" offset="5,-4" onAction="PUNCH" blend="PREMULTIPLIED_ALPHA" stretchToTarget="true" alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER" drawShadow="false" flip="1,1" scale="1,1.5"/>
    </RenderHandItem>

    <OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
		    <AvatarTransform class="ArmAngle">
			    <Set name="armName">arm2Angle</Set>
			    <Set name="armAngle">1750</Set>
			    <Set name="isAdditive">true</Set>
			    <Set name="pointTowardsPunchTarget">false</Set>
		    </AvatarTransform>
		</OnPunchUpdate>

    <OnDamagedTile>
		    <ParticleSystemUpdate name="Ps_OnDamagedParticle"/>
	  </OnDamagedTile>

    <AddClothingParticles>
			<ParticleSystemUpdate name="blood_particle" drawShadow="false"/>
            <ParticleSystemUpdate name="blood_particle_2" drawShadow="false"/>
		</AddClothingParticles>
    
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="blood_particle"/>
            <ParticleSystemOff name="blood_particle_2"/>
            <ParticleSystemOff name="Ps_OnDamagedParticle"/>
		</SwitchOffClothingParticles>

    <Update>
      <AvatarTransform class="ArmAngle" onAction="IDLE|WALK|JUMP|JUMPSTART|FALL|DANCE|DANCE2|DAB">
        <Set name="armName">arm2Angle</Set>
        <Set name="animTime">700</Set>
        <Set name="Curve">
          <KeyFrame>1, 200</KeyFrame>
        </Set>
      </AvatarTransform>
    </Update>
  </RenderRules>
</ItemRenderer>