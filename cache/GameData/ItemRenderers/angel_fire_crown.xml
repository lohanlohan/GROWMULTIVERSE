<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
	<Sprite name="Crown" fileName="game/custom_cosmetics1.rttex" textureSize="32" frame="0,8"/>
	<Sprite name="Flame" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="14,0"/>

<Animations>

    <SpriteAnimation name="Crown_A" autoPlay="true" sprite="Crown" animTime="750" autoPlay="true" isLoop="true">
			<Frame>0,8</Frame>
			<Frame>1,8</Frame>
	</SpriteAnimation>
    </Animations>

		<ParticleSystems>
			<ParticleSystem name="flame_particles">
        		<Emitter>
          			<Set name="particlesPerEmission">2</Set>
          			<Set name="particlesToEmit">1</Set>
         	 		<Set name="emissionInterval">0.05</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
          			<Set name="checkParticleNumToEmit">false</Set>
        		</Emitter>
       			 <Particle>
          			<Set name="sprite">Flame</Set>
          			<Set name="blendingMode">ADDITIVE</Set>
          			<Set name="lifeTime">0.85</Set>
					<Set name="isBackgroundParticle">false</Set>
          			<Set name="initialVelocity">0,-2</Set>
                    <Random name="offset" min="10, -37" max="-10, -37"/>
                        <Curve name="initialScale">
            				<KeyFrame>0, 0.4,0.4</KeyFrame>
            				<KeyFrame>1, 0.05,0.85</KeyFrame>
          				</Curve>
                        <Curve name="initialAlpha">
            				<KeyFrame>0, 0.17</KeyFrame>
            				<KeyFrame>1, 0</KeyFrame>
          				</Curve>
        			</Particle>
      	    </ParticleSystem>		
		</ParticleSystems>
  </Data>

  <RenderRules>
    <RenderHat>
	  <ParticleSystemUpdate name="flame_particles" offset="0, -32" alignment="CENTER"/>
	  <SpriteRender name="Crown" rotateOffset="true" offset="0, -32" alignment="CENTER"/>
    </RenderHat>

	<SwitchOffClothingParticles>
		<ParticleSystemOff name="flame_particles"/>
	</SwitchOffClothingParticles>

  </RenderRules>
</ItemRenderer>