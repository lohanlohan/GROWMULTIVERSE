<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer item="ITEM_ID_SERAPHIC_WINGS">
	<Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="wing" fileName="game/flappybirdwing.rttex" textureSize="112" frame="0,0"/>
		<Sprite name="jumpeffect" fileName="game/flappybirdwing.rttex" textureSize="112" frame="6,0"/>

		<Animations>
			<SpriteAnimation name="wing_Idle" playOnState="playerState.Idle|playerState.SpiritGuide|playerState.Move" sprite="wing" isLoop="true" animTime="900">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
			</SpriteAnimation>
			
			<SpriteAnimation name="wing_DoubleJ" playOnState="playerState.DoubleJump" sprite="wing" isLoop="false" animTime="800">
				<Frame>4,0</Frame>
				<Frame>5,0</Frame>
			</SpriteAnimation>		

      		<SpriteAnimation name="wing_Fall" playOnState="playerState.Fall" sprite="wing" isLoop="false" animTime="300">
        		<Frame>5,0</Frame>
			</SpriteAnimation>		
		
			<SpriteAnimation name="wing_Jump" playOnState="playerState.Jump" sprite="wing" isLoop="true" animTime="900">
				<Frame>3,0</Frame>
				<Frame>4,0</Frame>
				<Frame>5,0</Frame>
			</SpriteAnimation>

		</Animations>
		
		<ParticleSystems>
			<ParticleSystem name="double_jump_particle">
				<Emitter>
          			<Set name="offset">0,47</Set>
					<Set name="lifeTime">0.5</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="infParticles">true</Set>
          			<Set name="infLifeTime">true</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">jumpeffect</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="isBackgroundParticle">true</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="rotateWithVelocity">false</Set>
          			<Set name="interpolateScale">true</Set>
					<Set name="interpolateAlpha">true</Set>
					<Set name="lifeTime">1</Set>
					<Set name="initialScale">1,1</Set>
          			<Set name="finalScale">1.3, 1.3</Set>
          			<Set name="initialVelocity">2,2</Set>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>

		<RenderOptions>
			<Default>
				<Set name="PlayDefaultPunchAudio">true</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<OnDrawCustomOutline>
      <AvatarTransform class="RenderData">
        <Set name="saturation">getCurrent</Set>
        <Set name="brightness">getCurrent</Set>
        <Set name="contrast">getCurrent</Set>
      </AvatarTransform>
      <AvatarTransform class="Scale">
        <Set name="targetScale">getCurrent</Set>
      </AvatarTransform>
      <AvatarTransform class="RenderData">
        <Set name="saturation">3</Set>
        <Set name="brightness">1</Set>
        <Set name="contrast">0.1</Set>
      </AvatarTransform>
      <AvatarOutline duration="2000" startScale="0.9,0.9" endScale="1.1,1.1">
		<Colours>
          <Colour>92,92,94,225</Colour>
          <Colour>0,0,0,225</Colour>
        </Colours>
      </AvatarOutline>
      <AvatarTransform class="RenderData">
        <Set name="saturation">reset</Set>
        <Set name="brightness">reset</Set>
        <Set name="contrast">reset</Set>
      </AvatarTransform>
      <AvatarTransform class="Scale">
        <Set name="targetScale">reset</Set>
      </AvatarTransform>
    </OnDrawCustomOutline>
		<RenderBackpack>
			<SpriteRender name="wing" offset="4,-23" alignmentLeft="LEFT_CENTER" alignmentRight="RIGHT_CENTER"/>
			<SpriteRender name="wing" offset="-4,-23" flip="1,0" alignmentLeft="RIGHT_CENTER" alignmentRight="LEFT_CENTER"/>
			<StopIf>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
		</RenderBackpack>
		<ParticleSystemRender>
			<ParticleSystemRenderer name="drop_particles" onAction="MOVE|IDLE" drawShadow="false"/>
			<ParticleSystemRenderer name="double_jump_particle" onAction="JUMPDOUBLE" drawShadow="false"/>
		</ParticleSystemRender>



		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
		</OnPunchUpdate>

		<AddClothingParticles>
			<ParticleSystemUpdate name="double_jump_particle" onAction="JUMPDOUBLE" drawShadow="false"/>
		</AddClothingParticles>
    
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="double_jump_particle"/>
		</SwitchOffClothingParticles>

	</RenderRules>
</ItemRenderer>