<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

	<Sprite name="s_Aura" fileName="game/enigma_sword_aura.rttex" textureSize="700x700" frame="0,0"/>
	<Sprite name="s_PunchSword" fileName="game/enigma_256_sprites1.rttex" textureSize="256" frame="0,0"/>
	<Sprite name="s_BlockSword" fileName="game/enigma_256_sprites1.rttex" textureSize="256" frame="0,0"/>
	<Sprite name="s_Rays" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="12,4"/>
	<Sprite name="s_Curves" fileName="game/enigma_dvw_1.rttex" textureSize="64" frame="10,4"/>
	<Sprite name="s_Sparkle" fileName="game/enigma_particles_small2.rttex" textureSize="32" frame="7,8"/>
	<Sprite name="NecklaceSprite" fileName="game/custom_cosmetics1.rttex" textureSize="32" frame="22,9"/>
	    <Sprite name="GlowNecklaceSprite" fileName="game/custom_cosmetics1.rttex" textureSize="32" frame="23,9"/> 

	<Animations>
        <SpriteCurveAnimation name="A_AuraSpin" sprite="s_Aura" animTime="50000" autoPlay="true" isLoop="true">
            <Curve name="rotation">
				<KeyFrame>0, 0</KeyFrame>
				<KeyFrame>1, 360</KeyFrame>
			</Curve>
		</SpriteCurveAnimation>

		<SpriteCurveAnimation name="Necklace_Glow_A" sprite="GlowNecklaceSprite" animTime="2500" autoPlay="true" isLoop="true">
            <Curve name="alpha">
                <KeyFrame>0, 0.0</KeyFrame>
                <KeyFrame>0.5, 1</KeyFrame>
                <KeyFrame>1, 0.0</KeyFrame>
            </Curve>
        </SpriteCurveAnimation>

		<SpriteAnimation name="A_Horns" sprite="s_Rays">
    		<Frame>12,4</Frame>
    		<Frame>13,4</Frame>
		</SpriteAnimation>
		<SpriteAnimation name="A_Shadows" sprite="s_Curves">
    		<Frame>10,4</Frame>
    		<Frame>11,4</Frame>
		</SpriteAnimation>
    </Animations>

	<ParticleSystems>
			<ParticleSystem name="ps_Rays">
				<Emitter>
					<Set name="offset">0, -15</Set>
					<Set name="offsetFacing">false</Set>
					<Set name="emissionInterval">0.3</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_Rays</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="inSpecificOrder">true</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="interpolateAlpha">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.9, 0.9</KeyFrame>
						<KeyFrame>1, 1.1, 1.1</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.8</Set>
				</Particle>
			</ParticleSystem>
			
		<ParticleSystem name="ps_Curves" updateStage="AddClothingParticles">
			<Emitter>
				<Set name="offset">0, -15</Set>
				<Set name="offsetFacing">true</Set>
				<Set name="emissionInterval">0.75</Set>
				<Set name="infParticles">true</Set>
				<Set name="infLifeTime">true</Set>
				<Set name="particlesPerEmission">1</Set>
			</Emitter>
			<Particle randomSpriteFrame="true">
				<Set name="sprite">s_Curves</Set>
				<Set name="relativeToEmitter">true</Set>
				<Set name="inSpecificOrder">true</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="interpolateAlpha">true</Set>
				<Curve name="initialAlpha">
					<KeyFrame>0, 0</KeyFrame>
					<KeyFrame>0.5, 1</KeyFrame>
					<KeyFrame>1, 0</KeyFrame>
				</Curve>
				<Curve name="initialScale">
					<KeyFrame>0, 0.65, 0.65</KeyFrame>
					<KeyFrame>1, 1.25, 1.25</KeyFrame>
				</Curve>
				<Set name="lifeTime">3</Set>
			</Particle>
		</ParticleSystem>

		<ParticleSystem name="Punch_ps" secondary="PunchFollow_ps">
				<Emitter>
					<Set name="offset">-10,0</Set>
					<Set name="lifeTime">0.4</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">s_PunchSword</Set>
					<Select name="offset" input="punchCount">
						<Item>0, -50</Item>
						<Item>25, -35</Item>
						<Item>40, 0</Item>
						<Item>25, 25</Item>
						<Item>0, 40</Item>
						<Item>-25, 25</Item>
						<Item>-40, 0</Item>
						<Item>-25, -35</Item>
					</Select>
					<Curve name="initialScale">
						<KeyFrame>0, 0.15,0.15</KeyFrame>
					</Curve>
					<Random name="targetPosOffset" min="-10,-10" max="10,10"/>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="lifeTime">0.3</Set>
					<VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="0.9" angleOutVar="projectile_angle"/>
                    <SetVar name="projectile_offset" source="targetPosOffset"/>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="PunchFollow_ps">
				<Emitter>
					<Set name="lifeTime">0.28</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="particlesToEmit">80</Set>
					<Random name="offset" min="-1,-1" max="1,1"/>
					<Random name="emissionInterval" min="0.02" max="0.03"/>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_Sparkle</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Random name="lifeTime" min="0.75" max="1.5"/>
					<Random name="offset" min="-2,-2" max="2,2"/>
					<Random name="initialRotationRate" min="50" max="200"/>
					<Curve name="initialScale">
						<KeyFrame>0, 0.9,0.9</KeyFrame>
						<KeyFrame>1, 0.02,0.02</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.9, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="ps_tileSword">
        <Emitter>
          <Set name="infParticles">true</Set>
          <Set name="checkParticleNumToEmit">true</Set>
          <Set name="particlesPerEmission">1</Set>
          <Set name="particlesToEmit">1</Set>
          <Set name="delayTimer">0.25</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">s_BlockSword</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">1.1</Set>
          <Set name="renderAlignment">RIGHT_CENTER</Set>
          <Set name='initialScale'>0.15,0.15</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>0.9, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
          <Set name="offset" source="projectile_offset"/>
          <Set name="initialAngle" source="projectile_angle"/>
        </Particle>
      </ParticleSystem>
	</ParticleSystems>

    <VariableMap>
      <Set name="projectile_offset">0, 0</Set>
      <Set name="projectile_angle">0</Set>
    </VariableMap>

    <RenderOptions>
      <Default>
	    <Set name="IncludeAllActions">true</Set>
		<Set name="PunchSoundOverride">CHESTITEM</Set>
        <Set name="PlayDefaultPunchAudio">false</Set>
        <Set name="UserNameOffset">8</Set>
        <Set name="ShouldHover">true</Set>
      </Default>
    </RenderOptions>
  </Data>

  <RenderRules>
	<RenderBehind>
		<SpriteRender name="s_Aura" offset="0,7" scale="0.19,0.19" alignment="CENTER" blend="PREMULTIPLIED_ALPHA"/>
		<Group>
		<ParticleSystemRender name="ps_Rays"/>
		<ParticleSystemRender name="ps_Curves"/>
      </Group>
	</RenderBehind>

	<RenderChestItem>
		<SpriteRender name="NecklaceSprite" offset="1,-15" blend="PREMULTIPLIED_ALPHA"/>
		<SpriteRender name="GlowNecklaceSprite" offset="1,-15" blend="PREMULTIPLIED_ALPHA"/>   
    </RenderChestItem>
	
	<OnPunchStart>
		<ParticleSystemUpdate name="Punch_ps"/>
	</OnPunchStart>

	<OnDamagedTile>
        <ParticleSystemUpdate name="ps_tileSword" />
    </OnDamagedTile>

	<AddClothingParticles>
		<ParticleSystemUpdate name="ps_Rays" />
		<ParticleSystemUpdate name="ps_Curves" />
	</AddClothingParticles>
		<Update>
			<StopIf>
				<IsZombified>true</IsZombified>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
			<AvatarTransform class="FootPosition">
				<Set name="foot1dy">0</Set>
				<Set name="foot2dy">0</Set>
				<Set name="foot1y">0</Set>
				<Set name="foot2y">0</Set>
			</AvatarTransform>

			<AvatarTransform class="Emotion">
				<Set name="emotion">EMOTION_COUNT</Set>
			</AvatarTransform>
		</Update>

		<OnPunchUpdate>
            <AvatarTransform class="Emotion">
                <Set name="emotion">ANGRY</Set>
            </AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
            <AvatarTransform class="ArmAngle">
				<Set name="armName">arm1Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
		</OnPunchUpdate>

  	<OnDrawCustomOutline>
      <AvatarTransform class="Scale">
        <Set name="targetScale">1.1,1.1</Set>
      </AvatarTransform>
    </OnDrawCustomOutline>
  </RenderRules>
</ItemRenderer>