<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
	<StateMachines>
		<StateMachine name="playerState">
			<States>
				<State name="Idle"/>
				<State name="Punch"/>
				<State name="ZombiePunch"/>
			</States>
			<Transitions>
				<Transition from="ZombiePunch|Punch" to="Idle" >
					<Condition>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition from="ZombiePunch|Idle" to="Punch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>false</IsZombified>
					</Condition>
				</Transition>
				<Transition from="Idle|Punch" to="ZombiePunch">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
						<IsZombified>true</IsZombified>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
	</StateMachines>

	<Sprite name="sword_sprite" fileName="game/enigma_128_sprites1.rttex" textureSize="128" frame="6,8"/>
	<Sprite name="punch_effect" fileName="game/enigma_particles_small3.rttex" textureSize="32" frame="12,2"/>
	<Sprite name="s_OnHit_Particle" fileName="game/enigma_256_sprites1.rttex" textureSize="256" frame="1,0"/>
	
	<ParticleSystems>
		<ParticleSystem name="angel_particle">
			<Emitter>
				<Set name="offset">0,-18</Set>
				<Set name="emissionInterval">0.25</Set>
				<Set name="lifeTime">0.25</Set>
				<Set name="particlesPerEmission">1</Set>
				<Set name="particlesToEmit">1</Set>
			</Emitter>
			<Particle>
				<Set name="sprite">punch_effect</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="lifeTime">0.4</Set>
				<Set name="rotateWithVelocity">true</Set>
				<Set name="interpolateAlpha">false</Set>
				<Set name="initialAlpha">1</Set>
				<Set name="finalAlpha">1</Set>
				<Set name="interpolateVelocity">true</Set>
				<Curve name="initialScale">
            				<KeyFrame>0, 0.5,0.5</KeyFrame>
            				<KeyFrame>1, 2,2</KeyFrame>
          				</Curve>
				<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
				<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
			</Particle>
		</ParticleSystem>

		<ParticleSystem name="OnHit_Ps">
				<Emitter>
					<Random name="offset" min="-1,-1" max="1,1"/>
					<Set name="lifeTime">0.85</Set>
					<Set name="particlesPerEmission">1</Set>
					<Set name="delayTimer">0</Set>
				</Emitter>
				<Particle>
					<Random name="offset" min="-1,-1" max="1,1"/>
					<Set name="sprite">s_OnHit_Particle</Set>
					<Set name="blendingMode">ADDITIVE</Set>
					<Set name="lifeTime">1.75</Set>
					<Curve name="initialAlpha">
                        <KeyFrame>0, 0.8</KeyFrame>
                        <KeyFrame>0.3, 0.8</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
					</Curve>
				    <Curve name="initialScale">
            		    <KeyFrame>0, 0.2,0.2</KeyFrame>
            		    <KeyFrame>1, 0.25,0.25</KeyFrame>
          		    </Curve>
					<Random name="initialAngle" min="0" max="360"/>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
	<RenderOptions>
		<Default>
			<Set name="PunchSoundOverride">HAND</Set>
			<Set name="PlayDefaultPunchAudio">true</Set>
		</Default>
	</RenderOptions>
  </Data>

  <RenderRules>
    <RenderHandItem>
	  <SpriteRender name="sword_sprite" rotateOffset="true" offset="28,10" scale="0.65,0.65" alignment="CENTER"/>
    </RenderHandItem>

	<OnDamagedTile>
		    <ParticleSystemUpdate name="OnHit_Ps"/>
	</OnDamagedTile>

	<OnPunchUpdate>
		<AvatarTransform class="Face">
			<Set name="face">MAD</Set>
		</AvatarTransform>
		<AvatarTransform class="ArmAngle">
			<Set name="armName">arm2Angle</Set>
			<Set name="armAngle">1600</Set>
			<Set name="isAdditive">true</Set>
			<Set name="pointTowardsPunchTarget">false</Set>
		</AvatarTransform>
	</OnPunchUpdate>
	<OnPunchStart>
		<ParticleSystemUpdate name="angel_particle"/>
	</OnPunchStart>
	<SwitchOffClothingParticles>
		<ParticleSystemOff name="angel_particle"/>
		<ParticleSystemOff name="OnHit_Ps"/>
	</SwitchOffClothingParticles>
  </RenderRules>
</ItemRenderer>