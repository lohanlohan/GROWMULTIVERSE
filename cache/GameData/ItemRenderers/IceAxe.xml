<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer item="ITEM_ID_FIRE_KATANA">
	<Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
				<State name="Equip"/>
				<State name="Fall"/>
				<State name="Punch"/>
				</States>
				<Transitions>
				<Transition from="Equip" to="Fall" >
					<Condition>
					<IsAction>FALL</IsAction>
					</Condition>
				</Transition>
				<Transition from="Fall" to="Equip">
					<Condition>
					<IsAction operatorType="NotEqual">FALL</IsAction>
					</Condition>
				</Transition>
				<Transition from="Equip|Fall" to="Punch" >
					<Condition>
					<IsAction>PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition from="Punch" to="Equip">
					<Condition type="and">
					<IsAction operatorType="NotEqual">PUNCH</IsAction>
					<IsAction operatorType="NotEqual">FALL</IsAction>
					</Condition>
				</Transition>
				<Transition from="Punch" to="Fall">
					<Condition type="and">
					<IsAction operatorType="NotEqual">PUNCH</IsAction>
					<IsAction>FALL</IsAction>
					</Condition>
				</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="axe_move" fileName="game/eventweapons.rttex" textureSize="96,32" frame="0,3"/>
		<Sprite name="axe_punch" fileName="game/eventweapons.rttex" textureSize="96,32" frame="0,3"/>
		<Sprite name="sword_slash_Sprite" fileName="game/eventweapons.rttex" textureSize="96,32" frame="0,4"/>
		<Sprite name="snow" fileName="game/particles11.rttex" textureSize="32" frame="27,10"/>
		<Sprite name="core" fileName="game/particles11.rttex" textureSize="32" frame="8,13"/>
		<Sprite name="spark_Sprite" fileName="game/particles11.rttex" textureSize="32" frame="27,10"/>
		<Sprite name="hit_black_Sprite" fileName="game/particles_large12.rttex" textureSize="64" frame="12,4"/>
		<Sprite name="hit_red_Sprite" fileName="game/particles_large8.rttex" textureSize="64" frame="12,9"/>
		<Animations>
			<SpriteAnimation name="sword_slash_frames" autoPlay="true" sprite="sword_slash_Sprite" animTime="250" isLoop="true">
				<Frame>0,4</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="flamess" autoPlay="true" sprite="flames" animTime="400" isLoop="true">
				<Frame>8,0</Frame>
				<Frame>9,0</Frame>
				<Frame>10,0</Frame>
				<Frame>11,0</Frame>
				<Frame>12,0</Frame>
				<Frame>13,0</Frame>
				<Frame>14,0</Frame>
				<Frame>15,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="snowfall" autoPlay="true" sprite="snow" animTime="600" isLoop="true">
				<Frame>27,10</Frame>
				<Frame>28,10</Frame>
				<Frame>29,10</Frame>
			</SpriteAnimation>

			<SpriteCurveAnimation name="a_coreFloat" sprite="core" animTime="3000" autoPlay="true" isLoop="true">
				<Curve name="pos.y">
				<KeyFrame>0.f, -2</KeyFrame>
				<KeyFrame>0.1f, -1</KeyFrame>
				<KeyFrame>0.5f, 2</KeyFrame>
				<KeyFrame>0.9f, -1</KeyFrame>
				<KeyFrame>1.f, -2</KeyFrame>
				</Curve>
			</SpriteCurveAnimation>
			<SpriteAnimation name="cores" autoPlay="true" sprite="core" animTime="600" isLoop="true">
				<Frame>8 ,13</Frame>
				<Frame>9 ,13</Frame>
				<Frame>10,13</Frame>
				<Frame>11,13</Frame>
				<Frame>12,13</Frame>
				<Frame>13,13</Frame>
				<Frame>14,13</Frame>
				<Frame>15,13</Frame>
			</SpriteAnimation>
		</Animations>
		<ParticleSystems>
			<ParticleSystem name="punch_projectile" updateStage="OnPunchStart">
				<Emitter>
					<Random name="offset" min="28, -17" max="28, -16"/>
					<Set name="lifeTime">0</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Set name="sprite">sword_slash_Sprite</Set>
					<Set name="initialScale">1.75,2.25</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="lifeTime">0.2</Set>
					<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1"/>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ember_particle1">
				<Emitter>
					<Set name="offset">28, -25</Set>
					<Set name="offsetFacing">true</Set>
					<Random name="emissionInterval" min="0.4" max="0.7" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">snow</Set>
					<Set name="relativeToEmitter">true</Set>
					<Random name="offset" min="-8, -4" max="8, 4.01" />
					<Set name="inSpecificOrder">true</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.1, 1</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Random name="initialScale" min="0.75" max="1.25" />
					<Random name="lifeTime" min="0.8" max="1.5" />
					<Set name="initialVelocity">0, 30</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="ember_particle2">
				<Emitter>
					<Set name="offset">30, 10</Set>
					<Set name="offsetFacing">true</Set>
					<Random name="emissionInterval" min="0.3" max="0.6" />
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle usePlayerFacing="true">
					<Set name="sprite">snow</Set>
					<Set name="relativeToEmitter">true</Set>
					<Random name="offset" min="-8, -4" max="8, 4.01" />
					<Set name="inSpecificOrder">true</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 0</KeyFrame>
						<KeyFrame>0.1, 1</KeyFrame>
						<KeyFrame>0.5, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Random name="initialScale" min="0.75" max="1.25" />
					<Random name="lifeTime" min="0.8" max="1.5" />
					<Set name="initialVelocity">0, 10</Set>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="hit_black_particle_stamp">
				<Emitter>
					<Set name="lifeTime">1</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Random name="initialAngle" min="-360" max="360"/>
					<Set name="sprite">hit_black_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.5</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.4,0.4</KeyFrame>
						<KeyFrame>1, 1.3,1.3</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="hit_red_particle_stamp">
				<Emitter>
					<Set name="lifeTime">1</Set>
					<Set name="particlesToEmit">1</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle>
					<Random name="initialAngle" min="-360" max="360"/>
					<Set name="sprite">hit_red_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.5</Set>
					<Curve name="initialScale">
						<KeyFrame>0, 0.4,0.4</KeyFrame>
						<KeyFrame>1, 1.3,1.3</KeyFrame>
					</Curve>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
				</Particle>
			</ParticleSystem>
			<ParticleSystem name="hit_particle">
				<Emitter>
					<Set name="offset">0,0</Set>
					<Set name="lifeTime">0</Set>
					<Set name="particlesPerEmission">10</Set>
					<Set name="delayTimer">0.0</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">spark_Sprite</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
					<Set name="lifeTime">0.5</Set>
					<Set name="initalRGB">1,1,1</Set>
					<Set name="initialScale">1,1</Set>
					<Set name="rotateWithVelocity">true</Set>
					<Set name="interpolateAlpha">true</Set>
					<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="200,250"/>
				</Particle>
			</ParticleSystem>
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="HideParticlesOnTransform">false</Set>
				<Set name="PunchSoundOverride">HAND</Set>
				<Set name="RenderBackArmInfected">true</Set>
				<Set name="RenderFrontArmInfected">true</Set>
				<Set name="RenderFrontArmBuild">false</Set>
				<Set name="RenderFrontArmInTheFront">true</Set>
				<Set name="DefaultRenderMannequinHandItem">false</Set>
				<Set name="UserNameOffset">20</Set>
				<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<Update>
			<StopIf>
				<IsZombified>true</IsZombified>
			</StopIf>
			<AvatarTransform class="ArmAngle" onState="playerState.Equip|playerState.Fall">
				<Set name="armName">arm2Angle</Set>
				<Set name="armAngle">-240</Set>
			</AvatarTransform>
			<StopIf type="or">
				<IsZombified>true</IsZombified>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
				<IsWearing slot="SHOES">ITEM_ID_STAR_FIGHTER_REBEL_RAIDER</IsWearing>
				<IsWearing slot="SHOES">ITEM_ID_STAR_FIGHTER_IMPERIAL_ENFORCER</IsWearing>
			</StopIf>
		</Update>
		<RenderBehind>
			<SpriteRender name="core" offset="-16, -16" scale="2,2" rotationPoint="0,1" rotateOffset="false" blend="PREMULTIPLIED_ALPHA"/>
			<StopIf>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
			<Group>
				<Rotate>-15,0,0,1</Rotate>
				<SpriteRender name="axe_move" offset="6, 2" scale="1.5,1.5" rotationPoint="0,1" rotateOffset="false" blend="PREMULTIPLIED_ALPHA" onState="playerState.Equip|playerState.Fall"/>
			</Group>
			<ParticleSystemRender name="ember_particle1"/>
			<ParticleSystemRender name="ember_particle2"/>
			<ParticleSystemUpdate name="ember_particle1" onState="playerState.Equip|playerState.Fall"/>
			<ParticleSystemUpdate name="ember_particle2" onState="playerState.Equip|playerState.Fall"/>
		</RenderBehind>
		<RenderHandItem>
			<StopIf>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
			<SpriteRender name="axe_punch" offset="10, 8" scale="1.5,1.5" rotationPoint="0,1" rotateOffset="true" blend="PREMULTIPLIED_ALPHA" onState="playerState.Punch"/>
		</RenderHandItem>
		<OnPunchUpdate>
			<StopIf type="or">
				<IsZombified>true</IsZombified>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
				<IsWearing slot="SHOES">ITEM_ID_STAR_FIGHTER_REBEL_RAIDER</IsWearing>
				<IsWearing slot="SHOES">ITEM_ID_STAR_FIGHTER_IMPERIAL_ENFORCER</IsWearing>
			</StopIf>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle" onAction="PUNCH">
				<Set name="armName">arm2Angle</Set>
				<Set name="animTime">500</Set>
				<Set name="Curve">
					<KeyFrame>0.0, 0</KeyFrame>
					<KeyFrame>1, 360</KeyFrame>
				</Set>
			</AvatarTransform>
		</OnPunchUpdate>
		<OnDamagedTile>
			<ParticleSystemUpdate name="hit_black_particle_stamp"/>
			<ParticleSystemUpdate name="hit_red_particle_stamp"/>
			<ParticleSystemUpdate name="hit_particle"/>
		</OnDamagedTile>
		<SwitchOffClothingParticles>
			<ParticleSystemOff name="hit_black_particle_stamp"/>
			<ParticleSystemOff name="hit_red_particle_stamp"/>
			<ParticleSystemOff name="punch_projectile"/>
			<ParticleSystemOff name="hit_particle"/>
		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>