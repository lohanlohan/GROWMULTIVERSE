<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
			<StateMachine name="playerState">
				<States>
					<State name="Idle"/>
					<State name="Move"/>
					<State name="Fall"/>
					<State name="Jump"/>
					<State name="DoubleJump"/>
					<State name="SpiritGuide"/>
				</States>
				<Transitions>
					<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump" to="Idle" >
						<Condition>
							<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Jump|Fall|Idle|DoubleJump" to="Move">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>WALK</IsAction>
						</Condition>
					</Transition>				
					<Transition from="Move|Jump|Fall|Idle|DoubleJump" to="SpiritGuide">
						<Condition type="and">
							<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
							<IsAction operatorType="NotEqual">FALL</IsAction>
						</Condition>
					</Transition>
					<Transition from="SpiritGuide|Fall|Move|Idle" to="Jump">
						<Condition type="and">
							<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
							<IsAction>JUMP</IsAction>
						</Condition>
					</Transition>
					<Transition from="Jump|Fall" to="DoubleJump">
						<Condition>
							<IsAction>JUMPDOUBLE</IsAction>
						</Condition>
					</Transition>
					<Transition from="DoubleJump|SpiritGuide|Jump|Idle|Move" to="Fall">
						<Condition type="and">
							<IsVariableFloat name="speed.y" operator="Greater" abs="false">0.01</IsVariableFloat>
							<IsAction>FALL</IsAction>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="left_wing_sprite" fileName="game/aws.rttex" textureSize="64,128" frame="0,0"/>
		<Sprite name="right_wing_sprite" fileName="game/aws.rttex" textureSize="64,128" frame="0,0"/>

		<Animations>
			<SpriteAnimation name="left_wing_Idle" sprite="left_wing_sprite" autoPlay="true" isLoop="true" animTime="750">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				<Frame>4,0</Frame>
				<Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>7,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="right_wing_Idle" sprite="right_wing_sprite" autoPlay="true" isLoop="true" animTime="750">
				<Frame>0,0</Frame>
				<Frame>1,0</Frame>
				<Frame>2,0</Frame>
				<Frame>3,0</Frame>
				<Frame>4,0</Frame>
				<Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>7,0</Frame>
			</SpriteAnimation>
		</Animations>
		
		<ParticleSystems>

		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="PlayDefaultPunchAudio">true</Set>
                <Set name="ShouldHover">true</Set>
                 <Set name="UserNameOffset">5</Set>
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<OnDrawCustomOutline>
      <AvatarTransform class="RenderData">
        <Set name="saturation">getCurrent</Set>
        <Set name="brightness">getCurrent</Set>
        <Set name="contrast">getCurrent</Set>
      </AvatarTransform>
      <AvatarTransform class="Scale">
        <Set name="targetScale">getCurrent</Set>
      </AvatarTransform>
      <AvatarTransform class="RenderData">
        <Set name="saturation">50</Set>
        <Set name="brightness">1</Set>
        <Set name="contrast">1</Set>
      </AvatarTransform>
      <AvatarOutline duration="1500" startScale="1,1" endScale="1.1,1.1">
		<Colours>
          <Colour>255,213,65,255</Colour>
          <Colour>255,235,163,255</Colour>
        </Colours>
      </AvatarOutline>
      <AvatarTransform class="RenderData">
        <Set name="saturation">reset</Set>
        <Set name="brightness">reset</Set>
        <Set name="contrast">reset</Set>
      </AvatarTransform>
      <AvatarTransform class="Scale">
        <Set name="targetScale">reset</Set>
      </AvatarTransform>
    </OnDrawCustomOutline>
		<Update>
			<StopIf>
				<IsZombified>true</IsZombified>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
			<AvatarTransform class="FootPosition">
				<Set name="foot1dy">0</Set>
				<Set name="foot2dy">0</Set>
				<Set name="foot1y">0</Set>
				<Set name="foot2y">0</Set>
			</AvatarTransform>
		</Update>
        
		<RenderBackpack>
			<SpriteRender name="left_wing_sprite" offset="-30,-10" drawShadow="false"/>
			<SpriteRender name="right_wing_sprite" offset="30,-10" flip="1,0" drawShadow="false"/>
			<StopIf>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
		</RenderBackpack>
		<OnPunchUpdate>
			<AvatarTransform class="Face">
				<Set name="face">MAD</Set>
			</AvatarTransform>
		</OnPunchUpdate>
		<AddClothingParticles>

		</AddClothingParticles>
		<SwitchOffClothingParticles>

		</SwitchOffClothingParticles>
	</RenderRules>
</ItemRenderer>