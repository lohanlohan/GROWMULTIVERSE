<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<Sprite name="md_sprite" fileName="game//borutosikma.rttex" textureSize="128"/>
		<Sprite name="md_punch" fileName="game//borutosikma.rttex" textureSize="128"/>
		<Sprite name="md_eff4" fileName="game//particles_large12.rttex" textureSize="64"/>
		<Sprite name="s_explosion" fileName="game//explosion.rttex" textureSize="256" />
		<StateMachines>
		<StateMachine name="Motion">
			<States>
				<State name="Idle" />
				<State name="Move" />
				<State name="Jump" />
				<State name="Fall" />
				<State name="Punch"/>
				<State name="Respawn"/>
			</States>
			<Transitions>
				<Transition to="Idle" from="Fall|Move|Jump|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
						<IsVariableBool name="isAttacking">false</IsVariableBool>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Move" from="Jump|Fall|Idle|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">true</IsVariableBool>
						<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Jump" from="Idle|Move|Fall|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Fall" from="Jump|Idle|Move|Punch" >
					<Condition type="and">
						<IsVariableBool name="onGround">false</IsVariableBool>
						<IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
						<IsAction operatorType="NotEqual">PUNCH</IsAction>
					</Condition>
				</Transition>
				<Transition to="Punch" from="Idle|Move|Jump|Fall">
					<Condition type="and">
						<IsAction>PUNCH</IsAction>
					</Condition>
				</Transition>
			</Transitions>
		</StateMachine>
		</StateMachines>
		<Animations>
			<SpriteAnimation name="ge_punch_eff" sprite="md_punch" animTime="800" isLoop="false">
	     		<Frame>2,3</Frame>
	     		<Frame>3,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="a_explosion" sprite="s_explosion" animTime="400" isLoop="false">
    			<Frame>0,0</Frame>
       		<Frame>1,0</Frame>
    			<Frame>2,0</Frame>
       		<Frame>3,0</Frame>
    			<Frame>0,1</Frame>
    			<Frame>1,1</Frame>
    			<Frame>2,1</Frame>
    			<Frame>3,1</Frame>
            </SpriteAnimation>
			<SpriteAnimation name="ge_eff2" sprite="md_eff4" animTime="800" isLoop="true" playOnState="Motion.Punch|Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall">
				<Frame>1,5</Frame>
				<Frame>2,5</Frame>
				<Frame>3,5</Frame>
				<Frame>4,5</Frame>
				<Frame>5,5</Frame>
				<Frame>6,5</Frame>
				<Frame>7,5</Frame>
				<Frame>8,5</Frame>
				<Frame>9,5</Frame>
				<Frame>10,5</Frame>
				<Frame>11,5</Frame>
				<Frame>12,5</Frame>
				<Frame>13,5</Frame>
				<Frame>14,5</Frame>
				<Frame>15,5</Frame>
				<Frame>0,6</Frame>
				<Frame>1,6</Frame>
				<Frame>2,6</Frame>
				<Frame>3,6</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Idle_Animation" playOnState="Motion.Idle" sprite="md_sprite" animTime="800" isLoop="true">
   			<Frame>0,0</Frame>
   			<Frame>1,0</Frame>
   			<Frame>2,0</Frame>
   			<Frame>3,0</Frame>
	   		<Frame>4,0</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Punch_Animation" playOnState="Motion.Punch" sprite="md_sprite" animTime="400">
	   		<Frame>0,3</Frame>
	   		<Frame>1,3</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Jump_Animation" playOnState="Motion.Jump" sprite="md_sprite" animTime="600">
				<Frame>0,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Fall_Animation" playOnState="Motion.Fall" sprite="md_sprite" animTime="600">
				<Frame>1,2</Frame>
			</SpriteAnimation>
			<SpriteAnimation name="gigi_Walk_Animation" playOnState="Motion.Move" sprite="md_sprite" animTime="600" isLoop="true">
				<Frame>0,1</Frame>

			</SpriteAnimation>
		</Animations>
		<ParticleSystems>
			<ParticleSystem name="dasdasdas" updateStage="AddClothingParticles" updateState="Motion.Punch">
			<Emitter>
			<Set name="offset">30,-10040</Set>
			<Set name="offsetFacing">true</Set>
			<Random name="emissionInterval" min="6" max="6" />
			<Set name="infParticles">true</Set>
			<Set name="infLifeTime">true</Set>
			<Set name="particlesPerEmission">1</Set>
			</Emitter>
			<Particle>
			<Set name="sprite">md_punch</Set>
			<Set name="frame">0,0</Set>
			<Set name="renderAlignment">CENTER</Set>
			<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
			<Set name="initialScale">1,1</Set>
			<Random name="finalScale" min="5"/>
			<Set name="interpolateScale">false</Set>
			<Set name="lifeTime">0.5</Set>
			<Random name="targetPosOffset" min="-12,-11" max="12,11"/>
			<VectorTo name="initialVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="1" angleOutVar="projectile_angle"/>
			<VectorTo name="finalVelocity" source="targetPos" offset="targetPosOffset" duration="lifeTime" x="1" angleOutVar="projectile_angle"/>
			<Set name="interpolateVelocity">true</Set>
			<OnFinish>
				<ParticleSystemName>ps_explosion</ParticleSystemName>
			</OnFinish>
			</Particle>
		</ParticleSystem>
		<ParticleSystem name="ps_explosion">
			<Emitter>
			<Set name="lifeTime">0.4</Set>
			<Set name="particlesPerEmission">1</Set>
			<Set name="offset">0,0</Set>
			<Set name="particlesToEmit">1</Set>
			<Set name="checkParticleNumToEmit">true</Set>
			</Emitter>
			<Particle>
			<Set name="initialScale">1,1</Set>
			<Set name="sprite">s_explosion</Set>
			<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
			<Set name="lifeTime">0.4</Set>
			</Particle>
		</ParticleSystem>
			
		</ParticleSystems>
		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
				<Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="UserNameOffset">15</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
			</Default>
		</RenderOptions>
	</Data>
	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
			<AvatarSilhouetteRender color="10,10,10,100" offset ="0,48" emissionInterval="0.08" onState="Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<SpriteRender name="md_sprite" offset="0,-10048" drawShadow="true" scale="0.8,0.8" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<SpriteRender name="md_eff4" offset="4,-10060"  tintOverride="51,90,255,255" scale="1,2.2" drawShadow="true" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<SpriteRender name="md_eff4" offset="4,-10060" tintOverride="51,90,255,255" scale="1,2.2" drawShadow="false" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
			<SpriteRender name="md_eff4" offset="4,-10060" tintOverride="51,90,255,255" scale="1,2.2" drawShadow="false" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall|Motion.Punch"/>
		</RenderInFront>
		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
		<OnPunchStart>
		</OnPunchStart>
	</RenderRules>
</ItemRenderer>