        <AddClothingParticles>
            <ParticleSystemUpdate name="MoveTrail_going_right" onState="Facing.Right" onAction="JUMP|FALL|WALK|JUMPDOUBLE"/>
            <ParticleSystemUpdate name="MoveTrail_going_left" onState="Facing.Left" onAction="JUMP|FALL|WALK|JUMPDOUBLE"/>
            <ParticleSystemUpdate name="Spark_MoveTrail_going_right" onState="Facing.Right" onAction="JUMP|FALL|WALK|JUMPDOUBLE"/>
            <ParticleSystemUpdate name="Spark_MoveTrail_going_left" onState="Facing.Left" onAction="JUMP|FALL|WALK|JUMPDOUBLE"/>
        </AddClothingParticles>
        <SwitchOffClothingParticles>
            <ParticleSystemOff name="MoveTrail_going_right"/>
            <ParticleSystemOff name="MoveTrail_going_left"/>
            <ParticleSystemOff name="Spark_MoveTrail_going_right"/>
            <ParticleSystemOff name="Spark_MoveTrail_going_left"/>
        </SwitchOffClothingParticles>
    </RenderRules>
</ItemRenderer>
