<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
    <Data>
        <StateMachines>
            <StateMachine name="Motion">
                <States>
                    <State name="None"/>
                    <State name="Up"/>
                    <State name="Down"/>
                    <State name="Horizontal"/>
                    <State name="Punch"/>
                </States>
                <Transitions>
                    <Transition to="None" from="Punch|Up|Down|Horizontal">
                        <Condition type="and">
                            <IsVariableFloat name="pet.velocity.length" operator="Less" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Up" from="Punch|None|Down|Horizontal">
                        <Condition type="and">
                            <IsVariableFloat name="pet.velocity.y" operator="Less">-0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Down" from="Punch|None|Up|Horizontal">
                        <Condition type="and">
                            <IsVariableFloat name="pet.velocity.y" operator="Greater">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Horizontal" from="Punch|None|Down|Up">
                        <Condition type="and">
                            <IsVariableFloat name="pet.velocity.x" operator="Greater" abs="true">0.1</IsVariableFloat>
                            <IsVariableFloat name="pet.velocity.y" operator="Less" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Punch" from="None|Up|Down|Horizontal">
                        <Condition>
                            <IsAction>PUNCH</IsAction>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
            <StateMachine name="playerState">
                <States>
                    <State name="Idle"/>
                    <State name="Punch"/>
                    <State name="ZombiePunch"/>
                </States>
                <Transitions>
                    <Transition from="ZombiePunch|Punch" to="Idle">
                        <Condition>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition from="ZombiePunch|Idle" to="Punch">
                        <Condition type="and">
                            <IsAction>PUNCH</IsAction>
                            <IsZombified>false</IsZombified>
                        </Condition>
                    </Transition>
                    <Transition from="Idle|Punch" to="ZombiePunch">
                        <Condition type="and">
                            <IsAction>PUNCH</IsAction>
                            <IsZombified>true</IsZombified>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
        </StateMachines>
        <Sprite name="s_hat" fileName="game//mk4_pbc.rttex" textureSize="32" frame="0,0"/>
        <Sprite name="title" fileName="game//mk4_pbct.rttex" textureSize="249,26" frame="0,0"/>
        <Sprite name="title_effect" fileName="game//mk4_particles_large11.rttex" textureSize="64" frame="12,13"/>
        <Sprite name="aura" fileName="game//mk4_particles_large11.rttex" textureSize="64" frame="14,1"/>
        <Sprite name="s_punch" fileName="game//mk4_pbcp.rttex" textureSize="64" frame="0,0"/>
        <Sprite name="albm1" fileName="game//mk4_pbca.rttex" textureSize="128" frame="0,0"/>
        <Sprite name="albm2" fileName="game//mk4_pbca.rttex" textureSize="128" frame="1,0"/>
        <Sprite name="albm3" fileName="game//mk4_pbca.rttex" textureSize="128" frame="2,0"/>
        <Sprite name="albm4" fileName="game//mk4_pbca.rttex" textureSize="128" frame="3,0"/>
        <VariableMap>
            <Set name="titl">0</Set>
        </VariableMap>
        <Animations>
            <CurveAnimationFloat name="title_rotation" autoPlay="true" isLoop="true" animTime="6000">
                <Curve name="titl">
                    <KeyFrame>0, -10</KeyFrame>
                    <KeyFrame>0.2, 0</KeyFrame>
                    <KeyFrame>0.5, 10</KeyFrame>
                    <KeyFrame>0.8, 0</KeyFrame>
                    <KeyFrame>1, -10</KeyFrame>
                </Curve>
            </CurveAnimationFloat>
        </Animations>
        <ParticleSystems>
            <ParticleSystem name="ps_aura">
                <Emitter>
                    <Set name="offset">0, -16</Set>
                    <Set name="offsetFacing">true</Set>
                    <Random name="emissionInterval" min="0.3" max="0.6"/>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle usePlayerFacing="true">
                    <Set name="sprite">aura</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 0</KeyFrame>
                        <KeyFrame>0.1, 0.7</KeyFrame>
                        <KeyFrame>0.5, 0.7</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 1,1</KeyFrame>
                        <KeyFrame>1, 1.2,1.2</KeyFrame>
                    </Curve>
                    <Random name="initialScale" min="0.75, 0.75" max="1.25, 1.25"/>
                    <Random name="lifeTime" min="0.8" max="1.5"/>
                    <Set name="initialVelocity">0, -5</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_title">
                <Emitter>
                    <Set name="offset">0, -58</Set>
                    <Set name="emissionInterval">0.04</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">title</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">0.06</Set>
                    <Set name="initialAngle" source="titl"/>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.25,0.25</KeyFrame>
                        <KeyFrame>1, 0.25,0.25</KeyFrame>
                    </Curve>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_title_effect">
                <Emitter>
                    <Set name="offset">0, -58</Set>
                    <Set name="emissionInterval">1</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="infLifeTime">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">title_effect</Set>
                    <Set name="relativeToEmitter">true</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 0</KeyFrame>
                        <KeyFrame>0.2, 1</KeyFrame>
                        <KeyFrame>0.6, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">1</Set>
                    <Random name="initialScale" min="0.8" max="1"/>
                    <Random name="initialAngle" min="0" max="360"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="ps_punchSmoke">
                <Emitter>
                    <Set name="emissionInterval">1</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="lifeTime">0.5</Set>
                    <Set name="particlesPerEmission">2</Set>
                </Emitter>
                <Particle randomSpriteFrame="true">
                    <Random name="variantId" min="0" max="4"/>
                    <Select name="sprite" input="variantId">
                        <Item>"albm1"</Item>
                        <Item>"albm2"</Item>
                        <Item>"albm3"</Item>
                        <Item>"albm4"</Item>
                    </Select>
                    <Set name="renderAlignment">CENTER</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Random name="offset" min="-8, -8" max="8, 8"/>
                    <Set name="initialAngle">180</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.25, 0.25</KeyFrame>
                        <KeyFrame>1, 0.3, 0.3</KeyFrame>
                    </Curve>
                    <Set name="rotateWithVelocity">true</Set>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="60,80"/>
                    <Set name="lifeTime">0.5</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="punch_particle">
                <Emitter attachment="targetPos">
                    <Set name="offset">0, 0</Set>
                    <Set name="lifeTime">0</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <Set name="particlesToEmit">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">s_punch</Set>
                    <Set name="offset">0, 0</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="lifeTime">0.5</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Curve name="initialScale">
                        <KeyFrame>0, 0.5, 0.5</KeyFrame>
                        <KeyFrame>1, 0.7, 0.7</KeyFrame>
                    </Curve>
                </Particle>
            </ParticleSystem>
        </ParticleSystems>
        <RenderOptions>
            <Default>
                <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
                <Set name="IgnorePunchTypeCheck">true</Set>
                <Set name="IncludeAllActions">true</Set>
            </Default>
        </RenderOptions>
    </Data>
    <RenderRules>
        <RenderInFront>
            <ParticleSystemRender name="ps_title_effect"/>
            <ParticleSystemRender name="ps_title"/>
        </RenderInFront>
        <RenderBehind>
            <ParticleSystemRender name="ps_aura"/>
        </RenderBehind>
        <AddClothingParticles>
            <ParticleSystemUpdate name="ps_title_effect"/>
            <ParticleSystemUpdate name="ps_title"/>
            <ParticleSystemUpdate name="ps_aura"/>
        </AddClothingParticles>
        <RenderHat>
            <SpriteRender name="s_hat" offset="0,-15" alignment="DOWN_CENTER"/>
            <ParticleSystemRender name="ps_punchSmoke" onAction="PUNCH"/>
            <ParticleSystemRender name="punch_particle" onAction="PUNCH"/>
        </RenderHat>
        <OnPunchStart>
            <ParticleSystemUpdate name="punch_particle" onAction="PUNCH"/>
        </OnPunchStart>
        <OnDamagedTile>
            <ParticleSystemUpdate name="ps_punchSmoke"/>
        </OnDamagedTile>
    </RenderRules>
</ItemRenderer>
