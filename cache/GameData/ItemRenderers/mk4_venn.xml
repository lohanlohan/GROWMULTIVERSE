<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
    <Data>
        <Sprite name="s_splash" fileName="game//mk4_venisSword.rttex" textureSize="165,64" frame="10,0"/>
        <Sprite name="s_sword" fileName="game//mk4_venisSword.rttex" textureSize="165,64" frame="0,0"/>
        <Sprite name="s_slash" fileName="game//mk4_venisSword.rttex" textureSize="165,64" frame="9,0"/>
        <Sprite name="fire" fileName="game//venisSword.rttex" textureSize="165,64" frame="17,0"/>
        <Animations>
            <SpriteAnimation name="venisSword" sprite="s_sword" autoPlay="true" animTime="950" isLoop="true">
                <Frame>0,0</Frame>
                <Frame>1,0</Frame>
                <Frame>2,0</Frame>
                <Frame>3,0</Frame>
                <Frame>4,0</Frame>
                <Frame>5,0</Frame>
                <Frame>6,0</Frame>
                <Frame>7,0</Frame>
                <Frame>8,0</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="venis_splash" sprite="s_splash" animTime="400" isLoop="true" playOnAction="PUNCH">
                <Frame>10,0</Frame>
                <Frame>11,0</Frame>
                <Frame>12,0</Frame>
                <Frame>13,0</Frame>
                <Frame>14,0</Frame>
                <Frame>15,0</Frame>
            </SpriteAnimation>
        </Animations>
        <TileStampData>
            <Set name="FileName">game/galaxyTile.rttex</Set>
            <Set name="EndFrame">5,0</Set>
            <Set name="FrameCount">6</Set>
        </TileStampData>
        <ParticleSystems>
            <ParticleSystem name="punch_projectile">
                <Emitter>
                    <Set name="offset">14,-18</Set>
                    <Set name="emissionInterval">0.25</Set>
                    <Set name="lifeTime">0.3</Set>
                    <Set name="particlesPerEmission">1</Set>
                    <Set name="particlesToEmit">1</Set>
                </Emitter>
                <Particle alternateSpriteFrameWithPunch="true">
                    <Random name="variantId" min="0" max="2"/>
                    <Select name="sprite" input="variantId">
                        <Item>"s_slash"</Item>
                    </Select>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="inSpecificOrder">true</Set>
                    <Set name="lifeTime">0.4</Set>
                    <Set name="rotateWithVelocity">true</Set>
                    <Set name="interpolateAlpha">false</Set>
                    <Set name="initialScale">0.8,0.8</Set>
                    <Set name="initialAlpha">1</Set>
                    <Set name="finalAlpha">1</Set>
                    <Set name="interpolateVelocity">true</Set>
                    <VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="0.8" angle="0"/>
                    <VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="0.8" angle="0"/>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="tile_break_particle" updateStage="OnDestroyedTile">
                <Emitter>
                    <Set name="particlesPerEmission">50</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">fire</Set>
                    <Set name="rotateWithVelocity">true</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Set name="useGravity">true</Set>
                    <Curve name="initialScale">
                        <KeyFrame>0.8, 0.8, 0.8</KeyFrame>
                        <KeyFrame>1, 1, 1</KeyFrame>
                    </Curve>
                    <Set name="lifeTime">1</Set>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="20,34"/>
                    <Set name="gravityVector">15, 30</Set>
                </Particle>
            </ParticleSystem>
            <ParticleSystem name="hitSpark_particle">
                <Emitter>
                    <Set name="lifeTime">1</Set>
                    <Set name="particlesToEmit">2</Set>
                    <Set name="particlesPerEmission">25</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">fire</Set>
                    <Set name="blendingMode">ADDITIVE</Set>
                    <Set name="lifeTime">1</Set>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="20,25"/>
                    <Curve name="initialScale">
                        <KeyFrame>0, 1, 1</KeyFrame>
                        <KeyFrame>1, 0.25, 0.25</KeyFrame>
                    </Curve>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.2, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Random name="posOffset" min="-2,-2" max="2,2"/>
                    <Random name="initialRotationRate" min="-10" max="60"/>
                </Particle>
            </ParticleSystem>
        </ParticleSystems>
        <RenderOptions>
            <Default>
                <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
                <Set name="HideAngelOnDeath">true</Set>
                <Set name="RenderFrontArmInTheFront">true</Set>
            </Default>
        </RenderOptions>
    </Data>
    <RenderRules>
        <RenderInFront>
            <SpriteRender name="s_splash" offset="70,-5" scale="1.7,1.6" alignment="CENTER" rotateOffset="true" drawShadow="false" onAction="PUNCH"/>
            <ParticleSystemRender name="punch_projectile" scale="0.3,0.3" onAction="PUNCH"/>
        </RenderInFront>
        <RenderHandItem>
            <SpriteRender name="s_sword" scale="0.4,0.4" rotateOffset="true" offset="20,7" alignment="CENTER"/>
        </RenderHandItem>
        <OnPunchStart>
            <ParticleSystemUpdate name="punch_projectile"/>
        </OnPunchStart>
        <OnPunchUpdate>
            <StopIf>
                <IsZombified>true</IsZombified>
            </StopIf>
            <AvatarTransform class="Face">
                <Set name="face">MAD</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle">
                <Set name="armName">arm2Angle</Set>
                <Set name="armAngle">1200</Set>
                <Set name="isAdditive">true</Set>
            </AvatarTransform>
            <AvatarTransform class="ArmAngle">
                <Set name="armName">arm1Angle</Set>
                <Set name="armAngle">0</Set>
            </AvatarTransform>
        </OnPunchUpdate>
        <OnDestroyedTile>
            <ParticleSystemUpdate name="tile_break_particle"/>
        </OnDestroyedTile>
        <OnDamagedTile>
            <ParticleSystemUpdate name="hitSpark_particle"/>
        </OnDamagedTile>
        <SwitchOffClothingParticles>
            <ParticleSystemOff name="punch_projectile"/>
            <ParticleSystemOff name="tile_break_particle"/>
            <ParticleSystemOff name="hitSpark_particle"/>
        </SwitchOffClothingParticles>
    </RenderRules>
</ItemRenderer>
