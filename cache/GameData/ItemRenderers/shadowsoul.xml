<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
	<Data>
		<StateMachines>
<StateMachine name="playerState">
	<States>
		<State name="StartIdle"/>
		<State name="Idle"/>
		<State name="EndIdle"/>
		<State name="Move"/>
		<State name="Fall"/>
		<State name="Jump"/>
		<State name="DoubleJump"/>
		<State name="SpiritGuide"/>
	</States>

	<Transitions>
		<Transition from="SpiritGuide|Jump|Fall|Move|DoubleJump|EndIdle" to="StartIdle">
			<Condition type="and">
				<IsVariableBool name="onGround">true</IsVariableBool>
				<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
			</Condition>
		</Transition>

		<Transition from="StartIdle" to="Idle">
			<Condition>
				<IsAnimationFinished>a_startIdle</IsAnimationFinished>
			</Condition>
		</Transition>

		<Transition from="Idle|StartIdle" to="EndIdle">
			<Condition type="or">
				<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
				<IsVariableBool name="onGround">false</IsVariableBool>
			</Condition>
		</Transition>

		<Transition from="EndIdle" to="Idle">
			<Condition type="and">
				<IsAnimationFinished>a_endIdle</IsAnimationFinished>
				<IsVariableBool name="onGround">true</IsVariableBool>
				<IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
			</Condition>
		</Transition>

		<Transition from="Idle|StartIdle|EndIdle|Jump|Fall|DoubleJump|SpiritGuide" to="Move">
			<Condition type="and">
				<IsVariableBool name="onGround">true</IsVariableBool>
				<IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
				<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
			</Condition>
		</Transition>

		<Transition from="Idle|StartIdle|EndIdle|Move|Jump|Fall|DoubleJump" to="SpiritGuide">
			<Condition type="and">
				<IsWearing slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
				<IsVariableFloat name="speed.length" operator="Greater" abs="true">0</IsVariableFloat>
			</Condition>
		</Transition>

		<Transition from="Idle|StartIdle|EndIdle|Move|Fall|DoubleJump|SpiritGuide" to="Jump">
			<Condition type="and">
				<IsVariableBool name="onGround">false</IsVariableBool>
				<IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
				<IsWearing operatorType="NotEqual" slot="CHESTITEM">ITEM_ID_HAUNTED</IsWearing>
			</Condition>
		</Transition>

		<Transition from="Jump|Fall" to="DoubleJump">
			<Condition>
				<IsAction>JUMPDOUBLE</IsAction>
			</Condition>
		</Transition>

		<Transition from="Idle|StartIdle|EndIdle|Move|Jump|DoubleJump|SpiritGuide" to="Fall">
			<Condition type="and">
				<IsVariableBool name="onGround">false</IsVariableBool>
				<IsVariableFloat name="speed.y" operator="Greater">0.01</IsVariableFloat>
			</Condition>
		</Transition>
	</Transitions>
</StateMachine>

			<StateMachine name="Facing">
				<States>
					<State name="Left"/>
					<State name="Right"/>
				</States>
				<Transitions>
					<Transition to="Left" from="Right">
						<Condition>
							<IsFacingLeft>true</IsFacingLeft>
						</Condition>
					</Transition>
					<Transition to="Right" from="Left">
						<Condition>
							<IsFacingLeft>false</IsFacingLeft>
						</Condition>
					</Transition>
				</Transitions>
			</StateMachine>
		</StateMachines>

		<Sprite name="s_Soul" fileName="game/enigma_particles6.rttex" textureSize="64"/>
        <Sprite name="s_SoulEmpty" fileName="game/particles_large12.rttex" textureSize="64" frame="15,11"/>
        <Sprite name="s_SoulAvatarHorns" fileName="game/particles_large11.rttex" textureSize="64"/>
        <Sprite name="s_SoulAvatarSmoke" fileName="game/particles_large11.rttex" textureSize="64"/>
        <Sprite name="s_SoulEnterExplosion64" fileName="game/particles_large11.rttex" textureSize="64"/>
         <Sprite name="s_SoulEnterExplosion32" fileName="game/particles11.rttex" textureSize="32"/>
        <Sprite name="s_SoulRun" fileName="game/particles11.rttex" textureSize="32" frame="2,10"/>
        <Sprite name="s_SoulPunch" fileName="game/particles11.rttex" textureSize="32" frame="4,9"/>

		<Animations>
			<SpriteAnimation name="A_Run"  sprite="s_Soul" isLoop="true" animTime="800" playOnState="playerState.Move">
       			<Frame>0,0</Frame>
                <Frame>1,0</Frame>
				<Frame>2,0</Frame>
                 <Frame>3,0</Frame>
				<Frame>4,0</Frame>
                 <Frame>5,0</Frame>
				<Frame>6,0</Frame>
				<Frame>7,0</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="A_Jump"  sprite="s_Soul" isLoop="true" animTime="250" playOnState="playerState.Jump|playerState.DoubleJump">
       			<Frame>10,0</Frame>
			</SpriteAnimation>

			<SpriteAnimation name="A_Fall"  sprite="s_Soul" isLoop="true" animTime="200" playOnState="playerState.Fall">
       			<Frame>8,0</Frame>
                <Frame>9,0</Frame>
			</SpriteAnimation>

            <SpriteAnimation name="a_startIdle" sprite="s_SoulEmpty" isLoop="false" animTime="50">
                <Frames>15,11</Frames>
            </SpriteAnimation>

            <SpriteAnimation name="A_EnterExplosion" sprite="s_SoulEnterExplosion32">
                <Frame>1,10</Frame>
                <Frame>2,10</Frame>
                <Frame>3,10</Frame>
                <Frame>4,10</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="A_HornedAvatar" sprite="s_SoulAvatarHorns">
                <Frame>13,1</Frame>
                <Frame>14,1</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="A_AvatarSmoke" sprite="s_SoulAvatarSmoke">
                <Frame>13,2</Frame>
                <Frame>14,2</Frame>
            </SpriteAnimation>
            <SpriteAnimation name="A_AvatarExplosion64" sprite="s_SoulEnterExplosion64">
                <Frame>13,3</Frame>
                <Frame>14,3</Frame>
            </SpriteAnimation>
		</Animations>

	<ParticleSystems>
      <ParticleSystem name="MoveTrail_going_right">
        <Emitter usePlayerFacing="true">
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="emissionInterval">0.018</Set>
          <Set name="particlesPerEmission">1</Set>
		  <Set name="offsetFacing">true</Set>
          <Random name="offset" min="14, 5" max="-14, -35"/>
        </Emitter>
        <Particle>
          <Set name="sprite">s_SoulRun</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">1.15</Set>
          <Set name="interpolateScale">true</Set>
         <Set name="initialScale">0.6,0.6</Set>
          <Set name="finalScale">0,0</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 1</KeyFrame>
          </Curve>
          <Random name= "initialVelocity" min="-15,0" max="-50,0"/>
        </Particle>
      </ParticleSystem>

      <ParticleSystem name="MoveTrail_going_left">
        <Emitter usePlayerFacing="true">
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="emissionInterval">0.018</Set>
          <Set name="particlesPerEmission">1</Set>
		  <Set name="offsetFacing">true</Set>
          <Random name="offset" min="14, 5" max="-14, -35"/>
        </Emitter>
        <Particle>
          <Set name="sprite">s_SoulRun</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="lifeTime">1.15</Set>
          <Set name="interpolateScale">true</Set>
         <Set name="initialScale">0.6,0.6</Set>
          <Set name="finalScale">0,0</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame>
            <KeyFrame>1, 1</KeyFrame>
          </Curve>
          <Random name= "initialVelocity" min="15,0" max="50,0"/>
        </Particle>
      </ParticleSystem>

			<ParticleSystem name="Ps_Horns">
				<Emitter>
					<Set name="offset">0, -15</Set>
					<Set name="offsetFacing">true</Set>
					<Set name="emissionInterval">0.5</Set>
					<Set name="infParticles">true</Set>
					<Set name="infLifeTime">true</Set>
					<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_SoulAvatarHorns</Set>
					<Set name="relativeToEmitter">true</Set>
					<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="isBackgroundParticle">true</Set>
					<Set name="interpolateAlpha">true</Set>
					<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.8, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1.01, 1.01</KeyFrame>
                        <KeyFrame>0.5, 1.08, 1.08</KeyFrame>
						<KeyFrame>1, 1.25, 1.25</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.5</Set>
				</Particle>
			</ParticleSystem>
			
		<ParticleSystem name="Ps_Smoke">
			<Emitter>
				<Set name="offset">0, -15</Set>
				<Set name="offsetFacing">true</Set>
				<Set name="emissionInterval">1</Set>
				<Set name="infParticles">true</Set>
				<Set name="infLifeTime">true</Set>
				<Set name="particlesPerEmission">2</Set>
			</Emitter>
			<Particle randomSpriteFrame="true">
				<Set name="sprite">s_SoulAvatarSmoke</Set>
				<Set name="relativeToEmitter">true</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                <Set name="isBackgroundParticle">true</Set>
				<Set name="interpolateAlpha">true</Set>
				<Curve name="initialAlpha">
					<KeyFrame>0, 1</KeyFrame>
					<KeyFrame>1, 1</KeyFrame>
				</Curve>
				<Curve name="initialScale">
					<KeyFrame>0, 0.3, 0.3</KeyFrame>
					<KeyFrame>1, 1.3, 1.3</KeyFrame>
				</Curve>
				<Set name="lifeTime">2</Set>
			</Particle>
		</ParticleSystem>

			<ParticleSystem name="ps_EnterExplosion32">
				<Emitter>
				<Set name="offset">0, -15</Set>
				<Set name="offsetFacing">true</Set>
				<Set name="emissionInterval">99</Set>
				<Set name="infParticles">false</Set>
				<Set name="infLifeTime">false</Set>
                <Set name="lifeTime">0.01</Set>
				<Set name="particlesPerEmission">5</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_SoulEnterExplosion32</Set>
          			<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          			<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
              			<KeyFrame>0.75, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 1, 1</KeyFrame>
						<KeyFrame>1, 1, 1</KeyFrame>
					</Curve>
					<Random name="lifeTime" min="1" max="1.25"/>
                    <Set name="rotateWithVelocity">true</Set>
					<RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="40,85"/>
				</Particle>
			</ParticleSystem>

			<ParticleSystem name="ps_EnterExplosion64">
				<Emitter>
				<Set name="offset">0, -15</Set>
				<Set name="offsetFacing">true</Set>
				<Set name="emissionInterval">99</Set>
				<Set name="infParticles">false</Set>
				<Set name="infLifeTime">false</Set>
                <Set name="lifeTime">0.01</Set>
				<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_SoulEnterExplosion64</Set>
          			<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          			<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.5, 0.5</KeyFrame>
						<KeyFrame>1, 1.5, 1.5</KeyFrame>
					</Curve>
					<Set name="lifeTime">0.5</Set>
				</Particle>
			</ParticleSystem>

		<ParticleSystem name="ps_PunchEffect">
			<Emitter>
				<Set name="offset">20,-12</Set>
				<Set name="emissionInterval">0.25</Set>
				<Set name="lifeTime">0.25</Set>
				<Set name="particlesPerEmission">1</Set>
				<Set name="particlesToEmit">1</Set>
			</Emitter>
			<Particle>
				<Set name="sprite">s_SoulPunch</Set>
				<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
				<Set name="lifeTime">0.4</Set>
				<Set name="rotateWithVelocity">true</Set>
				<Set name="interpolateAlpha">true</Set>
				<Set name="initialAlpha">0.75</Set>
				<Set name="finalAlpha">1</Set>
				<Set name="interpolateVelocity">true</Set>
				<Curve name="initialScale">
            				<KeyFrame>0, 1,1</KeyFrame>
            				<KeyFrame>1, 1,1</KeyFrame>
          				</Curve>
				<VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
				<VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1" angle="0"/>
			</Particle>
		</ParticleSystem>

			<ParticleSystem name="ps_DamagedTile">
				<Emitter>
				<Set name="offset">0, 0</Set>
				<Set name="infParticles">false</Set>
				<Set name="infLifeTime">false</Set>
                <Set name="lifeTime">0.01</Set>
				<Set name="particlesPerEmission">1</Set>
				</Emitter>
				<Particle randomSpriteFrame="true">
					<Set name="sprite">s_SoulEnterExplosion64</Set>
          			<Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          			<Curve name="initialAlpha">
						<KeyFrame>0, 1</KeyFrame>
						<KeyFrame>1, 0</KeyFrame>
					</Curve>
					<Curve name="initialScale">
						<KeyFrame>0, 0.5, 0.5</KeyFrame>
						<KeyFrame>1, 1.5, 1.5</KeyFrame>
					</Curve>
					<Set name="lifeTime">1.5</Set>
				</Particle>
			</ParticleSystem>
	</ParticleSystems>

		<RenderOptions>
			<Default>
                <Set name="IncludeAllActions">true</Set>
        		<Set name="PunchSoundOverride">BACKPACK</Set>
        		<Set name="PlayDefaultPunchAudio">false</Set>
        		<Set name="IgnoreDefaultDamagedTileEffect">true</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
        <RenderInFront>
            <SpriteRender name="s_Soul" offset="0,-25" scale="1.2,1.2" blend="PREMULTIPLIED_ALPHA" drawShadow="false" alignment="CENTER" onState="playerState.Move|playerState.Jump|playerState.DoubleJump|playerState.Fall"/>
            <SpriteRender name="s_SoulEmpty" offset="0,0" blend="PREMULTIPLIED_ALPHA" drawShadow="false" alignment="CENTER" onState="playerState.Idle"/>
		<Group>
			<ParticleSystemRender name="ps_EnterExplosion32" onState="playerState.StartIdle|playerState.EndIdle"/>
			<ParticleSystemRender name="ps_EnterExplosion64" onState="playerState.StartIdle|playerState.EndIdle"/>
      </Group>
        </RenderInFront>
	<RenderBehind>
		<Group>
			<ParticleSystemRender name="Ps_Horns" onState="playerState.Idle|playerState.Punch"/>
			<ParticleSystemRender name="Ps_Smoke" onState="playerState.Idle|playerState.Punch"/>
      </Group>
	</RenderBehind>
	<Update>
			<AvatarTransform class="ArmAngle" onState="playerState.Move|playerState.Jump|playerState.DoubleJump|playerState.Fall">
				<Set name="armName">arm2Angle</Set>
                <Set name="armAngle">90</Set>
			</AvatarTransform>
			<AvatarTransform class="ArmAngle" onState="playerState.Move|playerState.Jump|playerState.DoubleJump|playerState.Fall">
				<Set name="armName">arm1Angle</Set>
                <Set name="armAngle">90</Set>
			</AvatarTransform>
			<AvatarTransform class="FootPosition" onState="playerState.Move|playerState.Jump|playerState.DoubleJump|playerState.Fall">
				<Set name="foot1dy">0</Set>
				<Set name="foot2dy">0</Set>
				<Set name="foot1y">0</Set>
				<Set name="foot2y">0</Set>
			</AvatarTransform>
	</Update>
		<OnPunchUpdate>
            <AvatarTransform class="Emotion">
                <Set name="emotion">ANGRY</Set>
            </AvatarTransform>
			<AvatarTransform class="ArmAngle">
				<Set name="armName">arm2Angle</Set>
                <Set name="pointTowardsPunchTarget">true</Set>
			</AvatarTransform>
		</OnPunchUpdate>

		<AddClothingParticles>
			<ParticleSystemUpdate name="MoveTrail_going_right" onState="Facing.Right" onAction="JUMP|FALL|WALK|JUMPDOUBLE"/>
            <ParticleSystemUpdate name="MoveTrail_going_left" onState="Facing.Left" onAction="JUMP|FALL|WALK|JUMPDOUBLE"/>
            <ParticleSystemUpdate name="Ps_Horns" onState="playerState.Idle|playerState.Punch"/>
            <ParticleSystemUpdate name="Ps_Smoke" onState="playerState.Idle|playerState.Punch"/>
            <ParticleSystemUpdate name="ps_EnterExplosion32" onState="playerState.StartIdle|playerState.EndIdle"/>
            <ParticleSystemUpdate name="ps_EnterExplosion64" onState="playerState.StartIdle|playerState.EndIdle"/>
		</AddClothingParticles>

		<SwitchOffClothingParticles>
			<ParticleSystemOff name="MoveTrail_going_right"/>
            <ParticleSystemOff name="MoveTrail_going_left"/>
			<ParticleSystemOff name="Ps_Horns"/>
            <ParticleSystemOff name="Ps_Smoke"/>
			<ParticleSystemOff name="ps_EnterExplosion32"/>
            <ParticleSystemOff name="ps_EnterExplosion64"/>
		</SwitchOffClothingParticles>

	<OnPunchStart>
		<ParticleSystemUpdate name="ps_PunchEffect"/>
	</OnPunchStart>

    	<OnDamagedTile>
			<ParticleSystemUpdate name="ps_DamagedTile"/>
		</OnDamagedTile>
	</RenderRules>
</ItemRenderer>