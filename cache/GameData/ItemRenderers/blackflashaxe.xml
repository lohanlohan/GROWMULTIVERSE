<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer>
  <Data>
    <StateMachines>
      <StateMachine name="playerState">
        <States>
          <State name="Idle" />
          <State name="Move" />
          <State name="Punch" />
          <State name="Jump" />
          <State name="Fall" />
        </States>
        <Transitions>
          <Transition to="Idle" from="Move|Punch|Jump|Fall">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Move" from="Idle|Punch|Jump|Fall">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Punch" from="Idle|Move|Jump|Fall">
            <Condition>
              <IsAction>PUNCH</IsAction>
            </Condition>
          </Transition>  
          <Transition to="Jump" from="Idle|Move|Fall|Punch">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>
          <Transition to="Fall" from="Idle|Move|Jump|Punch">
            <Condition type="and">
              <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
              <IsAction operatorType="NotEqual">PUNCH</IsAction>
            </Condition>
          </Transition>  
        </Transitions>
      </StateMachine>
    </StateMachines>
    
    <Sprite name="axe" fileName="game/blackflashaxe.rttex" textureSize="32" frame="0,0"/>
    <Sprite name="axe_spark" fileName="game/blackflashaxe.rttex" textureSize="32" frame="1,0"/>
    <Sprite name="axe_glow" fileName="game/blackflashaxe.rttex" textureSize="32" frame="2,0"/>
    <Sprite name="spark" fileName="game/blackspark.rttex" textureSize="64,32" frame="0,0"/>
    <Sprite name="shadow" fileName="game/shadows.rttex" textureSize="32" frame="0,0"/>

    <Animations>
      <SpriteCurveAnimation name="glow" isLoop="true" autoPlay="true" sprite="axe_glow" animTime="2000">
        <Curve name="alpha">
          <KeyFrame>0.f, 0.f</KeyFrame>
          <KeyFrame>0.2f, 0.f</KeyFrame>
          <KeyFrame>0.4f, 1.f</KeyFrame>
          <KeyFrame>0.8f, 1.f</KeyFrame>
          <KeyFrame>1.f, 0.f</KeyFrame>
        </Curve>
      </SpriteCurveAnimation>  
      <SpriteAnimation name="ances" sprite="spark" animTime="600" isLoop="true" autoPlay="true">
        <Frame>0,0</Frame><Frame>1,0</Frame><Frame>2,0</Frame><Frame>3,0</Frame>
        <Frame>4,0</Frame><Frame>5,0</Frame><Frame>6,0</Frame><Frame>7,0</Frame>
        <Frame>8,0</Frame><Frame>9,0</Frame><Frame>10,0</Frame>
      </SpriteAnimation>
    </Animations>  

    <TileStampData>
      <Set name="FileName">game/flashTile.rttex</Set>
      <Set name="EndFrame">5,0</Set>
      <Set name="FrameCount">6</Set>
    </TileStampData>

    <ParticleSystems>
      <ParticleSystem name="flash" updateStage="AddClothingParticles">
        <Emitter>
          <Set name="offset">0,0</Set>
          <Set name="offsetFacing">true</Set>
          <Random name="emissionInterval" min="0.1" max="0.4"/>
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Set name="particlesPerEmission">1</Set>
        </Emitter>
        <Particle usePlayerFacing="true">
          <Set name="sprite">axe_spark</Set>
          <Random name="offset" min="-1.7,-4.3" max="2,-7"/>
          <Set name="relativeToEmitter">true</Set>
          <Set name="inSpecificOrder">true</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Curve name="initialAlpha">
            <KeyFrame>0, 0</KeyFrame><KeyFrame>0.1, 1</KeyFrame>
            <KeyFrame>0.5, 1</KeyFrame><KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Random name="initialScale" min="0.4, 0.4" max="0.5, 0.5"/>
          <Random name="lifeTime" min="0.4" max="0.7"/>
          <Set name="initialVelocity">0, -10</Set>
        </Particle>
      </ParticleSystem>

      <ParticleSystem name="hitSpark_particle">
        <Emitter>
          <Set name="lifeTime">1</Set>
          <Set name="particlesToEmit">2</Set>
          <Set name="particlesPerEmission">25</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">axe_spark</Set>
          <Set name="blendingMode">ADDITIVE</Set>
          <Set name="lifeTime">1</Set>
          <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="20,25"/>
          <Curve name="initialScale">
            <KeyFrame>0, 1, 1</KeyFrame><KeyFrame>1, 0.25, 0.25</KeyFrame>
          </Curve>
          <Curve name="initialAlpha">
            <KeyFrame>0, 1</KeyFrame><KeyFrame>0.2, 1</KeyFrame><KeyFrame>1, 0</KeyFrame>
          </Curve>
          <Random name="posOffset" min="-2,-2" max="2,2"/>
          <Random name="initialRotationRate" min="-10" max="60"/>
        </Particle>
      </ParticleSystem>

      <ParticleSystem name="shadow_trail">
        <Emitter>
          <Set name="offset">0,-12</Set>
          <Set name="infParticles">true</Set>
          <Set name="infLifeTime">true</Set>
          <Random name="emissionInterval" min="0.05" max="0.1"/>
          <Set name="particlesPerEmission">1</Set>
        </Emitter>
        <Particle>
          <Set name="sprite">shadow</Set>
          <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
          <Set name="relativeToEmitter">true</Set>
          <Set name="lifeTime">0.5</Set>
          <Set name="initialAlpha">0.3</Set>
          <Set name="finalAlpha">0</Set>
          <Set name="interpolateAlpha">true</Set>
          <Set name="initialScale">1,0.3</Set>
          <Set name="finalScale">1.2,0.4</Set>
          <Set name="interpolateScale">true</Set>
        </Particle>
      </ParticleSystem>
    </ParticleSystems>

    <RenderOptions>
      <Default>
        <Set name="IgnoreDefaultDamagedTileEffect">true</Set>
        <Set name="IgnoreDefaultDestroyedTileEffect">true</Set>
        <Set name="DefaultRenderMannequinHandItem">true</Set>
      </Default>
    </RenderOptions>
  </Data>

  <RenderRules>
    <RenderHandItem>
      <SpriteRender name="spark" rotateOffset="true" offset="0,7" scale="0.4,0.5" alignment="DOWN_CENTER"/>
      <SpriteRender name="axe" rotateOffset="true" offset="0,32" alignment="DOWN_CENTER"/>
      <SpriteRender name="axe_glow" rotateOffset="true" offset="0,16" alignment="CENTER" blendingMode="PREMULTIPLIED_ALPHA"/>
      <SpriteRender name="flash" rotateOffset="true" offset="3,-3" scale="0.6,0.4" alignment="DOWN_CENTER"/>
      <ParticleSystemRender name="flash" rotateOffset="true" offset="3,-3" scale="0.6,0.4" alignment="DOWN_CENTER"/>
    </RenderHandItem>

    <OnPunchUpdate>
      <AvatarTransform class="Face">
        <Set name="face">MAD</Set>
      </AvatarTransform>
      <AvatarTransform class="ArmAngle">
        <Set name="armName">arm2Angle</Set>
        <Set name="armAngle">800</Set>
        <Set name="isAdditive">true</Set>
        <Set name="pointTowardsPunchTarget">false</Set>
      </AvatarTransform>
      <AvatarTransform class="ArmAngle" onState="playerState.Punch">
        <Set name="armName">arm2Angle</Set>
        <Set name="armAngle">500</Set>
        <Set name="isAdditive">true</Set>
        <Set name="pointTowardsPunchTarget">false</Set>
      </AvatarTransform>
    </OnPunchUpdate>

    <OnDestroyedTile>
      <ParticleSystemUpdate name="hitSpark_particle"/>
    </OnDestroyedTile>

    <OnDamagedTile>
      <ParticleSystemUpdate name="hitSpark_particle"/>
    </OnDamagedTile>

    <AddClothingParticles>
      <ParticleSystemUpdate name="flash" onAction="IDLE|MOVE" drawShadow="false"/>
      <ParticleSystemUpdate name="shadow_trail" onState="playerState.Move"/>
    </AddClothingParticles>

    <SwitchOffClothingParticles>
      <ParticleSystemUpdate name="flash"/>
      <ParticleSystemOff name="shadow_trail"/>
    </SwitchOffClothingParticles>
  </RenderRules>
</ItemRenderer>
