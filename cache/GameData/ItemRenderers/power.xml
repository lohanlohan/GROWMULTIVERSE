<?xml version="1.0" encoding="utf-8"?>
<ItemRenderer name="Power_Stable">
	<Data>
        <Sprite name="power_main" fileName="game//power.rttex" textureSize="200,200"/>
        <Sprite name="p_power" fileName="game//power.rttex" textureSize="200,200" frame="0,2"/>
        <Sprite name="death" fileName="game//power.rttex" textureSize="200,200" frame="4,2"/> 
        
        <Sprite name="p_effect" fileName="game//power_p.rttex" textureSize="100,100" frame="0,0"/>

		<StateMachines>
            <StateMachine name="Motion">
                <States>
                    <State name="Idle" />
                    <State name="Move" />
                    <State name="Jump" />
                    <State name="Fall" />
                    <State name="Punch"/>
                    <State name="Respawn"/>
                </States>
                <Transitions>
                    <Transition to="Idle" from="Fall|Move|Jump|Punch" >
                        <Condition type="and">
                            <IsVariableBool name="onGround">true</IsVariableBool>
                            <IsVariableFloat name="speed.length" operator="Less" abs="true">0.1</IsVariableFloat>
                            <IsVariableBool name="isAttacking">false</IsVariableBool>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Move" from="Jump|Fall|Idle|Punch" >
                        <Condition type="and">
                            <IsVariableBool name="onGround">true</IsVariableBool>
                            <IsVariableFloat name="speed.length" operator="Greater" abs="true">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Jump" from="Idle|Move|Fall|Punch" >
                        <Condition type="and">
                            <IsVariableBool name="onGround">false</IsVariableBool>
                            <IsVariableFloat name="speed.y" operator="Less">-0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Fall" from="Jump|Idle|Move|Punch" >
                        <Condition type="and">
                            <IsVariableBool name="onGround">false</IsVariableBool>
                            <IsVariableFloat name="speed.y" operator="Greater">0.1</IsVariableFloat>
                            <IsAction operatorType="NotEqual">PUNCH</IsAction>
                        </Condition>
                    </Transition>
                    <Transition to="Punch" from="Idle|Move|Jump|Fall">
                        <Condition type="and">
                            <IsAction>PUNCH</IsAction>
                        </Condition>
                    </Transition>
                </Transitions>
            </StateMachine>
		</StateMachines>

		<Animations>
            <SpriteAnimation name="idle" playOnState="Motion.Idle" sprite="power_main" animTime="1000" isLoop="true">
                <Frame>0,0</Frame>
                <Frame>1,0</Frame>
                <Frame>2,0</Frame>
			</SpriteAnimation>

            <SpriteAnimation name="punch" playOnState="Motion.Punch" sprite="p_power" animTime="600">
                <Frame>0,2</Frame>
                <Frame>1,2</Frame>
                <Frame>2,2</Frame>
			</SpriteAnimation>

            <SpriteAnimation name="jump" playOnState="Motion.Jump" sprite="power_main" animTime="1200">
				<Frame>3,2</Frame>
			</SpriteAnimation>

            <SpriteAnimation name="fall" playOnState="Motion.Fall" sprite="power_main" animTime="1200">
				<Frame>4,2</Frame>
			</SpriteAnimation>

            <SpriteAnimation name="walk" playOnState="Motion.Move" sprite="power_main" animTime="2000" isLoop="true">
                <Frame>0,1</Frame>
                <Frame>1,1</Frame>
                <Frame>2,1</Frame>
                <Frame>3,1</Frame>
                <Frame>4,1</Frame>
                <Frame>5,1</Frame>
			</SpriteAnimation>
            
            <SpriteAnimation name="deathAnim" sprite="death" animTime="1000" isLoop="false" playOnAction="DIE">
                <Frame>4,2</Frame>
            </SpriteAnimation>
		</Animations>

		<ParticleSystems>
            <ParticleSystem name="DeathParticle">
                <Emitter>
                    <Set name="lifeTime">1.5</Set>
                    <Set name="emissionInterval">0.3</Set>
                    <Set name="infParticles">true</Set>
                    <Set name="particlesPerEmission">6</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">death</Set>
                    <Set name="renderAlignment">CENTER</Set>
                    <Set name="blendingMode">PREMULTIPLIED_ALPHA</Set>
                    <Set name="useGravity">true</Set>
                    <Set name="interpolateScale">true</Set>
                    <Set name="initialScale">1.5,1.5</Set>
                    <Random name="finalScale" min="0.1, 0.1" max="0.3, 0.3"/>
                    <Set name="lifeTime">1.5</Set>
                    <RandomRadial name="initialVelocity" angleRange="0,360" radiusRange="80,100"/>
                    <Set name="gravityVector">0, 100</Set>
                </Particle>
            </ParticleSystem>

            <ParticleSystem name="PunchBurst" updateStage="OnPunchStart">
                <Emitter>
                    <Set name="offset">35,-10024</Set>
                    <Set name="emissionInterval">0.1</Set>
                    <Set name="particlesToEmit">1</Set>
                    <Set name="particlesPerEmission">1</Set>
                </Emitter>
                <Particle>
                    <Set name="sprite">p_effect</Set>
                    <Set name="blendingMode">ADDITIVE</Set>
                    <Set name="lifeTime">0.4</Set>
                    
                    <VectorTo name="initialVelocity" source="targetPos" duration="lifeTime" x="1.5" angle="0"/>
                    <VectorTo name="finalVelocity" source="targetPos" duration="lifeTime" x="1.5" angle="0"/>
                    
                    <Set name="rotateWithVelocity">true</Set>
                    <Curve name="initialAlpha">
                        <KeyFrame>0, 1</KeyFrame>
                        <KeyFrame>0.5, 1</KeyFrame>
                        <KeyFrame>1, 0</KeyFrame>
                    </Curve>
                    <Set name="initialScale">1,1</Set>
                </Particle>
            </ParticleSystem>
		</ParticleSystems>

		<RenderOptions>
			<Default>
				<Set name="JumpEndStateRange">100</Set>
                <Set name="ClothingOffsetFromShoes">10000</Set>
				<Set name="IsRidingBird">true</Set>
				<Set name="IsVehicle">true</Set>
				<Set name="UserNameOffset">30</Set>
				<Set name="RenderShoesWithMermaidTail">true</Set>
				<Set name="ShoesHidesBodyLegs">true</Set>
				<Set name="IsToRenderPants">false</Set>
                <Set name="HideAvatarOnDeath">true</Set>
                <Set name="IncludeAllActions">true</Set>
			</Default>
		</RenderOptions>
	</Data>

	<RenderRules>
		<RenderInFront>
			<StopIf>
				<IsVariableBool name="isMannequin">true</IsVariableBool>
				<IsRenderMod>RENDER_MOD_MINI_YOU</IsRenderMod>
			</StopIf>
            
            <SpriteRender name="power_main" offset="0,-10024.20" drawShadow="true" scale="0.5,0.5" onState="Motion.Idle|Motion.Move|Motion.Jump|Motion.Fall"/>
            
            <SpriteRender name="p_power" offset="0,-10024.20" drawShadow="true" scale="0.5,0.5" onState="Motion.Punch"/>
		</RenderInFront>

		<RenderShoes>
			<StopIf>
				<IsSitting>true</IsSitting>
				<IsSleepingOnaBed>true</IsSleepingOnaBed>
				<IsWearing slot="SHIRT">ITEM_ID_TACTICAL_STEALTH_DEVICE</IsWearing>
			</StopIf>
		</RenderShoes>
        
        <OnPunchStart>
            <ParticleSystemUpdate name="PunchBurst"/>
        </OnPunchStart>
        
        <OnKilled>
            <ParticleSystemUpdate name="DeathParticle"/>
        </OnKilled>
	</RenderRules>
</ItemRenderer>
